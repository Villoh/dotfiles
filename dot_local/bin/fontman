#!/bin/bash
# fontman v3.0 - Simple Font Manager

VERSION="3.0.0"

# Paths
CONFIG_DIR="$HOME/.config/fontman"
CONFIG_FILE="$CONFIG_DIR/config"
DB_FILE="$CONFIG_DIR/fonts"
CACHE_DIR="$CONFIG_DIR/cache"

# Defaults
FONTS_DIR="$HOME/.local/share/fonts/fontman"
CACHE_TTL_VERSION=3600
CACHE_TTL_FONTS=86400

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

# ========== INIT ==========

init() {
    mkdir -p "$CONFIG_DIR" "$CACHE_DIR"

    if [[ ! -f "$CONFIG_FILE" ]]; then
        cat > "$CONFIG_FILE" << 'EOF'
# FontMan Configuration

# Installation directory
FONTS_DIR="$HOME/.local/share/fonts/fontman"

# Cache TTL (seconds)
CACHE_TTL_VERSION=3600    # 1 hour
CACHE_TTL_FONTS=86400     # 24 hours

# Repositories (name|url)
nerdfonts|https://github.com/ryanoasis/nerd-fonts
EOF
    fi

    load_config

    mkdir -p "$FONTS_DIR"
    [[ ! -f "$DB_FILE" ]] && touch "$DB_FILE"
}

load_config() {
    while IFS='=' read -r key value; do
        [[ "$key" =~ ^#.*$ ]] && continue
        [[ -z "$key" ]] && continue
        [[ "$key" =~ \| ]] && continue

        key=$(echo "$key" | xargs)
        value="${value%%#*}"
        value=$(echo "$value" | xargs)

        eval "export $key=\"$value\""
    done < "$CONFIG_FILE"

    FONTS_DIR=$(eval echo "$FONTS_DIR")
}

# ========== UTILS ==========

msg_info()    { echo -e "${BLUE}ℹ${NC} $1"; }
msg_success() { echo -e "${GREEN}✓${NC} $1"; }
msg_error()   { echo -e "${RED}✗${NC} $1" >&2; }
msg_warn()    { echo -e "${YELLOW}⚠${NC} $1"; }

confirm() {
    local prompt="$1" default="${2:-n}"
    [[ "$default" == "y" ]] && prompt="$prompt [Y/n]" || prompt="$prompt [y/N]"
    read -rp "$(echo -e "${YELLOW}${prompt}${NC} ")" response
    response=${response:-$default}
    [[ "$response" =~ ^[Yy]$ ]]
}

is_github_url() {
    [[ "$1" =~ ^https://github\.com/ ]]
}

is_font_file() {
    [[ "$1" =~ \.(ttf|otf|ttc)$ ]]
}

is_zip_file() {
    [[ "$1" =~ \.zip$ ]]
}

# ========== REPOS ==========

get_api_url() {
    local github_url="$1"
    echo "https://api.github.com/repos/${github_url#https://github.com/}"
}

get_repo_url() {
    local repo_name="$1"
    grep "^$repo_name|" "$CONFIG_FILE" 2>/dev/null | cut -d'|' -f2
}

list_repos() {
    grep '|' "$CONFIG_FILE" 2>/dev/null | grep -v '^#' | cut -d'|' -f1
}

get_default_repo() {
    list_repos | head -1
}

# ========== GITHUB API ==========

##
# Obtiene la última versión (tag) de un repositorio.
# Acepta tanto nombre de repo registrado en config como URL directa de GitHub.
#
# @param $1  Nombre del repo (ej: nerdfonts) o URL (ej: https://github.com/org/repo)
##
get_latest_version() {
    local repo_name="$1"
    # Sanitize para nombre de caché (reemplaza / por _)
    local cache="$CACHE_DIR/${repo_name//\//_}_version"
    # Sanitiza también : para nombres de caché en sistemas de ficheros
    cache="${cache//:/_}"

    if [[ -f "$cache" ]] && [[ $(($(date +%s) - $(stat -c %Y "$cache"))) -lt $CACHE_TTL_VERSION ]]; then
        cat "$cache"
        return
    fi

    local repo_url
    if is_github_url "$repo_name"; then
        repo_url="$repo_name"
    else
        repo_url=$(get_repo_url "$repo_name")
    fi

    [[ -z "$repo_url" ]] && { msg_error "Cannot resolve repo: $repo_name"; return 1; }

    local api_url
    api_url=$(get_api_url "$repo_url")
    local version
    version=$(curl -s "$api_url/releases/latest" | grep -Po '"tag_name": "\K[^"]*')

    echo "$version" | tee "$cache"
}

get_available_fonts() {
    local repo_name="$1"
    local cache="$CACHE_DIR/${repo_name}_fonts"

    if [[ -f "$cache" ]] && [[ $(($(date +%s) - $(stat -c %Y "$cache"))) -lt $CACHE_TTL_FONTS ]]; then
        cat "$cache"
        return
    fi

    local repo_url
    repo_url=$(get_repo_url "$repo_name")
    local api_url
    api_url=$(get_api_url "$repo_url")

    curl -s "$api_url/releases/latest" | \
        grep -Po '"name": "\K[^"]*\.zip' | \
        sed 's/\.zip$//' | \
        sort | \
        tee "$cache"
}

##
# Obtiene los assets de un release de GitHub filtrando por extensiones de fuente.
# Devuelve las URLs de descarga de assets relevantes (.zip, .ttf, .otf, .ttc).
#
# @param $1  URL del repositorio de GitHub
##
get_assets_from_url() {
    local repo_url="$1"
    local api_url
    api_url=$(get_api_url "$repo_url")

    curl -s "$api_url/releases/latest" | \
        grep -Po '"browser_download_url": "\K[^"]*' | \
        grep -iE '\.(zip|ttf|otf|ttc)$' | \
        grep -viE '(checksum|sha256|md5|LICENSE|README)'
}

find_font() {
    local search="$1"
    local repo_name="$2"
    local fonts
    mapfile -t fonts < <(get_available_fonts "$repo_name")

    for font in "${fonts[@]}"; do
        [[ "$font" == "$search" ]] && echo "$font" && return 0
    done

    for font in "${fonts[@]}"; do
        [[ "${font,,}" == "${search,,}" ]] && echo "$font" && return 0
    done

    for font in "${fonts[@]}"; do
        [[ "${font,,}" == *"${search,,}"* ]] && echo "$font" && return 0
    done

    return 1
}

# ========== INTERACTIVE PICKER ==========

##
# Selector interactivo de assets.
# Usa fzf con multiselect si está disponible, sino fallback a menú numerado.
#
# @param $@  Lista de URLs de assets para mostrar
# @stdout    URLs seleccionadas (una por línea)
##
interactive_picker() {
    local assets=("$@")
    local names=()

    # Extraer solo el nombre del fichero para mostrar
    for url in "${assets[@]}"; do
        names+=("$(basename "$url")")
    done

    if command -v fzf &>/dev/null; then
        # fzf multiselect: devuelve nombres seleccionados
        local selected
        selected=$(printf '%s\n' "${names[@]}" | fzf \
            --multi \
            --prompt="Select fonts (TAB to multi-select, ENTER to confirm): " \
            --header="Assets from release" \
            --height=40% \
            --border \
            --ansi)

        [[ -z "$selected" ]] && return 1

        # Traducir nombres de vuelta a URLs
        while IFS= read -r name; do
            for url in "${assets[@]}"; do
                [[ "$(basename "$url")" == "$name" ]] && echo "$url"
            done
        done <<< "$selected"
    else
        # Fallback: menú numerado con multiselect manual
        echo ""
        echo -e "${BOLD}Available assets:${NC}"
        echo ""

        local i=1
        for name in "${names[@]}"; do
            echo -e "  ${CYAN}[$i]${NC} $name"
            ((i++))
        done

        echo ""
        echo -e "${YELLOW}Enter numbers separated by spaces (e.g: 1 3 5), or 'all':${NC} "
        read -r selection

        if [[ "$selection" == "all" ]]; then
            printf '%s\n' "${assets[@]}"
            return 0
        fi

        for num in $selection; do
            if [[ "$num" =~ ^[0-9]+$ ]] && (( num >= 1 && num <= ${#assets[@]} )); then
                echo "${assets[$((num - 1))]}"
            else
                msg_warn "Invalid selection: $num"
            fi
        done
    fi
}

# ========== INSTALL HELPERS ==========

##
# Instala un asset desde una URL de descarga directa.
# Si es .zip lo extrae, si es fuente directa la copia al directorio.
#
# @param $1  URL del asset
# @param $2  Nombre del directorio destino en FONTS_DIR
##
install_asset() {
    local url="$1"
    local font_name="$2"
    local font_dir="$FONTS_DIR/$font_name"
    local filename
    filename=$(basename "$url")

    mkdir -p "$font_dir"

    if is_zip_file "$filename"; then
        local temp_zip="/tmp/fontman_${filename}"
        if wget -q --show-progress "$url" -O "$temp_zip" 2>&1; then
            if unzip -q "$temp_zip" -d "$font_dir"; then
                rm -f "$temp_zip"
                return 0
            else
                msg_error "Extraction failed for $filename"
                rm -rf "$font_dir" "$temp_zip"
                return 1
            fi
        else
            msg_error "Download failed: $url"
            rm -f "$temp_zip"
            return 1
        fi
    elif is_font_file "$filename"; then
        if wget -q --show-progress "$url" -O "$font_dir/$filename" 2>&1; then
            return 0
        else
            msg_error "Download failed: $url"
            rm -rf "$font_dir"
            return 1
        fi
    else
        msg_error "Unsupported asset type: $filename"
        return 1
    fi
}

# ========== DATABASE ==========

db_add()    { echo "$1|$2|$3" >> "$DB_FILE"; }
db_remove() {
    grep -v "^$1|" "$DB_FILE" > "$DB_FILE.tmp" 2>/dev/null
    mv "$DB_FILE.tmp" "$DB_FILE" 2>/dev/null
}
db_get()    { grep "^$1|" "$DB_FILE" 2>/dev/null; }
db_list()   { [[ -s "$DB_FILE" ]] && cat "$DB_FILE"; }
db_update() { db_remove "$1"; db_add "$1" "$2" "$3"; }

# ========== COMMANDS ==========

##
# Instala fuentes. Acepta:
#   - Nombres de fuentes de un repo registrado: fontman install JetBrainsMono
#   - URLs directas de GitHub:                  fontman install https://github.com/org/repo
#
# @param $@  Nombres de fuentes, URLs de GitHub, o flags (--repo=<name>)
##
cmd_install() {
    local repo_name
    repo_name=$(get_default_repo)
    local targets=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --repo=*) repo_name="${1#*=}"; shift ;;
            --repo)   repo_name="$2"; shift 2 ;;
            *)        targets+=("$1"); shift ;;
        esac
    done

    [[ ${#targets[@]} -eq 0 ]] && { msg_error "Specify font name or GitHub URL"; return 1; }

    for target in "${targets[@]}"; do
        if is_github_url "$target"; then
            _install_from_github_url "$target"
        else
            _install_from_repo "$target" "$repo_name"
        fi
    done

    fc-cache -fv >/dev/null 2>&1
    msg_success "Font cache updated"
}

##
# Instala una fuente desde un repo registrado en la config.
#
# @param $1  Nombre de la fuente a buscar
# @param $2  Nombre del repositorio
##
_install_from_repo() {
    local search_term="$1"
    local repo_name="$2"

    local repo_url
    repo_url=$(get_repo_url "$repo_name")
    [[ -z "$repo_url" ]] && { msg_error "Repository not found: $repo_name"; return 1; }

    local version
    version=$(get_latest_version "$repo_name")
    msg_info "Repository: ${BOLD}$repo_name${NC} — Version: ${BOLD}$version${NC}"

    if db_get "$search_term" &>/dev/null; then
        msg_warn "$search_term already installed"
        return 0
    fi

    local font_name
    font_name=$(find_font "$search_term" "$repo_name")
    if [[ -z "$font_name" ]]; then
        msg_error "Font not found: $search_term"
        return 1
    fi

    [[ "$font_name" != "$search_term" ]] && msg_info "Found: $font_name"

    msg_info "Installing $font_name..."
    local url="$repo_url/releases/latest/download/${font_name}.zip"

    if install_asset "$url" "$font_name"; then
        db_add "$font_name" "$version" "$repo_name"
        msg_success "$font_name installed"
    fi
}

##
# Instala fuentes desde una URL de GitHub arbitraria.
# Obtiene los assets del último release, presenta un picker interactivo
# y descarga los seleccionados.
#
# @param $1  URL del repositorio de GitHub (https://github.com/org/repo)
##
_install_from_github_url() {
    local repo_url="$1"

    msg_info "Fetching release assets from ${BOLD}$repo_url${NC}..."

    local version
    version=$(get_latest_version "$repo_url")
    [[ -z "$version" ]] && { msg_error "Could not fetch release info from $repo_url"; return 1; }

    msg_info "Latest release: ${BOLD}$version${NC}"

    local assets=()
    mapfile -t assets < <(get_assets_from_url "$repo_url")

    [[ ${#assets[@]} -eq 0 ]] && { msg_error "No font assets found in latest release"; return 1; }

    echo ""

    local selected=()
    mapfile -t selected < <(interactive_picker "${assets[@]}")

    [[ ${#selected[@]} -eq 0 ]] && { msg_warn "No assets selected"; return 0; }

    echo ""

    for asset_url in "${selected[@]}"; do
        local filename
        filename=$(basename "$asset_url")
        # Nombre de la fuente: sin extensión, usado como clave en la DB
        local font_name="${filename%.*}"

        if db_get "$font_name" &>/dev/null; then
            msg_warn "$font_name already installed"
            continue
        fi

        msg_info "Installing $filename..."

        if install_asset "$asset_url" "$font_name"; then
            # Guardamos la URL del repo como origen para que update funcione
            db_add "$font_name" "$version" "$repo_url"
            msg_success "$font_name installed"
        fi
    done
}

cmd_remove() {
    [[ $# -eq 0 ]] && { msg_error "Specify font name"; return 1; }

    for font in "$@"; do
        local info
        info=$(db_get "$font")
        [[ -z "$info" ]] && { msg_warn "$font not installed"; continue; }

        confirm "Remove $font?" "n" || continue

        rm -rf "$FONTS_DIR/$font"
        db_remove "$font"
        msg_success "$font removed"
    done

    fc-cache -fv >/dev/null 2>&1
}

##
# Actualiza fuentes instaladas.
# Soporta tanto fuentes de repos registrados como fuentes instaladas desde URL directa.
#
# @param $@  Nombres de fuentes a actualizar (vacío = todas)
##
cmd_update() {
    local fonts=()

    if [[ $# -eq 0 ]]; then
        readarray -t fonts < <(db_list | cut -d'|' -f1)
    else
        fonts=("$@")
    fi

    [[ ${#fonts[@]} -eq 0 ]] && { msg_warn "No fonts installed"; return 0; }

    local updates=()
    echo ""

    for font in "${fonts[@]}"; do
        local info
        info=$(db_get "$font")
        [[ -z "$info" ]] && { msg_warn "$font not installed"; continue; }

        IFS='|' read -r name current_ver repo <<< "$info"

        local latest
        latest=$(get_latest_version "$repo")

        if [[ -z "$latest" ]]; then
            msg_warn "Could not check version for $name"
            continue
        fi

        if [[ "$current_ver" != "$latest" ]]; then
            updates+=("$name|$repo|$latest")
            echo -e "${YELLOW}⬆${NC} $name: $current_ver → $latest"
        else
            echo -e "${GREEN}✓${NC} $name: up to date"
        fi
    done

    [[ ${#updates[@]} -eq 0 ]] && { msg_success "All fonts up to date"; return 0; }

    echo ""
    confirm "Update ${#updates[@]} font(s)?" "y" || return 0

    for update in "${updates[@]}"; do
        IFS='|' read -r name repo latest <<< "$update"

        msg_info "Updating $name..."
        rm -rf "$FONTS_DIR/$name"

        if is_github_url "$repo"; then
            # Instalado desde URL directa — buscar asset coincidente en el release
            local assets=()
            mapfile -t assets < <(get_assets_from_url "$repo")

            # Buscar el asset cuyo nombre base coincida con el font_name guardado
            local asset_url=""
            for url in "${assets[@]}"; do
                local candidate
                candidate=$(basename "$url")
                candidate="${candidate%.*}"
                if [[ "${candidate,,}" == "${name,,}" ]]; then
                    asset_url="$url"
                    break
                fi
            done

            if [[ -z "$asset_url" ]]; then
                msg_error "Cannot find asset for '$name' in $repo"
                # Ofrecemos picker manual para elegir el asset correcto
                msg_warn "Select manually:"
                local selected=()
                mapfile -t selected < <(interactive_picker "${assets[@]}")
                [[ ${#selected[@]} -gt 0 ]] && asset_url="${selected[0]}"
            fi

            [[ -z "$asset_url" ]] && continue

            if install_asset "$asset_url" "$name"; then
                db_update "$name" "$latest" "$repo"
                msg_success "$name updated"
            fi
        else
            # Repo registrado en config (nerdfonts, etc.)
            local repo_url
            repo_url=$(get_repo_url "$repo")
            local url="$repo_url/releases/latest/download/${name}.zip"

            if wget -q --show-progress "$url" -O /tmp/fontman_update.zip && \
               unzip -q /tmp/fontman_update.zip -d "$FONTS_DIR/$name"; then
                db_update "$name" "$latest" "$repo"
                msg_success "$name updated"
            fi
            rm -f /tmp/fontman_update.zip
        fi
    done

    fc-cache -fv >/dev/null 2>&1
    msg_success "Font cache updated"
}

cmd_list() {
    if ! db_list &>/dev/null; then
        msg_warn "No fonts installed"
        return 0
    fi

    echo -e "${BOLD}Installed fonts:${NC}"
    echo ""

    db_list | while IFS='|' read -r name version repo; do
        local count
        count=$(find "$FONTS_DIR/$name" -type f \( -iname "*.ttf" -o -iname "*.otf" -o -iname "*.ttc" \) 2>/dev/null | wc -l)
        # Mostrar el origen de forma legible
        local origin
        is_github_url "$repo" && origin="$repo" || origin="repo:$repo"
        echo -e "  ${GREEN}●${NC} ${BOLD}$name${NC} ($version) [$origin] - $count files"
    done
}

cmd_search() {
    local query="${1:-}"
    local repo_name="${2:-$(get_default_repo)}"

    local fonts
    mapfile -t fonts < <(get_available_fonts "$repo_name")
    [[ ${#fonts[@]} -eq 0 ]] && { msg_error "Could not fetch fonts"; return 1; }

    echo -e "${BOLD}Available in $repo_name:${NC}"
    echo ""

    local count=0
    for font in "${fonts[@]}"; do
        [[ -n "$query" ]] && [[ ! "${font,,}" =~ "${query,,}" ]] && continue

        if db_get "$font" &>/dev/null; then
            echo -e "  ${GREEN}[installed]${NC} $font"
        else
            echo -e "  ${BLUE}[available]${NC} $font"
        fi
        ((count++))
    done

    echo ""
    echo -e "${BOLD}Total: $count${NC}"
}

cmd_repos() {
    echo -e "${BOLD}Configured repositories:${NC}"
    echo ""

    while IFS='|' read -r name url; do
        echo -e "  ${GREEN}●${NC} ${BOLD}$name${NC}"
        echo "      $url"
    done < <(grep '|' "$CONFIG_FILE" | grep -v '^#')

    echo ""
    echo "Edit: $CONFIG_FILE"
}

cmd_config() {
    echo -e "${BOLD}FontMan Configuration:${NC}"
    echo ""
    echo -e "  ${CYAN}FONTS_DIR${NC}         = $FONTS_DIR"
    echo -e "  ${CYAN}CACHE_TTL_VERSION${NC} = $CACHE_TTL_VERSION"
    echo -e "  ${CYAN}CACHE_TTL_FONTS${NC}   = $CACHE_TTL_FONTS"
    echo ""
    echo "Edit: $CONFIG_FILE"
}

cmd_clean() {
    msg_info "Cleaning cache..."
    rm -rf "$CACHE_DIR"/*
    msg_success "Cache cleaned"

    local orphans=0
    for dir in "$FONTS_DIR"/*; do
        [[ ! -d "$dir" ]] && continue
        local name
        name=$(basename "$dir")

        if ! db_get "$name" &>/dev/null; then
            msg_warn "Orphaned: $name"
            confirm "Remove?" "n" && { rm -rf "$dir"; ((orphans++)); }
        fi
    done

    [[ $orphans -gt 0 ]] && fc-cache -fv >/dev/null 2>&1
}

show_help() {
    echo -e "${BOLD}${CYAN}FontMan${NC} - Simple Font Manager v$VERSION"
    echo ""
    echo -e "${BOLD}USAGE:${NC}"
    echo "    fontman <command> [options] [arguments]"
    echo ""
    echo -e "${BOLD}COMMANDS:${NC}"
    echo -e "    ${GREEN}install${NC} <font|url>...   Install fonts from repo or GitHub URL"
    echo "                              --repo=<name> specify repository"
    echo -e "    ${GREEN}remove${NC} <font>...        Remove fonts"
    echo -e "    ${GREEN}update${NC} [font]...        Update fonts (all if no args)"
    echo -e "    ${GREEN}list${NC}                    List installed fonts"
    echo -e "    ${GREEN}search${NC} [query] [repo]   Search fonts in registered repos"
    echo -e "    ${GREEN}repos${NC}                   List repositories"
    echo -e "    ${GREEN}config${NC}                  Show configuration"
    echo -e "    ${GREEN}clean${NC}                   Clean cache and orphans"
    echo -e "    ${GREEN}help${NC}                    Show this help"
    echo ""
    echo -e "${BOLD}EXAMPLES:${NC}"
    echo "    fontman install JetBrainsMono FiraCode"
    echo "    fontman install Hack --repo=nerdfonts"
    echo "    fontman install https://github.com/subframe7536/maple-font"
    echo "    fontman install https://github.com/tonsky/FiraCode"
    echo "    fontman search mono"
    echo "    fontman update"
    echo ""
    echo -e "${BOLD}FILES:${NC}"
    echo "    Fonts:  $FONTS_DIR"
    echo "    Config: $CONFIG_FILE"
    echo "    DB:     $DB_FILE"
}

# ========== MAIN ==========

main() {
    init

    local cmd="${1:-help}"
    shift 2>/dev/null

    case "$cmd" in
        install|i)      cmd_install "$@" ;;
        remove|rm)      cmd_remove "$@" ;;
        update|up)      cmd_update "$@" ;;
        list|ls)        cmd_list ;;
        search|find)    cmd_search "$@" ;;
        repos)          cmd_repos ;;
        config)         cmd_config ;;
        clean)          cmd_clean ;;
        help|-h)        show_help ;;
        version|-v)     echo "fontman v$VERSION" ;;
        *)
            msg_error "Unknown command: $cmd"
            echo "Use 'fontman help'"
            return 1
            ;;
    esac
}

main "$@"
