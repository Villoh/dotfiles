#!/bin/bash
set -uo pipefail

script_path="${BASH_SOURCE[0]}"
if command -v readlink >/dev/null 2>&1; then
  resolved_path="$(readlink -f -- "$script_path" 2>/dev/null || printf '%s\n' "$script_path")"
else
  resolved_path="$script_path"
fi

script_dir="$(cd -- "$(dirname -- "$resolved_path")" && pwd -P)"
repo_root="$(cd -- "$script_dir/../.." && pwd -P)"
template_file="$repo_root/.chezmoiscripts/run_onchange_01_linux-secrets.sh.tmpl"

if [[ ! -f "$template_file" ]]; then
  echo "  [FAIL] Linux secrets template not found: $template_file" >&2
  exit 1
fi

if ! command -v python3 >/dev/null 2>&1; then
  echo "  [FAIL] python3 is required to process secrets.json" >&2
  exit 1
fi

rendered="$(python3 - "$template_file" "$repo_root" <<'PY'
import re
import sys
from pathlib import Path

template = Path(sys.argv[1]).read_text(encoding="utf-8")
repo_root = sys.argv[2]
script = re.sub(r"^\{\{ if.*?\}\}\n", "", template)
script = re.sub(r"\n\{\{ end -\}\}\s*$", "", script)
script = script.replace("{{ .chezmoi.sourceDir }}", repo_root)
script = re.sub(r"^# secrets\.json.*\n", "", script, flags=re.MULTILINE)
print(script)
PY
)"

bash <<< "$rendered"
