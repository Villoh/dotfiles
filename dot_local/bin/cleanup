#!/bin/bash
#
# Script de limpieza del sistema para Arch Linux / CachyOS
# Limpia caché de paquetes, logs, archivos temporales, etc.
#
# Uso: cleanup [--noconfirm] [--help]

# Colores para output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# Variables globales
NOCONFIRM=false
USER_REPLY=""

# Parsear argumentos
while [[ $# -gt 0 ]]; do
    case $1 in
        --noconfirm)
            NOCONFIRM=true
            shift
            ;;
        --help|-h)
            echo "Uso: $(basename $0) [OPCIONES]"
            echo
            echo "Opciones:"
            echo "  --noconfirm    Ejecutar sin pedir confirmación (usa valores por defecto)"
            echo "  --help, -h     Mostrar esta ayuda"
            echo
            echo "Comportamiento con --noconfirm:"
            echo "  - Limpia archivos temporales de pacman"
            echo "  - Ejecuta 'pacman -Sc' (conserva versiones instaladas)"
            echo "  - Elimina paquetes huérfanos"
            echo "  - Ejecuta 'yay/paru -Sc' si están instalados"
            echo "  - Limpia logs >2 semanas"
            echo "  - Vacía la papelera"
            echo "  - NO limpia caché de usuario ni thumbnails (conservador)"
            exit 0
            ;;
        *)
            echo "Argumento desconocido: $1"
            echo "Usa --help para ver las opciones disponibles"
            exit 1
            ;;
    esac
done

# Función para imprimir con color
print_status() {
    echo -e "${GREEN}[✓]${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}[!]${NC} $1"
}

print_error() {
    echo -e "${RED}[✗]${NC} $1"
}

print_info() {
    echo -e "${BLUE}[i]${NC} $1"
}

print_step() {
    echo -e "${CYAN}[Paso $1/$2]${NC} $3"
}

# Función para obtener espacio usado
get_size() {
    du -sh "$1" 2>/dev/null | cut -f1 || echo "0"
}

# Función para preguntar con opción de --noconfirm
# Uso: ask "mensaje" "default_value"
# default_value: Y, N, 1, 2, etc.
ask() {
    local message="$1"
    local default="$2"

    if [[ "$NOCONFIRM" == true ]]; then
        USER_REPLY="$default"
        echo -e "$message [auto: $default]"
    else
        read -p "$message " -n 1 -r USER_REPLY
        echo
    fi
}

# Banner
echo "=================================="
echo "  Sistema de Limpieza - Arch/CachyOS"
echo "=================================="
if [[ "$NOCONFIRM" == true ]]; then
    print_info "Modo automático activado (--noconfirm)"
fi
echo

# Verificar si es root para ciertas operaciones
if [[ $EUID -ne 0 ]]; then
    print_warning "Algunas operaciones requieren sudo. Se solicitará cuando sea necesario."
    echo
fi

TOTAL_STEPS=9

# 1. Limpiar archivos temporales de pacman
echo
print_step 1 $TOTAL_STEPS "Verificando archivos temporales de pacman"
TEMP_FILES=$(sudo find /var/cache/pacman/pkg/ -name "download-*" -o -name "*.part" 2>/dev/null)
if [[ -n "$TEMP_FILES" ]]; then
    TEMP_COUNT=$(echo "$TEMP_FILES" | wc -l)
    print_info "Encontrados $TEMP_COUNT archivos temporales"
    sudo rm -f /var/cache/pacman/pkg/download-* /var/cache/pacman/pkg/*.part 2>/dev/null
    print_status "Archivos temporales eliminados"
else
    print_status "No hay archivos temporales que limpiar"
fi

# 2. Limpiar caché de pacman (paquetes antiguos)
echo
print_step 2 $TOTAL_STEPS "Limpieza de caché de pacman"
CACHE_SIZE=$(get_size /var/cache/pacman/pkg/)
print_status "Caché actual de pacman: $CACHE_SIZE"
if [[ "$NOCONFIRM" == false ]]; then
    print_info "  1 = -Sc  → Borrar solo versiones antiguas (mantiene paquetes instalados)"
    print_info "  2 = -Scc → Borrar TODO el caché (libera más espacio)"
fi
ask "¿Qué hacer? [1/2/n]" "1"
if [[ $USER_REPLY == "1" ]]; then
    if [[ "$NOCONFIRM" == true ]]; then
        yes | sudo pacman -Sc
    else
        sudo pacman -Sc
    fi
    NEW_SIZE=$(get_size /var/cache/pacman/pkg/)
    print_status "Caché limpiado. Nuevo tamaño: $NEW_SIZE"
elif [[ $USER_REPLY == "2" ]]; then
    if [[ "$NOCONFIRM" == true ]]; then
        yes | sudo pacman -Scc
    else
        sudo pacman -Scc
    fi
    NEW_SIZE=$(get_size /var/cache/pacman/pkg/)
    print_status "Caché limpiado completamente. Nuevo tamaño: $NEW_SIZE"
else
    print_info "Caché de pacman sin cambios"
fi

# 3. Paquetes huérfanos
echo
print_step 3 $TOTAL_STEPS "Buscando paquetes huérfanos"
print_info "Paquetes huérfanos = dependencias que ya no necesita ningún paquete instalado"
ORPHANS=$(pacman -Qtdq 2>/dev/null)
if [[ -n "$ORPHANS" ]]; then
    ORPHAN_COUNT=$(echo "$ORPHANS" | wc -l)
    print_warning "$ORPHAN_COUNT paquetes huérfanos encontrados:"
    echo "$ORPHANS"
    ask "¿Eliminar paquetes huérfanos? [Y/n]" "Y"
    if [[ $USER_REPLY =~ ^[Yy]$ ]] || [[ -z $USER_REPLY ]]; then
        sudo pacman -Rns $(pacman -Qtdq) --noconfirm
        print_status "Paquetes huérfanos eliminados"
    else
        print_info "Paquetes huérfanos conservados"
    fi
else
    print_status "No hay paquetes huérfanos"
fi

# 4. Caché de AUR helper (yay/paru)
echo
print_step 4 $TOTAL_STEPS "Limpieza de caché de AUR helper"
if command -v yay &> /dev/null; then
    YAY_CACHE=$(get_size ~/.cache/yay/ 2>/dev/null || echo "0")
    if [[ "$YAY_CACHE" != "0" ]]; then
        print_status "Caché de yay: $YAY_CACHE"
        if [[ "$NOCONFIRM" == false ]]; then
            print_info "  1 = -Sc  → Borrar solo versiones antiguas"
            print_info "  2 = -Scc → Borrar TODO el caché de AUR"
        fi
        ask "¿Qué hacer? [1/2/n]" "1"
        if [[ $USER_REPLY == "1" ]]; then
            if [[ "$NOCONFIRM" == true ]]; then
                yes | yay -Sc
            else
                yay -Sc
            fi
            print_status "Caché de yay limpiado"
        elif [[ $USER_REPLY == "2" ]]; then
            if [[ "$NOCONFIRM" == true ]]; then
                yes | yay -Scc
            else
                yay -Scc
            fi
            print_status "Caché de yay limpiado completamente"
        else
            print_info "Caché de yay sin cambios"
        fi
    else
        print_status "No hay caché de yay que limpiar"
    fi
elif command -v paru &> /dev/null; then
    PARU_CACHE=$(get_size ~/.cache/paru/ 2>/dev/null || echo "0")
    if [[ "$PARU_CACHE" != "0" ]]; then
        print_status "Caché de paru: $PARU_CACHE"
        if [[ "$NOCONFIRM" == false ]]; then
            print_info "  1 = -Sc  → Borrar solo versiones antiguas"
            print_info "  2 = -Scc → Borrar TODO el caché de AUR"
        fi
        ask "¿Qué hacer? [1/2/n]" "1"
        if [[ $USER_REPLY == "1" ]]; then
            if [[ "$NOCONFIRM" == true ]]; then
                yes | paru -Sc
            else
                paru -Sc
            fi
            print_status "Caché de paru limpiado"
        elif [[ $USER_REPLY == "2" ]]; then
            if [[ "$NOCONFIRM" == true ]]; then
                yes | paru -Scc
            else
                paru -Scc
            fi
            print_status "Caché de paru limpiado completamente"
        else
            print_info "Caché de paru sin cambios"
        fi
    else
        print_status "No hay caché de paru que limpiar"
    fi
else
    print_info "No se encontró yay ni paru"
fi

# 5. Logs del sistema (journalctl)
echo
print_step 5 $TOTAL_STEPS "Limpieza de logs del sistema"
JOURNAL_SIZE=$(journalctl --disk-usage 2>/dev/null | grep -oP '\d+\.\d+[A-Z]' | head -1 || echo "desconocido")
print_status "Tamaño actual de logs: $JOURNAL_SIZE"
ask "¿Limpiar logs antiguos (>2 semanas)? [Y/n]" "Y"
if [[ $USER_REPLY =~ ^[Yy]$ ]] || [[ -z $USER_REPLY ]]; then
    BEFORE_SIZE=$JOURNAL_SIZE
    sudo journalctl --vacuum-time=2weeks
    NEW_SIZE=$(journalctl --disk-usage 2>/dev/null | grep -oP '\d+\.\d+[A-Z]' | head -1 || echo "desconocido")
    if [[ "$BEFORE_SIZE" == "$NEW_SIZE" ]]; then
        print_status "Logs sin cambios (todos son recientes, <2 semanas)"
    else
        print_status "Logs limpiados. Nuevo tamaño: $NEW_SIZE"
    fi
fi

# 6. Papelera del usuario
echo
print_step 6 $TOTAL_STEPS "Limpieza de papelera"
TRASH_SIZE=$(get_size ~/.local/share/Trash/ 2>/dev/null || echo "0")
if [[ "$TRASH_SIZE" != "0" ]] && [[ "$TRASH_SIZE" != "4,0K" ]]; then
    print_status "Tamaño de la papelera: $TRASH_SIZE"
    ask "¿Vaciar papelera? [Y/n]" "Y"
    if [[ $USER_REPLY =~ ^[Yy]$ ]] || [[ -z $USER_REPLY ]]; then
        rm -rf ~/.local/share/Trash/{files,info}/* 2>/dev/null
        print_status "Papelera vaciada"
    fi
else
    print_status "La papelera ya está vacía"
fi

# 7. Caché de usuario
echo
print_step 7 $TOTAL_STEPS "Limpieza de caché de usuario"
USER_CACHE_SIZE=$(get_size ~/.cache/ 2>/dev/null || echo "0")
print_status "Tamaño del caché de usuario: $USER_CACHE_SIZE"
if [[ "$NOCONFIRM" == false ]]; then
    print_warning "Esto incluye caché de navegadores, aplicaciones, etc."
fi
ask "¿Limpiar archivos de caché antiguos (>30 días)? [y/N]" "N"
if [[ $USER_REPLY =~ ^[Yy]$ ]]; then
    find ~/.cache/ -type f -atime +30 -delete 2>/dev/null || true
    NEW_CACHE_SIZE=$(get_size ~/.cache/)
    print_status "Caché de usuario limpiado (archivos >30 días)"
    print_status "Nuevo tamaño: $NEW_CACHE_SIZE"
else
    print_info "Caché de usuario sin cambios"
fi

# 8. Thumbnails
echo
print_step 8 $TOTAL_STEPS "Limpieza de miniaturas (thumbnails)"
THUMB_SIZE=$(get_size ~/.cache/thumbnails/ 2>/dev/null || echo "0")
if [[ "$THUMB_SIZE" != "0" ]] && [[ "$THUMB_SIZE" != "4,0K" ]]; then
    print_status "Tamaño de miniaturas: $THUMB_SIZE"
    ask "¿Limpiar thumbnails? [y/N]" "N"
    if [[ $USER_REPLY =~ ^[Yy]$ ]]; then
        rm -rf ~/.cache/thumbnails/* 2>/dev/null
        print_status "Thumbnails eliminados"
    else
        print_info "Thumbnails sin cambios"
    fi
else
    print_status "No hay thumbnails que limpiar"
fi

# 9. Archivos .log antiguos en /var/log
echo
print_step 9 $TOTAL_STEPS "Limpieza de logs rotados antiguos"
OLD_LOGS=$(sudo find /var/log -name "*.log.*" -o -name "*.old" 2>/dev/null | wc -l)
if [[ $OLD_LOGS -gt 0 ]]; then
    print_status "Encontrados $OLD_LOGS archivos de log antiguos en /var/log"
    ask "¿Eliminar logs rotados antiguos? [y/N]" "N"
    if [[ $USER_REPLY =~ ^[Yy]$ ]]; then
        sudo find /var/log -name "*.log.*" -delete 2>/dev/null
        sudo find /var/log -name "*.old" -delete 2>/dev/null
        print_status "Logs antiguos eliminados"
    else
        print_info "Logs rotados sin cambios"
    fi
else
    print_status "No hay logs rotados antiguos que limpiar"
fi

# Resumen final
echo
echo "=================================="
print_status "Limpieza completada ($TOTAL_STEPS pasos)"
echo "=================================="
echo
print_info "Consejo: Ejecuta este script periódicamente para mantener el sistema limpio"
if [[ "$NOCONFIRM" == false ]]; then
    print_info "Usa --noconfirm para ejecutar automáticamente con valores por defecto"
fi
