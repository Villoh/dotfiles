#!/bin/bash
# ~/.local/bin/migrate-aur

# Colores
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
MAGENTA='\033[0;35m'
CYAN='\033[0;36m'
NC='\033[0m'

# Variables
DRY_RUN=false
EXCLUDE_PKGS=()
SPECIFIC_PKGS=()

# Funciأ³n de ayuda
show_help() {
    cat << EOF
${CYAN}Uso:${NC} migrate-aur [OPCIONES] [PAQUETES...]

${YELLOW}Descripciأ³n:${NC}
  Migra paquetes de AUR a repositorios oficiales si estأ،n disponibles.
  Prioridad: cachyos > chaotic-aur > core/extra/multilib
  Busca automأ،ticamente variantes sin sufijos -bin, -git, etc.

${YELLOW}Opciones:${NC}
  -n, --dry-run              Simular migraciأ³n sin realizar cambios
  -e, --exclude PKG[,PKG...] Excluir paquetes de la migraciأ³n
  -h, --help                 Mostrar esta ayuda

${YELLOW}Ejemplos:${NC}
  migrate-aur                    # Migrar todos los paquetes disponibles
  migrate-aur vscodium-bin       # Migrar solo vscodium-bin
  migrate-aur -n                 # Ver quأ© se migrarأ­a (dry-run)
  migrate-aur -e megasync        # Migrar todos excepto megasync
  migrate-aur -e "pkg1,pkg2"     # Excluir mأ؛ltiples paquetes

${GREEN}Nota:${NC} Este proceso NO borra configuraciones de usuario (~/.config, /etc/)
EOF
    exit 0
}

# Funciأ³n para obtener nombre base del paquete (quitar sufijos)
get_base_name() {
    local pkg="$1"
    echo "$pkg" | sed -E 's/-(bin|git|svn|hg|bzr|cvs)$//'
}

# Funciأ³n para buscar paquete en repos
find_in_repos() {
    local aur_pkg="$1"
    local base_name=$(get_base_name "$aur_pkg")
    
    # Primero intentar con el nombre exacto
    local repo=$(pacman -Sp --print-format '%r' "$aur_pkg" 2>/dev/null | head -1)
    if [ -n "$repo" ] && [ "$repo" != "aur" ]; then
        echo "$repo|$aur_pkg"
        return 0
    fi
    
    # Si no existe, intentar con el nombre base (sin sufijo)
    if [ "$base_name" != "$aur_pkg" ]; then
        repo=$(pacman -Sp --print-format '%r' "$base_name" 2>/dev/null | head -1)
        if [ -n "$repo" ] && [ "$repo" != "aur" ]; then
            echo "$repo|$base_name"
            return 0
        fi
    fi
    
    return 1
}

# Parsear argumentos
while [[ $# -gt 0 ]]; do
    case $1 in
        -n|--dry-run)
            DRY_RUN=true
            shift
            ;;
        -e|--exclude)
            IFS=',' read -ra EXCLUDE_PKGS <<< "$2"
            shift 2
            ;;
        -h|--help)
            show_help
            ;;
        -*)
            echo -e "${RED}Error: Opciأ³n desconocida '$1'${NC}"
            echo "Usa --help para ver las opciones disponibles"
            exit 1
            ;;
        *)
            SPECIFIC_PKGS+=("$1")
            shift
            ;;
    esac
done

# Funciأ³n para verificar si un paquete estأ، excluido
is_excluded() {
    local pkg="$1"
    for excluded in "${EXCLUDE_PKGS[@]}"; do
        if [[ "$pkg" == "$excluded" ]]; then
            return 0
        fi
    done
    return 1
}

# Banner
if [ "$DRY_RUN" = true ]; then
    echo -e "${CYAN}================================================================${NC}"
    echo -e "${CYAN}      ${YELLOW}SIMULACIأ“N: MIGRACIأ“N AUR â†’ REPOS (DRY-RUN)${NC}"
    echo -e "${CYAN}================================================================${NC}\n"
else
    echo -e "${CYAN}================================================================${NC}"
    echo -e "${CYAN}         ${YELLOW}MIGRACIأ“N AUR â†’ REPOSITORIOS OFICIALES${NC}"
    echo -e "${CYAN}================================================================${NC}\n"
fi

# Arrays para almacenar paquetes migrables
declare -a migrables_aur_pkg=()
declare -a migrables_repo_pkg=()
declare -a migrables_repo=()
declare -a excluded_list=()

# Obtener lista de paquetes a revisar
if [ ${#SPECIFIC_PKGS[@]} -gt 0 ]; then
    echo -e "${BLUE}ًں”چ Revisando paquetes especأ­ficos...${NC}\n"
    PKGS_TO_CHECK=("${SPECIFIC_PKGS[@]}")
else
    echo -e "${BLUE}ًں”چ Buscando todos los paquetes AUR instalados...${NC}\n"
    mapfile -t PKGS_TO_CHECK < <(pacman -Qem | awk '{print $1}')
fi

# Revisar cada paquete
for aur_pkg in "${PKGS_TO_CHECK[@]}"; do
    if is_excluded "$aur_pkg"; then
        excluded_list+=("$aur_pkg")
        printf "${MAGENTA}âٹک${NC} %-30s ${YELLOW}[AUR]${NC} â†’ ${MAGENTA}[excluido]${NC}\n" "$aur_pkg"
        continue
    fi
    
    if ! pacman -Qm "$aur_pkg" &>/dev/null; then
        printf "${RED}âœ—${NC} %-30s ${RED}no estأ، instalado desde AUR${NC}\n" "$aur_pkg"
        continue
    fi
    
    result=$(find_in_repos "$aur_pkg")
    
    if [ -n "$result" ]; then
        repo=$(echo "$result" | cut -d'|' -f1)
        repo_pkg=$(echo "$result" | cut -d'|' -f2)
        
        migrables_aur_pkg+=("$aur_pkg")
        migrables_repo_pkg+=("$repo_pkg")
        migrables_repo+=("$repo")
        
        if [ "$aur_pkg" != "$repo_pkg" ]; then
            printf "${GREEN}âœ“${NC} %-30s ${YELLOW}[AUR]${NC} â†’ ${BLUE}[%s/%s]${NC}\n" "$aur_pkg" "$repo" "$repo_pkg"
        else
            printf "${GREEN}âœ“${NC} %-30s ${YELLOW}[AUR]${NC} â†’ ${BLUE}[%s]${NC}\n" "$aur_pkg" "$repo"
        fi
    else
        printf "${RED}âœ—${NC} %-30s ${YELLOW}[AUR]${NC} â†’ ${RED}no disponible${NC}\n" "$aur_pkg"
    fi
done

# Resumen
echo -e "\n${CYAN}================================================================${NC}"
echo -e "${CYAN}                       ${YELLOW}RESUMEN${NC}"
echo -e "${CYAN}================================================================${NC}"
echo -e "${CYAN}Paquetes migrables: ${GREEN}${#migrables_aur_pkg[@]}${NC}"
if [ ${#excluded_list[@]} -gt 0 ]; then
    echo -e "${CYAN}Paquetes excluidos: ${MAGENTA}${#excluded_list[@]}${NC}"
fi
echo -e "${CYAN}================================================================${NC}\n"

# Si no hay nada que migrar
if [ ${#migrables_aur_pkg[@]} -eq 0 ]; then
    echo -e "${GREEN}âœ“ No hay paquetes AUR migrables a repos oficiales.${NC}"
    exit 0
fi

# Si es dry-run, terminar aquأ­
if [ "$DRY_RUN" = true ]; then
    echo -e "${YELLOW}â„¹ï¸ڈ  Modo simulaciأ³n: no se realizaron cambios${NC}"
    echo -e "${YELLOW}ًں’، Ejecuta sin -n | --dry-run para realizar la migraciأ³n${NC}"
    exit 0
fi

# Preguntar si migrar
echo -e "${YELLOW}آ؟Deseas migrar estos paquetes? [s/N]${NC}"
read -r respuesta

if [[ ! "$respuesta" =~ ^[sS]$ ]]; then
    echo -e "${RED}â‌Œ Migraciأ³n cancelada${NC}"
    exit 0
fi

# Migrar paquetes
echo -e "\n${BLUE}ًںڑ€ Iniciando migraciأ³n...${NC}\n"

SUCCESS_COUNT=0
FAILED_COUNT=0

for i in "${!migrables_aur_pkg[@]}"; do
    aur_pkg="${migrables_aur_pkg[$i]}"
    repo_pkg="${migrables_repo_pkg[$i]}"
    repo="${migrables_repo[$i]}"
    
    echo -e "${CYAN}----------------------------------------------------------------${NC}"
    if [ "$aur_pkg" != "$repo_pkg" ]; then
        echo -e "ًں“¦ Migrando: ${GREEN}$aur_pkg${NC} ${YELLOW}[AUR]${NC} â†’ ${BLUE}[$repo/$repo_pkg]${NC}"
    else
        echo -e "ًں“¦ Migrando: ${GREEN}$aur_pkg${NC} ${YELLOW}[AUR]${NC} â†’ ${BLUE}[$repo]${NC}"
    fi
    echo -e "${CYAN}----------------------------------------------------------------${NC}"
    
    echo -e "${YELLOW}Desinstalando versiأ³n AUR ($aur_pkg)...${NC}"
    if sudo pacman -Rdd --noconfirm "$aur_pkg" 2>/dev/null; then
        echo -e "${GREEN}âœ“ Desinstalado${NC}"
    else
        echo -e "${RED}âœ— Error al desinstalar${NC}"
        FAILED_COUNT=$((FAILED_COUNT + 1))
        continue
    fi
    
    echo -e "${YELLOW}Instalando desde $repo ($repo_pkg)...${NC}"
    if sudo pacman -S --noconfirm "$repo/$repo_pkg" 2>/dev/null; then
        echo -e "${GREEN}âœ“ Instalado desde $repo${NC}\n"
        SUCCESS_COUNT=$((SUCCESS_COUNT + 1))
    else
        echo -e "${RED}âœ— Error al instalar, revertiendo...${NC}"
        if paru -S --noconfirm "$aur_pkg" 2>/dev/null; then
            echo -e "${YELLOW}âڑ  Restaurado a versiأ³n AUR${NC}\n"
        else
            echo -e "${RED}âœ— Error crأ­tico: no se pudo restaurar${NC}\n"
        fi
        FAILED_COUNT=$((FAILED_COUNT + 1))
    fi
done

# Resumen final
echo -e "\n${CYAN}================================================================${NC}"
echo -e "${CYAN}                   ${GREEN}MIGRACIأ“N COMPLETADA${NC}"
echo -e "${CYAN}================================================================${NC}"
echo -e "${CYAN}Exitosos:  ${GREEN}$SUCCESS_COUNT${NC}"
echo -e "${CYAN}Fallidos:  ${RED}$FAILED_COUNT${NC}"
echo -e "${CYAN}================================================================${NC}\n"

echo -e "${YELLOW}ًں’، Tip: Ejecuta 'list-packages' para verificar los cambios${NC}"