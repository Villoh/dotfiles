#!/bin/bash
# ~/.local/bin/openvpn-status

# Encuentra VPNs activas con sus PIDs
active_vpns=()
for pidfile in /tmp/openvpn-*.pid; do
  [ -f "$pidfile" ] || continue
  provider=$(basename "$pidfile" | sed 's/openvpn-\(.*\)\.pid/\1/')
  pid=$(sudo cat "$pidfile" 2>/dev/null)
  
  if [ -n "$pid" ] && sudo kill -0 "$pid" 2>/dev/null; then
    active_vpns+=("$provider:$pid")
  fi
done

if [ ${#active_vpns[@]} -eq 0 ]; then
  echo "🔴 VPN: Desconectada"
  echo "IP: $(curl -s --max-time 3 ifconfig.me 2>/dev/null || echo 'N/A')"
  exit 0
fi

echo "🟢 VPN: Conectada (${#active_vpns[@]})"
echo "IP: $(curl -s --max-time 3 ifconfig.me 2>/dev/null || echo 'N/A')"
echo

for vpn_info in "${active_vpns[@]}"; do
  provider="${vpn_info%%:*}"
  pid="${vpn_info##*:}"
  
  echo "📡 $provider (PID: $pid)"
  
  # Info de la interfaz tun
  if ip a show tun0 &>/dev/null; then
    ip a show tun0 | grep -E "inet " | awk '{print "   └─ Túnel:", $2}'
  fi
  
  # Server desde el log (opcional)
  if [ -f "/tmp/openvpn-$provider.log" ]; then
    server=$(sudo grep -m1 "Attempting to establish" "/tmp/openvpn-$provider.log" 2>/dev/null | awk -F'[][]' '{print $2}')
    [ -n "$server" ] && echo "   └─ Server: $server"
  fi
done
