#!/bin/bash
# dotfiles-sync - Sincroniza dotfiles con GitHub
# Uso: dotfiles-sync

set -e

DOTFILES_DIR="$HOME/.dotfiles"
REMOTE="origin"
BRANCH="main"

# Colores para output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# Función para mensajes
msg() { echo -e "${BLUE}==>${NC} $1"; }
success() { echo -e "${GREEN}✓${NC} $1"; }
error() { echo -e "${RED}✗${NC} $1" >&2; exit 1; }
warn() { echo -e "${YELLOW}!${NC} $1"; }

# Verificar que estamos en el directorio correcto
cd "$DOTFILES_DIR" || error "No se encuentra $DOTFILES_DIR"

# Verificar que es un repo git
[[ -d .git ]] || error "No es un repositorio git"

# Verificar conexión con remote
msg "Verificando conexión con GitHub..."
git fetch "$REMOTE" &>/dev/null || error "No se puede conectar con $REMOTE"

# Mostrar estado actual
msg "Estado actual:"
git status --short

# Si no hay cambios, salir
if [[ -z $(git status --porcelain) ]]; then
    success "No hay cambios que sincronizar"
    exit 0
fi

# Mostrar archivos modificados
echo ""
git status --porcelain | while read -r line; do
    status="${line:0:2}"
    file="${line:3}"
    case "$status" in
        "M ") echo -e "  ${YELLOW}●${NC} Modificado: $file" ;;
        "A ") echo -e "  ${GREEN}+${NC} Añadido: $file" ;;
        "D ") echo -e "  ${RED}-${NC} Eliminado: $file" ;;
        "??") echo -e "  ${BLUE}?${NC} Sin seguimiento: $file" ;;
        *) echo -e "  ${status} $file" ;;
    esac
done

# Añadir archivos sin seguimiento automáticamente
if git status --porcelain | grep -q "^??"; then
    msg "Añadiendo archivos sin seguimiento..."
    git add -A
fi

# Si no hay nada en staging, añadir todo
if [[ -z $(git diff --cached --name-only) ]]; then
    msg "Añadiendo cambios..."
    git add -u
fi

# Reemplazar desde línea ~70 hasta el commit
# ELIMINAR toda la función generate_commit_msg() y reemplazar con:

# Generar mensaje simple y claro
COMMIT_MSG="Auto sync: dotfiles - $(date +'%Y-%m-%d %H:%M')"
msg "Mensaje de commit: ${YELLOW}$COMMIT_MSG${NC}"

# Commit
msg "Commiteando cambios..."
git commit -m "$COMMIT_MSG" || error "Error al hacer commit"
success "Commit realizado"

# Pull antes de push
msg "Sincronizando con remote..."
if ! git pull --rebase "$REMOTE" "$BRANCH" 2>/dev/null; then
    warn "Conflictos detectados. Resuélvelos manualmente"
    exit 1
fi

# Push
msg "Subiendo cambios a GitHub..."
git push "$REMOTE" "$BRANCH" || error "Error al hacer push"

success "¡Dotfiles sincronizados!"
echo ""
msg "Commit: $(git log -1 --pretty=format:'%h - %s')"
