#!/bin/bash
# pre-hyde-install.sh - Preparar dotfiles antes de HyDE install

MODULES=("$@")
DOTFILES_DIR="$(chezmoi source-path)"

if [ ${#MODULES[@]} -eq 0 ]; then
    echo "Usage: $0 <module1> <module2> ..."
    echo "Example: $0 gtk nwg-look nwg-displays"
    exit 1
fi

cd "$DOTFILES_DIR" || exit 1

for module in "${MODULES[@]}"; do
    echo "==> Processing module: $module"
    
    # 1. Unstow
    echo "  [1/2] Unstowing $module..."
    stow -D "$module" 2>/dev/null || echo "  Warning: module not stowed"
    
    # 2. Copiar de dotfiles a config
    echo "  [2/2] Copying from dotfiles to config..."
    if [ -d "$DOTFILES_DIR/$module/.config" ]; then
        cp -r "$DOTFILES_DIR/$module/.config/"* "$HOME/.config/"
    fi
    
    echo "  ✓ $module ready for HyDE install"
done

echo ""
echo "==> All modules prepared!"
echo "==> Now run: cd ~/HyDE/Scripts && ./install.sh -r"
echo "==> Then run: ./post-hyde-install.sh ${MODULES[*]}"
