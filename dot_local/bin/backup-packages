#!/bin/bash
set -e

# Colors
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
NC='\033[0m'

BACKUP_DIR="$(chezmoi source-path)/packages/linux"
mkdir -p "${BACKUP_DIR}"

# ── Backup functions ───────────────────────────────────────────────────────────

backup_pacman() {
    echo -e "${GREEN}📦 Pacman packages (explicit):${NC}"
    pacman -Qqe > "${BACKUP_DIR}/pacman.txt"
    echo -e "  ${YELLOW}→ $(wc -l < "${BACKUP_DIR}/pacman.txt") packages saved to pacman.txt${NC}\n"
}

backup_aur() {
    echo -e "${GREEN}🔧 AUR packages:${NC}"
    pacman -Qqm > "${BACKUP_DIR}/aur.txt"
    echo -e "  ${YELLOW}→ $(wc -l < "${BACKUP_DIR}/aur.txt") packages saved to aur.txt${NC}\n"
}

backup_flatpak() {
    if command -v flatpak >/dev/null 2>&1; then
        echo -e "${GREEN}📱 Flatpak packages:${NC}"
        flatpak list --app --columns=application 2>/dev/null > "${BACKUP_DIR}/flatpak.txt" || echo "" > "${BACKUP_DIR}/flatpak.txt"
        echo -e "  ${YELLOW}→ $(wc -l < "${BACKUP_DIR}/flatpak.txt") packages saved to flatpak.txt${NC}\n"
    else
        echo -e "${YELLOW}⚠️  Flatpak not installed, skipping${NC}\n"
    fi
}

backup_uv() {
    if command -v uv >/dev/null 2>&1; then
        echo -e "${GREEN}🐍 uv tools:${NC}"
        uv tool list 2>/dev/null | grep -v '^\s' | awk '{print $1}' > "${BACKUP_DIR}/uv-tools.txt" || echo "" > "${BACKUP_DIR}/uv-tools.txt"
        echo -e "  ${YELLOW}→ $(wc -l < "${BACKUP_DIR}/uv-tools.txt") tools saved to uv-tools.txt${NC}\n"
    else
        echo -e "${YELLOW}⚠️  uv not installed, skipping${NC}\n"
    fi
}

backup_bun() {
    if command -v bun >/dev/null 2>&1; then
        echo -e "${GREEN}🍞 Bun global packages:${NC}"
        bun pm ls -g 2>/dev/null | tail -n +2 | awk '{print $2}' | sed 's/@[^@]*$//' > "${BACKUP_DIR}/bun-global.txt"
        echo -e "  ${YELLOW}→ $(wc -l < "${BACKUP_DIR}/bun-global.txt") packages saved to bun-global.txt${NC}\n"
    else
        echo -e "${YELLOW}⚠️  Bun not installed, skipping${NC}\n"
    fi
}

backup_npm() {
    if command -v npm >/dev/null 2>&1; then
        echo -e "${GREEN}📦 npm global packages:${NC}"
        npm ls -g --depth=0 --json 2>/dev/null | jq -r '.dependencies | keys[]' > "${BACKUP_DIR}/npm-global.txt" || echo "" > "${BACKUP_DIR}/npm-global.txt"
        echo -e "  ${YELLOW}→ $(wc -l < "${BACKUP_DIR}/npm-global.txt") packages saved to npm-global.txt${NC}\n"
    else
        echo -e "${YELLOW}⚠️  npm not installed, skipping${NC}\n"
    fi
}

backup_bin() {
    if command -v bin >/dev/null 2>&1; then
        echo -e "${GREEN}🗃️  bin packages:${NC}"
        bin list 2>/dev/null | grep -E 'https?://' | awk -F'  +' '{print $3}' > "${BACKUP_DIR}/bin-packages.txt" || echo "" > "${BACKUP_DIR}/bin-packages.txt"
        echo -e "  ${YELLOW}→ $(wc -l < "${BACKUP_DIR}/bin-packages.txt") packages saved to bin-packages.txt${NC}\n"
    else
        echo -e "${YELLOW}⚠️  bin not installed, skipping${NC}\n"
    fi
}

backup_brew() {
    if command -v brew >/dev/null 2>&1; then
        echo -e "${GREEN}🍺 Brew packages:${NC}"
        brew leaves > "${BACKUP_DIR}/brew.txt" || echo "" > "${BACKUP_DIR}/brew.txt"
        echo -e "  ${YELLOW}→ $(wc -l < "${BACKUP_DIR}/brew.txt") packages saved to brew.txt${NC}\n"
    else
        echo -e "${YELLOW}⚠️  Brew not installed, skipping${NC}\n"
    fi
}

run_all() {
    backup_pacman
    backup_aur
    backup_flatpak
    backup_uv
    backup_bun
    backup_npm
    backup_bin
    backup_brew
}

# ── Entry point ────────────────────────────────────────────────────────────────

if [[ $# -eq 0 ]]; then
    echo -e "${BLUE}📦 Backing up installed packages...${NC}\n"
    run_all
    echo -e "${GREEN}✅ Backup completed!${NC}"
    echo -e "${BLUE}📁 Location: ${BACKUP_DIR}${NC}"
    exit 0
fi

# Individual flags — can be combined: backup-packages --pacman --aur --bun
HANDLED=false
for arg in "$@"; do
    case "$arg" in
        --pacman)  backup_pacman;  HANDLED=true ;;
        --aur)     backup_aur;     HANDLED=true ;;
        --flatpak) backup_flatpak; HANDLED=true ;;
        --uv)      backup_uv;      HANDLED=true ;;
        --bun)     backup_bun;     HANDLED=true ;;
        --npm)     backup_npm;     HANDLED=true ;;
        --bin)     backup_bin;     HANDLED=true ;;
        --brew)    backup_brew;    HANDLED=true ;;
        --interactive|-i) : ;;  # handled below
        *) echo -e "${YELLOW}⚠️  Unknown flag: $arg${NC}" >&2 ;;
    esac
done

[[ "$HANDLED" == true ]] && exit 0

if [[ "${1:-}" == "--interactive" || "${1:-}" == "-i" ]]; then
    if ! command -v gum >/dev/null 2>&1; then
        echo -e "${YELLOW}⚠️  gum not installed. Install with: sudo pacman -S gum${NC}" >&2
        exit 1
    fi

    gum style \
        --foreground 75 \
        --border-foreground 75 \
        --border double \
        --align center \
        --width 60 \
        --margin "1 2" \
        --padding "2 4" \
        '📦  BACKUP PACKAGES  📦' \
        '' \
        'Selecciona qué gestores quieres hacer backup'

    SELECTED=$(gum choose \
        --no-limit \
        --cursor.foreground="75" \
        --selected.foreground="75" \
        --header="Espacio para seleccionar, Enter para confirmar" \
        --header.foreground="245" \
        "📦 pacman" \
        "🔧 aur" \
        "📱 flatpak" \
        "🐍 uv" \
        "🍞 bun" \
        "📦 npm" \
        "🗃️  bin" \
        "🍺 brew")

    if [ -z "$SELECTED" ]; then
        gum style --foreground 196 "❌ No se seleccionó ninguna opción"
        exit 1
    fi

    echo ""
    echo "$SELECTED" | while IFS= read -r choice; do
        case "$choice" in
            *pacman*)  backup_pacman  ;;
            *aur*)     backup_aur     ;;
            *flatpak*) backup_flatpak ;;
            *uv*)      backup_uv      ;;
            *bun*)     backup_bun     ;;
            *npm*)     backup_npm     ;;
            *bin*)     backup_bin     ;;
            *brew*)    backup_brew    ;;
        esac
    done

    gum style \
        --foreground 46 \
        --border-foreground 46 \
        --border double \
        --align center \
        --width 60 \
        "✅ ¡Backup completado!"
fi
