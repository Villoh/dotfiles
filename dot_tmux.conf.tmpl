# =============================================================================
# tmux / psmux - cross-platform configuration
# =============================================================================
# Path: ~/.tmux.conf
# Windows uses psmux. Linux uses tmux.
#
# Goal: keep the zellij muscle memory that pays off most, but move session- and
# window-management actions back toward the natural tmux model.
#
# This is intentionally hybrid: some Alt bindings stay for navigation/splits,
# while structural actions live behind Prefix (Ctrl+a).
# =============================================================================

# --- shell & behavior ---------------------------------------------------------
{{ if eq .chezmoi.os "windows" -}}
set -g default-shell "pwsh"
{{ end -}}
set -g mouse on
set -g mode-keys vi
set -g history-limit 10000
set -g base-index 1
set -g pane-base-index 1
set -g renumber-windows on
set -g automatic-rename off
set -g allow-rename off
set -g focus-events on
set -g status-position bottom
set -g repeat-time 750

{{ if ne .chezmoi.os "windows" -}}
# --- Linux tmux plugins -------------------------------------------------------
set -g @plugin 'tmux-plugins/tpm'
set -g @plugin 'tmux-plugins/tmux-sensible'
set -g @plugin 'tmux-plugins/tmux-yank'
set -g @plugin 'christoomey/vim-tmux-navigator'
set -g @plugin 'tmux-plugins/tmux-resurrect'
set -g @plugin 'alexwforsythe/tmux-which-key'
set -g @plugin 'Nybkox/tmux-kanagawa'

set -g @kanagawa-theme 'Kanagawa'
set -g @kanagawa-plugins "git cpu-usage ram-usage"
set -g @kanagawa-ignore-window-colors true

set -g default-terminal "tmux-256color"
set -ga terminal-overrides ",*:Tc"
set -s extended-keys off

if-shell 'command -v wl-copy >/dev/null 2>&1' \
  'bind-key -T copy-mode-vi y send-keys -X copy-pipe-and-cancel "wl-copy"' \
  'bind-key -T copy-mode-vi y send-keys -X copy-pipe-and-cancel "xclip -selection clipboard"'

# Floating scratch session, kept Linux-only because it shells out to tmux.
bind-key -n M-g if-shell -F '#{==:#{session_name},scratch}' {
  detach-client
} {
  display-popup -d "#{pane_current_path}" -E "tmux new-session -A -s scratch"
}

bind-key K confirm-before -p "Kill all other sessions? (y/n)" "kill-session -a"
{{ end -}}

# --- prefix -------------------------------------------------------------------
unbind-key C-b
set -g prefix C-a
bind-key C-a send-prefix

# --- keep tmux defaults, but make them path-aware where it matters -----------
unbind-key c
bind-key c new-window -c "#{pane_current_path}"

unbind-key '"'
bind-key '"' split-window -v -c "#{pane_current_path}"

unbind-key %
bind-key % split-window -h -c "#{pane_current_path}"

# --- no-prefix zellij muscle memory ------------------------------------------
# Host terminals may still intercept some Alt combinations. These bindings are
# kept only where the zellij muscle memory is worth the tradeoff.

## Focus panes
bind-key -n M-h     if-shell -F '#{pane_at_left}'  'previous-window' 'select-pane -L'
bind-key -n M-Left  if-shell -F '#{pane_at_left}'  'previous-window' 'select-pane -L'
bind-key -n M-j     select-pane -D
bind-key -n M-Down  select-pane -D
bind-key -n M-k     select-pane -U
bind-key -n M-Up    select-pane -U
bind-key -n M-l     if-shell -F '#{pane_at_right}' 'next-window'     'select-pane -R'
bind-key -n M-Right if-shell -F '#{pane_at_right}' 'next-window'     'select-pane -R'

## Pane management
bind-key -n M-n if-shell -F '#{>=:#{pane_width},#{pane_height}}' 'split-window -h -c "#{pane_current_path}"' 'split-window -v -c "#{pane_current_path}"'
bind-key -n M-d split-window -v -c "#{pane_current_path}"
bind-key -n M-e split-window -h -c "#{pane_current_path}"
bind-key -n M-x kill-pane
bind-key -n M-z resize-pane -Z
bind-key -n M-f display-popup -d "#{pane_current_path}" -E "#{default-shell}"

## Resize
## psmux currently folds Alt+Shift+letter onto Alt+letter here, so keep
## directional resize behind Prefix instead of global Alt bindings.

## Window switching
bind-key -n 'M-,' previous-window
bind-key -n 'M-.' next-window
bind-key -n M-1 select-window -t 1
bind-key -n M-2 select-window -t 2
bind-key -n M-3 select-window -t 3
bind-key -n M-4 select-window -t 4
bind-key -n M-5 select-window -t 5
bind-key -n M-6 select-window -t 6
bind-key -n M-7 select-window -t 7
bind-key -n M-8 select-window -t 8
bind-key -n M-9 select-window -t 9
# Secondary global fallback for hosts that intercept Alt+1..9 (WezTerm/WT).
bind-key -n M-F1 select-window -t 1
bind-key -n M-F2 select-window -t 2
bind-key -n M-F3 select-window -t 3
bind-key -n M-F4 select-window -t 4
bind-key -n M-F5 select-window -t 5
bind-key -n M-F6 select-window -t 6
bind-key -n M-F7 select-window -t 7
bind-key -n M-F8 select-window -t 8
bind-key -n M-F9 select-window -t 9


## Layouts / modes / help
bind-key -n 'M-[' previous-layout
bind-key -n 'M-]' next-layout
bind-key -n M-s copy-mode
bind-key -n M-w choose-tree
{{ if eq .chezmoi.os "windows" -}}
bind-key -n M-y display-popup -E "pwsh -NoLogo -NoProfile -Command \"less -N -- (Join-Path $env:USERPROFILE '.tmux-keys')\""
{{ else -}}
bind-key -n M-y display-popup -E "less -N -- ~/.tmux-keys"
{{ end -}}

# --- prefix aliases for zellij habits that do not map cleanly as globals -----
# Pane focus aliases
bind-key -r h select-pane -L
bind-key -r j select-pane -D
bind-key -r k select-pane -U
bind-key -r l select-pane -R

# Directional resize aliases
bind-key -r H resize-pane -L 5
bind-key -r J resize-pane -D 5
bind-key -r K resize-pane -U 5
bind-key -r L resize-pane -R 5
bind-key -r S-Left resize-pane -L 5
bind-key -r S-Down resize-pane -D 5
bind-key -r S-Up resize-pane -U 5
bind-key -r S-Right resize-pane -R 5

# Window creation / close / rename / reorder
bind-key t new-window -c "#{pane_current_path}"
bind-key r rename-window
bind-key i swap-window -t -1
bind-key o swap-window -t +1

# Popup / chooser / quit
bind-key f display-popup -d "#{pane_current_path}" -E "#{default-shell}"
bind-key g choose-tree
bind-key C-q confirm-before -p "Kill current tmux/psmux session? (y/n)" "kill-session"
{{ if eq .chezmoi.os "windows" -}}
bind-key y display-popup -E "pwsh -NoLogo -NoProfile -Command \"less -N -- (Join-Path $env:USERPROFILE '.tmux-keys')\""
{{ else -}}
bind-key y display-popup -E "less -N -- ~/.tmux-keys"
{{ end -}}
bind-key Y list-keys

# There is no faithful zellij move mode in tmux. Keep a discoverable hint.
bind-key m display-message "Pane move: Prefix+{ / Prefix+} | Window move: Prefix+i / Prefix+o"

# --- zellij-to-tmux cheat sheet ----------------------------------------------
# Ctrl-g         -> no lock mode in tmux/psmux
# Alt-s          -> kept as no-prefix copy-mode
# Alt-m          -> Prefix+m shows move help
# Alt-h/j/k/l    -> kept no-prefix; also Prefix+h/j/k/l
# Alt-n/d/e      -> kept no-prefix; Prefix+\" and Prefix+% remain canonical tmux
# Alt-x / Alt-z  -> kept no-prefix; Prefix+x / Prefix+z also exist
# Alt-f          -> kept no-prefix; Prefix+f alias too
# Alt-Shift-h/j/k/l -> use Prefix+H/J/K/L (psmux folds shifted letters here)
# Shift+arrows      -> use Prefix+Shift+Left/Down/Up/Right
# Prefix+Alt+arrows -> inherited tmux resize bindings still work too
# Alt-t          -> Prefix+t (or canonical Prefix+c)
# Alt-, / Alt-.  -> kept no-prefix; Prefix+p / Prefix+n also exist
# Alt-1..9       -> kept no-prefix when the host terminal passes them; otherwise use Alt+F1..F9 or Prefix+1..9
# Alt-Shift-t    -> canonical Prefix+&
# Alt-r          -> Prefix+r (or canonical Prefix+,)
# Alt-i / Alt-o  -> Prefix+i / Prefix+o
# Alt-[ / Alt-]  -> kept no-prefix; canonical tmux layout cycle is Prefix+Space
# Alt-w          -> kept no-prefix; Prefix+g chooser alias too
# Alt-Shift-d    -> canonical Prefix+d
# Ctrl-q         -> Prefix+Ctrl+q
# Alt-y          -> opens the friendly cheatsheet; Prefix+y does the same; Prefix+Y / Prefix+? show the raw tmux key table
# Alt-+/-        -> no faithful tmux equivalent; use directional resize instead

{{ if ne .chezmoi.os "windows" -}}
# --- TPM init -----------------------------------------------------------------
run '~/.tmux/plugins/tpm/tpm'
{{ end -}}
