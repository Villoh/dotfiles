{{- $isWindows := eq .chezmoi.os "windows" -}}
encryption = "gpg"
mode = "symlink"

[gpg]
    recipient = "2E5BD225E500AB50"
    {{ if $isWindows -}}
    command = "C:/Program Files/GnuPG/bin/gpg.exe"
    {{- end }}

[git]
    autoCommit = false
    autoPush = false

[data]
    isWindows = {{ $isWindows }}

    # ── Owner-only — do NOT enable unless you are Villoh ─────────────────────
    enable_secrets = {{ promptBool "Enable personal secrets (owner only — requires Bitwarden)" false }}

    # ── Cross-platform modules ─────────────────────────────────────────────
    enable_zed        = true
    enable_yazi       = true
    enable_btop       = true
    enable_fastfetch  = true
    enable_cava       = true
    enable_gh_dash    = true
    enable_micro      = true
    enable_opencode   = true
    enable_starship   = true
    enable_ohmyposh   = true
    enable_bun        = true
    enable_git        = true
    enable_uv         = true
    enable_zellij     = true
    enable_ytm_player = true
    enable_scoop      = true

    # ── Linux-only modules ─────────────────────────────────────────────────
    {{ if not $isWindows -}}
    enable_zsh        = true
    enable_bash       = true
    enable_hyprland   = true
    enable_waybar     = true
    enable_swaync     = true
    enable_swayosd    = true
    enable_kitty      = true
    enable_ghostty    = true
    enable_tmux       = true
    enable_aerc       = true
    enable_nchat      = true
    enable_freetube   = true
    enable_cliphist   = true
    enable_vesktop    = true
    enable_systemd    = true
    {{- else }}
    enable_zsh        = false
    enable_bash       = false
    enable_hyprland   = false
    enable_waybar     = false
    enable_swaync     = false
    enable_swayosd    = false
    enable_kitty      = false
    enable_ghostty    = false
    enable_tmux       = false
    enable_aerc       = false
    enable_nchat      = false
    enable_freetube   = false
    enable_cliphist   = false
    enable_vesktop    = false
    enable_systemd    = false
    {{- end }}

    # ── Windows-only modules ───────────────────────────────────────────────
    {{ if $isWindows -}}
    enable_glazewm          = true
    enable_yasb             = true
    enable_wezterm          = true
    enable_alacritty        = true
    enable_flow_launcher    = true
    enable_ditto            = true
    enable_nilesoft         = true
    enable_autohotkey       = true
    enable_rainmeter        = true
    enable_warp             = true
    enable_windhawk         = true
    enable_windows_terminal = true
    enable_mica             = true
    enable_junctions        = true
    enable_startup          = true
    enable_cursors          = true
    cursor_scheme           = "Catppuccin-Mocha-Mauve-Cursors"
    {{- else }}
    enable_glazewm          = false
    enable_yasb             = false
    enable_wezterm          = false
    enable_alacritty        = false
    enable_flow_launcher    = false
    enable_ditto            = false
    enable_nilesoft         = false
    enable_autohotkey       = false
    enable_rainmeter        = false
    enable_warp             = false
    enable_windhawk         = false
    enable_windows_terminal = false
    enable_mica             = false
    enable_junctions        = false
    enable_startup          = false
    enable_cursors          = false
    {{- end }}
