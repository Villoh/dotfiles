{{- $isWindows := eq .chezmoi.os "windows" -}}
{{- $all := promptBool "Enable all modules" true -}}
encryption = "gpg"
mode = "symlink"

[gpg]
    recipient = "2E5BD225E500AB50"
    {{ if $isWindows -}}
    command = "C:/Program Files/GnuPG/bin/gpg.exe"
    {{- end }}

[git]
    autoCommit = true
    autoPush = true

[data]
    isWindows = {{ $isWindows }}

    # ── Cross-platform modules ─────────────────────────────────────────────
    enable_zed        = {{ or $all (promptBool "Enable Zed editor" true) }}
    enable_yazi       = {{ or $all (promptBool "Enable Yazi file manager" true) }}
    enable_btop       = {{ or $all (promptBool "Enable btop" true) }}
    enable_fastfetch  = {{ or $all (promptBool "Enable Fastfetch" true) }}
    enable_cava       = {{ or $all (promptBool "Enable Cava audio visualizer" true) }}
    enable_gh_dash    = {{ or $all (promptBool "Enable gh-dash" true) }}
    enable_micro      = {{ or $all (promptBool "Enable Micro editor" true) }}
    enable_opencode   = {{ or $all (promptBool "Enable OpenCode" true) }}
    enable_starship   = {{ or $all (promptBool "Enable Starship prompt" true) }}
    enable_ohmyposh   = {{ or $all (promptBool "Enable Oh My Posh" true) }}
    enable_bun        = {{ or $all (promptBool "Enable Bun config" true) }}

    # ── Linux-only modules ─────────────────────────────────────────────────
    {{ if not $isWindows -}}
    enable_zsh        = {{ or $all (promptBool "Enable Zsh config" true) }}
    enable_bash       = {{ or $all (promptBool "Enable Bash config" true) }}
    enable_hyprland   = {{ or $all (promptBool "Enable Hyprland" true) }}
    enable_waybar     = {{ or $all (promptBool "Enable Waybar" true) }}
    enable_swaync     = {{ or $all (promptBool "Enable SwayNC" true) }}
    enable_swayosd    = {{ or $all (promptBool "Enable SwayOSD" true) }}
    enable_kitty      = {{ or $all (promptBool "Enable Kitty terminal" true) }}
    enable_ghostty    = {{ or $all (promptBool "Enable Ghostty terminal" true) }}
    enable_tmux       = {{ or $all (promptBool "Enable tmux" true) }}
    enable_aerc       = {{ or $all (promptBool "Enable aerc email client" true) }}
    enable_nchat      = {{ or $all (promptBool "Enable nchat" true) }}
    enable_freetube   = {{ or $all (promptBool "Enable FreeTube" true) }}
    enable_cliphist   = {{ or $all (promptBool "Enable cliphist" true) }}
    enable_vesktop    = {{ or $all (promptBool "Enable Vesktop/Vencord" true) }}
    enable_systemd    = {{ or $all (promptBool "Enable systemd user services" true) }}
    {{- else }}
    enable_zsh        = false
    enable_bash       = false
    enable_hyprland   = false
    enable_waybar     = false
    enable_swaync     = false
    enable_swayosd    = false
    enable_kitty      = false
    enable_ghostty    = false
    enable_tmux       = false
    enable_aerc       = false
    enable_nchat      = false
    enable_freetube   = false
    enable_cliphist   = false
    enable_vesktop    = false
    enable_systemd    = false
    {{- end }}

    # ── Windows-only modules ───────────────────────────────────────────────
    {{ if $isWindows -}}
    enable_glazewm          = {{ or $all (promptBool "Enable GlazeWM" true) }}
    enable_yasb             = {{ or $all (promptBool "Enable YASB status bar" true) }}
    enable_wezterm          = {{ or $all (promptBool "Enable WezTerm" true) }}
    enable_alacritty        = {{ or $all (promptBool "Enable Alacritty" true) }}
    enable_flow_launcher    = {{ or $all (promptBool "Enable Flow Launcher" true) }}
    enable_ditto            = {{ or $all (promptBool "Enable Ditto clipboard" true) }}
    enable_nilesoft         = {{ or $all (promptBool "Enable Nilesoft Shell" true) }}
    enable_autohotkey       = {{ or $all (promptBool "Enable AutoHotkey" true) }}
    enable_rainmeter        = {{ or $all (promptBool "Enable Rainmeter" true) }}
    enable_warp             = {{ or $all (promptBool "Enable Warp terminal" true) }}
    enable_windhawk         = {{ or $all (promptBool "Enable Windhawk" true) }}
    enable_windows_terminal = {{ or $all (promptBool "Enable Windows Terminal" true) }}
    enable_mica             = {{ or $all (promptBool "Enable MicaForEveryone" true) }}
    {{- else }}
    enable_glazewm          = false
    enable_yasb             = false
    enable_wezterm          = false
    enable_alacritty        = false
    enable_flow_launcher    = false
    enable_ditto            = false
    enable_nilesoft         = false
    enable_autohotkey       = false
    enable_rainmeter        = false
    enable_warp             = false
    enable_windhawk         = false
    enable_windows_terminal = false
    enable_mica             = false
    {{- end }}
