{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    [
      "superpowers@git+https://github.com/obra/superpowers.git",
      {
        "enabled": true
      }
    ],
    [ "@dietrichgebert/ponytail",
      {
        "enabled": true
      }
    ],
    [
      "oc-plugin-vault-tec",
      {
        "enabled": false,
        "mode": "append"
      }
    ],
    [
      "@plannotator/opencode@latest",
      {
        "enabled": true,
        "mode": "append"
      }
    ],
    "./plugins/caveman/plugin.js"
  ],
  "provider": {
    "tunnel-agent-cliproxy": {
      "name": "Tunnel Agent",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:8317/v1",
        "litellmProxy": true,
        "apiKey": "{env:TUNNEL_AGENT_CLIPROXY_API_KEY}"
      },
      "models": {
        "claude-3-5-haiku-20241022": {
          "name": "Claude 3.5 Haiku (Tunnel Agent)"
        },
        "claude-3-7-sonnet-20250219": {
          "name": "Claude 3 7 Sonnet (Tunnel Agent)"
        },
        "claude-fable-5": {
          "name": "Claude Fable 5 (Tunnel Agent)"
        },
        "claude-haiku-4-5-20251001": {
          "name": "Claude Haiku 4.5 (Tunnel Agent)"
        },
        "claude-opus-4-1-20250805": {
          "name": "Claude Opus 4.1 (Tunnel Agent)"
        },
        "claude-opus-4-20250514": {
          "name": "Claude Opus 4 (Tunnel Agent)"
        },
        "claude-opus-4-5-20251101": {
          "name": "Claude Opus 4.5 (Tunnel Agent)"
        },
        "claude-opus-4-6": {
          "name": "Claude Opus 4.6 (Tunnel Agent)"
        },
        "claude-opus-4-7": {
          "name": "Claude Opus 4.7 (Tunnel Agent)"
        },
        "claude-opus-4-8": {
          "name": "Claude Opus 4.8 (Tunnel Agent)"
        },
        "claude-sonnet-4-20250514": {
          "name": "Claude Sonnet 4 (Tunnel Agent)"
        },
        "claude-sonnet-4-5-20250929": {
          "name": "Claude Sonnet 4.5 (Tunnel Agent)"
        },
        "claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6 (Tunnel Agent)"
        },
        "codex-auto-review": {
          "name": "Codex Auto Review (Tunnel Agent)"
        },
        "gpt-5.3-codex-spark": {
          "name": "GPT 5.3 Codex Spark (Tunnel Agent)"
        },
        "gpt-5.4": {
          "name": "GPT-5.4 (Tunnel Agent)"
        },
        "gpt-5.4-mini": {
          "name": "GPT-5.4 Mini (Tunnel Agent)"
        },
        "gpt-5.5": {
          "name": "GPT-5.5 (Tunnel Agent)"
        },
        "gpt-image-1.5": {
          "name": "GPT Image 1.5 (Tunnel Agent)"
        },
        "gpt-image-2": {
          "name": "GPT Image 2 (Tunnel Agent)"
        }
      }
    },
    "tunnel-agent-perplexity": {
      "name": "Tunnel Agent",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:8327/v1",
        "litellmProxy": true,
        "apiKey": "{env:TUNNEL_AGENT_PERPLEXITY_TOKEN}"
      },
      "models": {
        "anthropic/claude-opus-4.7": {
          "name": "Claude Opus 4.7 (Tunnel Agent - Perplexity)"
        },
        "anthropic/claude-opus-4.7-thinking": {
          "name": "Claude Opus 4.7 Thinking (Tunnel Agent - Perplexity)"
