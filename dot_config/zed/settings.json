{
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "agent_servers": {
    "claude": {
      "favorite_config_option_values": {
        "model": [
          "default"
        ]
      }
    }
  },
  "git_panel": {
    "tree_view": true
  },
  "icon_theme": "Catppuccin Mocha",
  "theme": "Catppuccin Mocha (Blur)",
  "theme_overrides": {
    "Aura Dark": {
      "editor.document_highlight.read_background": "#00000000",
      "editor.document_highlight.write_background": "#00000000",
      "border.variant": "#15141C",
      "border": "#15141C",
      "title_bar.background": "#15141C",
      "panel.background": "#15141C",
      "panel.focused_border": "#4E466E",
      "players": [
        {
          "cursor": "#BD9DFF"
        }
      ],
      "syntax": {
        "comment": {
          "font_style": "italic"
        },
        "comment.doc": {
          "font_style": "italic"
        }
      }
    }
  },

  // ============================================================
  // CHROME DEL EDITOR
  // ============================================================

  "title_bar": {
    "show_onboarding_banner": false,
    "show_project_items": false,
    "show_branch_name": true,
    "show_user_menu": false
  },
  "tab_bar": {
    "show": true
  },
  "toolbar": {
    "quick_actions": false
  },
  "status_bar": {
    "experimental.show": true
  },

  // ============================================================
  // PANELES
  // ============================================================

  "project_panel": {
    "dock": "right",
    "default_width": 400,
    "hide_root": true,
    "auto_fold_dirs": false,
    "starts_open": false,
    "git_status": true,
    "sticky_scroll": false,
    "scrollbar": {
      "show": "never"
    },
    "indent_guides": {
      "show": "never"
    }
  },
  "outline_panel": {
    "default_width": 300,
    "indent_guides": {
      "show": "never"
    }
  },
  "file_finder": {
    "modal_max_width": "large"
  },
  "centered_layout": {
    "right_padding": 0.15,
    "left_padding": 0.15
  },

  // ============================================================
  // FUENTES
  // ============================================================

  "ui_font_family": "Lilex",
  "ui_font_size": 18,
  "buffer_font_family": "Lilex",
  "buffer_font_size": 18,
  "buffer_line_height": {
    "custom": 2
  },
  "agent_buffer_font_size": 20,

  // ============================================================
  // EDITOR
  // ============================================================

  "scrollbar": {
    "show": "auto"
  },
  "gutter": {
    "min_line_number_digits": 0,
    "folds": true,
    "runnables": false
  },
  "indent_guides": {
    "enabled": false
  },
  "multi_cursor_modifier": "cmd_or_ctrl",
  "cursor_shape": "bar",
  "cursor_blink": true,
  "selection_highlight": true,
  "drag_and_drop_selection": {
    "enabled": false
  },
  "seed_search_query_from_cursor": "never",
  "current_line_highlight": "none",
  "show_whitespaces": "none",
  "tab_size": 2,
  "auto_indent": false,
  "auto_indent_on_paste": false,
  "horizontal_scroll_margin": 1,
  "vertical_scroll_margin": 1,

  // ============================================================
  // LSP — desactivado intencionalmente (filosofía Vim)
  // ============================================================

  "show_completions_on_input": false,
  "show_completion_documentation": false,
  "inline_code_actions": false,
  "lsp_document_colors": "none",
  "hover_popover_enabled": true,

  // ============================================================
  // GUARDADO
  // ============================================================

  "format_on_save": "off",
  "autosave": {
    "after_delay": {
      "milliseconds": 1000
    }
  },
  "extend_comment_on_newline": false,

  // ============================================================
  // GIT — desactivado, filosofía minimalista
  // ============================================================

  "git": {
    "git_gutter": "tracked_files",
    "inline_blame": {
      "enabled": true
    }
  },

  // ============================================================
  // SESIÓN Y COMPORTAMIENTO
  // ============================================================

  "auto_update": false,
  "when_closing_with_no_tabs": "keep_window_open",
  "close_on_file_delete": true,
  "restore_on_file_reopen": false,
  "restore_on_startup": "empty_tab",
  "session": {
    "restore_unsaved_buffers": false
  },

  // ============================================================
  // TERMINAL
  // ============================================================
  "terminal": {
    "font_family": "CaskaydiaCove Nerd Font",
    "font_size": 14,
    "font_weight": 400,
    "line_height": "standard",
    "font_features": {
      "calt": false
    }
  }
}
