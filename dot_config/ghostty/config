# Config syntax crash course
# ==========================
# # The config file consists of simple key-value pairs,
# # separated by equals signs.
# font-family = Iosevka
# window-padding-x = 2
#
# # Spacing around the equals sign does not matter.
# # All of these are identical:
# key=value
# key= value
# key =value
# key = value
#
# # Any line beginning with a # is a comment. It's not possible to put
# # a comment after a config option, since it would be interpreted as a
# # part of the value. For example, this will have a value of "#123abc":
# background = #123abc
#
# # Empty values are used to reset config keys to default.
# key =
#
# # Some config options have unique syntaxes for their value,
# # which is explained in the docs for that config option.
# # Just for example:
# resize-overlay-duration = 4s 200ms
# === TEMA Y APARIENCIA ===
theme = catppuccin-mocha
# Para listar todos los temas disponibles: ghostty +list-themes

# O puedes usar uno de estos que vienen con Ghostty:
# theme = dracula
# theme = nord
# theme = gruvbox-dark
# theme = tokyo-night

# === FUENTE ===
font-family = JetBrains Mono
font-size = 13

# === APARIENCIA ===
background-opacity = 0.85
window-padding-x = 4
window-padding-y = 4

# === COMPORTAMIENTO ===
mouse-hide-while-typing = true
copy-on-select = true

# === KEYBINDINGS ===
# Reload config
keybind = ctrl+shift+comma=reload_config

# Abrir config en editor
keybind = ctrl+comma=open_config

# Gestión de ventanas y tabs
keybind = ctrl+shift+n=new_window
keybind = ctrl+shift+t=new_tab
keybind = ctrl+shift+w=close_tab:this
keybind = ctrl+tab=next_tab
keybind = ctrl+shift+tab=previous_tab

# Ir a tab específico (Alt+número)
keybind = alt+digit_1=goto_tab:1
keybind = alt+digit_2=goto_tab:2
keybind = alt+digit_3=goto_tab:3
keybind = alt+digit_4=goto_tab:4
keybind = alt+digit_5=goto_tab:5
keybind = alt+digit_6=goto_tab:6
keybind = alt+digit_7=goto_tab:7
keybind = alt+digit_8=goto_tab:8
keybind = alt+digit_9=last_tab

# Splits (¡Ghostty los tiene nativos!)
keybind = ctrl+shift+e=new_split:right
keybind = ctrl+shift+d=new_split:down
keybind = ctrl+shift+z=toggle_split_zoom

# Navegar entre splits
keybind = ctrl+alt+arrow_left=goto_split:left
keybind = ctrl+alt+arrow_right=goto_split:right
keybind = ctrl+alt+arrow_up=goto_split:up
keybind = ctrl+alt+arrow_down=goto_split:down

# Redimensionar splits
keybind = ctrl+alt+shift+arrow_left=resize_split:left,10
keybind = ctrl+alt+shift+arrow_right=resize_split:right,10
keybind = ctrl+alt+shift+arrow_up=resize_split:up,10
keybind = ctrl+alt+shift+arrow_down=resize_split:down,10

# Copiar/Pegar
keybind = ctrl+shift+c=copy_to_clipboard
keybind = ctrl+shift+v=paste_from_clipboard
keybind = ctrl+shift+a=select_all

# Font size
keybind = ctrl+equal=increase_font_size:1
keybind = ctrl+minus=decrease_font_size:1
keybind = ctrl+0=reset_font_size

# Scrollback
keybind = shift+page_up=scroll_page_up
keybind = shift+page_down=scroll_page_down
keybind = shift+home=scroll_to_top
keybind = shift+end=scroll_to_bottom

# Saltar entre prompts (útil!)
keybind = ctrl+shift+page_up=jump_to_prompt:-1
keybind = ctrl+shift+page_down=jump_to_prompt:1

# Command palette
keybind = ctrl+shift+p=toggle_command_palette

# Fullscreen
keybind = ctrl+enter=toggle_fullscreen

# Inspector (debug)
keybind = ctrl+shift+i=inspector:toggle

# Quit
keybind = ctrl+shift+q=quit
