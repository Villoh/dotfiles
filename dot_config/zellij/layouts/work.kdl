// =============================================================================
// Zellij - Work Layout
// =============================================================================

layout {
    default_tab_template {
        children
        pane size=1 borderless=true {
            plugin location="zjstatus"
        }
    }

    // -------------------------------------------------------------------------
    // Tab 1 — Dev
    // ┌──────────────────────┬──────────┐
    // │                      │          │
    // │   shell (agent here) │ lazygit  │
    // │        (75%)         │  (25%)   │
    // └──────────────────────┴──────────┘
    // Alt+t → new tab → run: claude / opencode / pi
    // -------------------------------------------------------------------------
    tab name="dev" focus=true {
        pane split_direction="vertical" {
            pane size="75%"
            pane command="lazygit" size="25%"
        }
    }

    // -------------------------------------------------------------------------
    // Tab 2 — YouTube Music
    // -------------------------------------------------------------------------
    tab name="ytm" {
        pane command="ytm"
    }
}
