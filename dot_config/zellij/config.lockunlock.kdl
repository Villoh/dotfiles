// =============================================================================
// Zellij - OPTION A: tmux-style prefix (lock/unlock), nvim-safe
// =============================================================================
// Philosophy: default_mode is "locked" (100% passthrough to the app/shell).
// "Ctrl g" acts as the tmux-style prefix: it unlocks for exactly ONE action,
// then auto-relocks. No Alt modifier needed anymore ŌĆö since every action
// requires the explicit unlock gesture first, plain letters are already safe
// (they never reach Zellij unless you just pressed Ctrl g).
//
// Flow example: Ctrl g -> h   (moves focus left, then auto re-locks)
//               Ctrl g -> t   (new tab, then auto re-locks)
// This mirrors tmux: prefix + key, single-shot, back to normal typing.
//
// Trade-off vs the Alt version: repeated actions (e.g. moving focus 3 times)
// need Ctrl g each time. Frequent navigation is less fluid than Alt+hjkl,
// but there is ZERO collision surface with Neovim/shell bindings.
// =============================================================================
// Path: %USERPROFILE%/.config\zellij\config.kdl
// Docs: https://zellij.dev/documentation/
// =============================================================================

default_shell "pwsh"
default_mode "locked"
default_layout "work"
pane_frames false
scroll_buffer_size 10000
copy_on_select false
mouse_mode true
mirror_session false
show_startup_tips false
on_force_close "detach"

theme "catppuccin-mocha"

keybinds {

    // -------------------------------------------------------------------------
    // Locked ŌĆö passthrough to the app/shell. Ctrl g is the ONLY captured key.
    // -------------------------------------------------------------------------
    locked {
        bind "Ctrl g" { SwitchToMode "Normal"; }
    }

    // -------------------------------------------------------------------------
    // Alt+hjkl ŌĆö the ONE deliberate exception to "no Alt". Always active in
    // both Locked and Normal (no Ctrl g needed), for fast repeated pane focus
    // navigation. Low collision risk with shell/nvim (unlike the old full Alt
    // scheme). NewPane/etc. stay Ctrl-g gated only ŌĆö not added here.
    // -------------------------------------------------------------------------
    shared_among "normal" "locked" {
        bind "Alt h" "Alt Left"  { MoveFocusOrTab "Left"; }
        bind "Alt j" "Alt Down"  { MoveFocus "Down"; }
        bind "Alt k" "Alt Up"    { MoveFocus "Up"; }
        bind "Alt l" "Alt Right" { MoveFocusOrTab "Right"; }
    }

    // -------------------------------------------------------------------------
    // Normal ŌĆö reached only via Ctrl g. Every one-shot action re-locks itself
    // immediately after running, so you never "stay" in Normal typing text.
    // Entries into a sticky sub-mode (Scroll/Move/Rename) do NOT re-lock here,
    // because those modes have their own explicit exit key (which re-locks).
    // -------------------------------------------------------------------------
    normal {
        bind "Ctrl g" { SwitchToMode "Locked"; }

        // Pane focus
        bind "h" "Left"  { MoveFocusOrTab "Left";  SwitchToMode "Locked"; }
        bind "j" "Down"  { MoveFocus "Down";       SwitchToMode "Locked"; }
        bind "k" "Up"    { MoveFocus "Up";         SwitchToMode "Locked"; }
        bind "l" "Right" { MoveFocusOrTab "Right"; SwitchToMode "Locked"; }

        // Pane management
        bind "n" { NewPane;               SwitchToMode "Locked"; }
        bind "d" { NewPane "Down";        SwitchToMode "Locked"; }
        bind "r" { NewPane "Right";       SwitchToMode "Locked"; }
        bind "s" { NewPane "stacked";     SwitchToMode "Locked"; }
        bind "x" { CloseFocus;            SwitchToMode "Locked"; }
        bind "z" { ToggleFocusFullscreen; SwitchToMode "Locked"; }
        bind "f" { ToggleFloatingPanes;   SwitchToMode "Locked"; }

        // Resize ŌĆö enters sticky Resize mode (tmux repeat-time equivalent,
        // but without a timeout: stay until you explicitly exit).
        bind "+" "=" "-" { SwitchToMode "Resize"; }

        // Tabs
        bind "t"       { NewTab;             SwitchToMode "Locked"; }
        bind ","       { GoToPreviousTab;    SwitchToMode "Locked"; }
        bind "."       { GoToNextTab;        SwitchToMode "Locked"; }
        bind "1"       { GoToTab 1;          SwitchToMode "Locked"; }
        bind "2"       { GoToTab 2;          SwitchToMode "Locked"; }
        bind "3"       { GoToTab 3;          SwitchToMode "Locked"; }
        bind "4"       { GoToTab 4;          SwitchToMode "Locked"; }
        bind "5"       { GoToTab 5;          SwitchToMode "Locked"; }
        bind "6"       { GoToTab 6;          SwitchToMode "Locked"; }
        bind "7"       { GoToTab 7;          SwitchToMode "Locked"; }
        bind "8"       { GoToTab 8;          SwitchToMode "Locked"; }
        bind "9"       { GoToTab 9;          SwitchToMode "Locked"; }
        bind "Shift t" { CloseTab;           SwitchToMode "Locked"; }
        bind "Shift r" { SwitchToMode "RenameTab"; TabNameInput 0; }
        bind "c"       { SwitchToMode "RenamePane"; PaneNameInput 0; }
        bind "i"       { MoveTab "Left";  SwitchToMode "Locked"; }
        bind "o"       { MoveTab "Right"; SwitchToMode "Locked"; }

        // Layouts
        bind "["  { PreviousSwapLayout; SwitchToMode "Locked"; }
        bind "]"  { NextSwapLayout;     SwitchToMode "Locked"; }

        // Session
        bind "w" {
            LaunchOrFocusPlugin "zellij:session-manager" {
                floating true
                move_to_focused_tab true
            }
            SwitchToMode "Locked";
        }
        bind "Shift d" { Detach; SwitchToMode "Locked"; }
        bind "Ctrl q"  { Quit; }

        // Sub-modes (sticky ŌĆö their own exit key handles re-locking)
        bind "Ctrl s" { SwitchToMode "Scroll"; }
        bind "m"      { SwitchToMode "Move"; }

        // Help
        bind "y" {
            LaunchOrFocusPlugin "file:~/.config/zellij/plugins/zellij_forgot.wasm" {
                floating true
                move_to_focused_tab true
                LOAD_ZELLIJ_BINDINGS "true"
                "prefix"                "Ctrl g (single-shot, auto re-locks)"
                "focus left/down/up/right" "Ctrl g+h/j/k/l  OR  Alt+h/j/k/l (no prefix)"
                "new pane (default dir)" "n"
                "split down"            "d"
                "split right"           "r"
                "new pane (stacked)"    "s"
                "close pane"            "x"
                "toggle fullscreen"     "z"
                "toggle floating"       "f"
                "resize +/-"            "+ / -"
                "resize dir"            "Shift h/j/k/l"
                "new tab"               "t"
                "prev/next tab"         ", / ."
                "go to tab 1-9"         "1-9"
                "close tab"             "Shift t"
                "rename tab"            "Shift r"
                "rename pane"           "c"
                "move tab left/right"   "i / o"
                "prev/next layout"      "[ / ]"
                "session manager"       "w"
                "detach"                "Shift d"
                "quit"                  "Ctrl q"
                "scroll mode"           "Ctrl s  (f=search, e=editscrollback)"
                "move mode"             "m  (n/Tab=move, p=backwards)"
            }
            SwitchToMode "Locked";
        }
    }

    // -------------------------------------------------------------------------
    // Resize mode ŌĆö sticky sub-mode, equivalent to tmux's `-r` repeatable
    // resize + repeat-time, but timeout-free: repeat hjkl/+/- freely, exit
    // explicitly with Esc/Enter/q (re-locks automatically).
    // -------------------------------------------------------------------------
    resize {
        bind "Esc" "Enter" "q" { SwitchToMode "Locked"; }
        bind "h" "Left"  { Resize "Increase Left"; }
        bind "j" "Down"  { Resize "Increase Down"; }
        bind "k" "Up"    { Resize "Increase Up"; }
        bind "l" "Right" { Resize "Increase Right"; }
        bind "Shift h"   { Resize "Decrease Left"; }
        bind "Shift j"   { Resize "Decrease Down"; }
        bind "Shift k"   { Resize "Decrease Up"; }
        bind "Shift l"   { Resize "Decrease Right"; }
        bind "+" "="     { Resize "Increase"; }
        bind "-"         { Resize "Decrease"; }
    }

    // -------------------------------------------------------------------------
    // Scroll mode ŌĆö sticky sub-mode. Exit re-locks (not back to Normal).
    // -------------------------------------------------------------------------
    scroll {
        bind "Esc" "q" "s"           { SwitchToMode "Locked"; }
        bind "j" "Down"              { ScrollDown; }
        bind "k" "Up"                { ScrollUp; }
        bind "d"                     { HalfPageScrollDown; }
        bind "u"                     { HalfPageScrollUp; }
        bind "l" "PageDown" "Ctrl f" { PageScrollDown; }
        bind "h" "PageUp"   "Ctrl b" { PageScrollUp; }
        bind "g"                     { ScrollToTop; }
        bind "G"                     { ScrollToBottom; }
        bind "Ctrl c"                { ScrollToBottom; SwitchToMode "Locked"; }
        bind "f"                     { SwitchToMode "EnterSearch"; SearchInput 0; }
        bind "e"                     { EditScrollback; SwitchToMode "Locked"; }
    }

    entersearch {
        bind "Enter"        { SwitchToMode "Search"; }
        bind "Esc" "Ctrl c" { SwitchToMode "Scroll"; }
    }

    search {
        bind "Esc" "q" { SwitchToMode "Locked"; }
        bind "n"       { Search "down"; }
        bind "p"       { Search "up"; }
        bind "c"       { SearchToggleOption "CaseSensitivity"; }
        bind "o"       { SearchToggleOption "WholeWord"; }
        bind "w"       { SearchToggleOption "Wrap"; }
    }

    // -------------------------------------------------------------------------
    // Move mode ŌĆö sticky sub-mode. Exit re-locks (not back to Normal).
    // -------------------------------------------------------------------------
    move {
        bind "Esc" "Enter" "m" { SwitchToMode "Locked"; }
        bind "h" "Left"        { MovePane "Left"; }
        bind "j" "Down"        { MovePane "Down"; }
        bind "k" "Up"          { MovePane "Up"; }
        bind "l" "Right"       { MovePane "Right"; }
        bind "n" "Tab"         { MovePane; }
        bind "p"               { MovePaneBackwards; }
        bind ","               { MoveTab "Left"; }
        bind "."               { MoveTab "Right"; }
    }

    // -------------------------------------------------------------------------
    // Rename modes ŌĆö exit re-locks (not back to Normal).
    // -------------------------------------------------------------------------
    renametab {
        bind "Enter"  { SwitchToMode "Locked"; }
        bind "Esc"    { UndoRenameTab; SwitchToMode "Locked"; }
        bind "Ctrl c" { SwitchToMode "Locked"; }
    }

    renamepane {
        bind "Enter"  { SwitchToMode "Locked"; }
        bind "Esc"    { UndoRenamePane; SwitchToMode "Locked"; }
        bind "Ctrl c" { SwitchToMode "Locked"; }
    }

}

// =============================================================================
// PLUGINS - aliases used in layouts (unchanged from the main config)
// =============================================================================
plugins {
    tab-bar location="zellij:tab-bar"
    status-bar location="zellij:status-bar"
    strider location="zellij:strider"
    compact-bar location="zellij:compact-bar"
    session-manager location="zellij:session-manager"
    welcome-screen location="zellij:session-manager" {
        welcome_screen true
    }
    filepicker location="zellij:strider" {
        cwd "/"
    }

    zjstatus location="file:~/.config/zellij/plugins/zjstatus.wasm" {
        color_rosewater "#f5e0dc"
        color_flamingo  "#f2cdcd"
        color_pink      "#f5c2e7"
        color_mauve     "#cba6f7"
        color_red       "#f38ba8"
        color_maroon    "#eba0ac"
        color_peach     "#fab387"
        color_yellow    "#f9e2af"
        color_green     "#a6e3a1"
        color_teal      "#94e2d5"
        color_sky       "#89dceb"
        color_sapphire  "#74c7ec"
        color_blue      "#89b4fa"
        color_lavender  "#b4befe"
        color_text      "#cdd6f4"
        color_subtext1  "#bac2de"
        color_subtext0  "#a6adc8"
        color_overlay2  "#9399b2"
        color_overlay1  "#7f849c"
        color_overlay0  "#6c7086"
        color_surface2  "#585b70"
        color_surface1  "#45475a"
        color_surface0  "#313244"
        color_base      "#1e1e2e"
        color_mantle    "#181825"
        color_crust     "#11111b"

        format_left "#[bg=$surface0,fg=$blue]#[bg=$blue,fg=$crust,bold] {session} {mode} {tabs}"
        format_center "{notifications}"
        format_right "#[bg=$surface0,fg=$mauve]#[bg=$surface0,fg=$mauve]#[bg=$mauve,fg=$crust]¾░āŁ #[bg=$surface1,fg=$mauve,bold] {datetime}#[bg=$surface0,fg=$surface1]"
        format_space " "
        format_hide_on_overlength "true"
        format_precedence "lrc"
        border_enabled "false"
        border_char "ŌöĆ"
        border_format "#[bg=$surface0]{char}"
        border_position "top"
        hide_frame_for_single_pane "false"
        mode_normal "#[bg=$green,fg=$crust,bold] NORMAL#[bg=$surface0,fg=$green]"
        mode_tmux "#[bg=$mauve,fg=$crust,bold] TMUX#[bg=$surface0,fg=$mauve]"
        mode_locked "#[bg=$red,fg=$crust,bold] LOCKED  #[bg=$surface0,fg=$red]"
        mode_pane "#[bg=$teal,fg=$crust,bold] PANE#[bg=$surface0,fg=teal]"
        mode_tab "#[bg=$teal,fg=$crust,bold] TAB#[bg=$surface0,fg=$teal]"
        mode_scroll "#[bg=$flamingo,fg=$crust,bold] SCROLL#[bg=$surface0,fg=$flamingo]"
        mode_enter_search "#[bg=$flamingo,fg=$crust,bold] ENT-SEARCH#[bg=$surfaco,fg=$flamingo]"
        mode_search "#[bg=$flamingo,fg=$crust,bold] SEARCHARCH#[bg=$surfac0,fg=$flamingo]"
        mode_resize "#[bg=$yellow,fg=$crust,bold] RESIZE#[bg=$surfac0,fg=$yellow]"
        mode_rename_tab "#[bg=$yellow,fg=$crust,bold] RENAME-TAB#[bg=$surface0,fg=$yellow]"
        mode_rename_pane "#[bg=$yellow,fg=$crust,bold] RENAME-PANE#[bg=$surface0,fg=$yellow]"
        mode_move "#[bg=$yellow,fg=$crust,bold] MOVE#[bg=$surface0,fg=$yellow]"
        mode_session "#[bg=$pink,fg=$crust,bold] SESSION#[bg=$surface0,fg=$pink]"
        mode_prompt "#[bg=$pink,fg=$crust,bold] PROMPT#[bg=$surface0,fg=$pink]"
        tab_normal "#[bg=$surface0,fg=$overlay0]#[bg=$overlay0,fg=$crust,bold]{index} #[bg=$surface1,fg=$overlay0,bold] {name}{floating_indicator}#[bg=$surface0,fg=$surface1]"
        tab_normal_fullscreen "#[bg=$surface0,fg=$overlay0]#[bg=$overlay0,fg=$crust,bold]{index} #[bg=$surface1,fg=$overlay0,bold] {name}{fullscreen_indicator}#[bg=$surface0,fg=$surface1]"
        tab_normal_sync "#[bg=$surface0,fg=$overlay0]#[bg=$overlay0,fg=$crust,bold]{index} #[bg=$surface1,fg=$overlay0,bold] {name}{sync_indicator}#[bg=$surface0,fg=$surface1]"
        tab_active "#[bg=$surface0,fg=$mauve]#[bg=$mauve,fg=$crust,bold]{index} #[bg=$surface1,fg=$mauve,bold] {name}{floating_indicator}#[bg=$surface0,fg=$surface1]"
        tab_active_fullscreen "#[bg=$surface0,fg=$mauve]#[bg=$mauve,fg=$crust,bold]{index} #[bg=$surface1,fg=$mauve,bold] {name}{fullscreen_indicator}#[bg=$surface0,fg=$surface1]"
        tab_active_sync "#[bg=$surface0,fg=$mauve]#[bg=$mauve,fg=$crust,bold]{index} #[bg=$surface1,fg=$mauve,bold] {name}{sync_indicator}#[bg=$surface0,fg=$surface1]"
        tab_separator "#[bg=$surface0] "
        tab_sync_indicator " "
        tab_fullscreen_indicator " ¾░Ŗō"
        tab_floating_indicator " ¾░╣Ö"
        notification_format_unread "#[bg=surface0,fg=$yellow]#[bg=$yellow,fg=$crust] #[bg=$surface1,fg=$yellow] {message}#[bg=$surface0,fg=$yellow]"
        notification_format_no_notifications ""
        notification_show_interval "10"

        datetime "{format}"
        datetime_format "%A, %B %d %H:%M %p"
        datetime_timezone "Europe/Madrid"
    }
}

load_plugins {
    "file:~/.config/zellij/plugins/zellij_forgot.wasm"
}
