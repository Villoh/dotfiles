{
  "skillListingBudgetFraction": 0.02,
  "env": {
    "ANTHROPIC_BASE_URL": "http://127.0.0.1:8317",
    "ANTHROPIC_AUTH_TOKEN": "no-key",
    "CLAUDE_CODE_ENABLE_GATEWAY_MODEL_DISCOVERY": "1"
  },
  "permissions": {
    "defaultMode": "bypassPermissions"
  },
  "model": "claude-sonnet-4-6",
  "hooks": {},
  "statusLine": {
    "type": "command",
    "command": "cols=$(stty size \u003C/dev/tty 2\u003E/dev/null | awk \u0027{print $2}\u0027); export COLUMNS=$(( ${cols:-120} \u003E 4 ? ${cols:-120} - 4 : 1 )); plugin_dir=$(ls -1d \u0022${CLAUDE_CONFIG_DIR:-$HOME/.claude}\u0022/plugins/cache/*/claude-hud/*/ 2\u003E/dev/null | sort -V | tail -1); exec \u0022/c/Program Files/nodejs/node\u0022 \u0022${plugin_dir}dist/index.js\u0022"
  },
  "enabledPlugins": {
    "basedpyright@claude-code-lsps": true,
    "caveman@caveman": true,
    "claude-hud@claude-hud": true,
    "dart@claude-code-lsps": true,
    "frontend-slides@frontend-slides": true,
    "gopls-lsp@claude-plugins-official": true,
    "jdtls-lsp@claude-plugins-official": true,
    "jdtls@claude-code-lsps": true,
    "kotlin-lsp@claude-plugins-official": true,
    "powershell-editor-services@claude-code-lsps": true,
    "pyright-lsp@claude-plugins-official": true,
    "pyright@claude-code-lsps": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "superpowers@superpowers-marketplace": true,
    "typescript-lsp@claude-plugins-official": true,
    "vscode-langservers@claude-code-lsps": true,
    "csharp-lsp@claude-plugins-official": true,
    "plannotator@plannotator": true
  },
  "extraKnownMarketplaces": {
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    },
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    },
    "claude-code-lsps": {
      "source": {
        "source": "github",
        "repo": "Piebald-AI/claude-code-lsps"
      }
    },
    "claude-hud": {
      "source": {
        "source": "github",
        "repo": "jarrodwatts/claude-hud"
      }
    },
    "everything-claude-code": {
      "source": {
        "source": "git",
        "url": "https://github.com/affaan-m/everything-claude-code.git"
      }
    },
    "frontend-slides": {
      "source": {
        "source": "github",
        "repo": "zarazhangrui/frontend-slides"
      }
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    },
    "superpowers-marketplace": {
      "source": {
        "source": "github",
        "repo": "obra/superpowers-marketplace"
      }
    },
    "plannotator": {
      "source": {
        "source": "github",
        "repo": "backnotprop/plannotator"
      }
    }
  },
  "voice": {
    "enabled": false,
    "mode": "hold"
  },
  "skipDangerousModePermissionPrompt": true,
  "voiceEnabled": false
}
