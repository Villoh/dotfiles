# =============================================================================
# tmux / psmux - LOCK/UNLOCK scheme, mirrored from the Zellij Option A config
# =============================================================================
# Path: ~/.tmux.conf (only if promoted from this file)
# Windows uses psmux. Linux uses tmux.
#
# Philosophy: prefix = "Ctrl g", same gate key as Zellij's lock/unlock config,
# for identical muscle memory across both tools. Unlike Zellij, tmux's own
# prefix mechanism ALREADY auto-reverts to passthrough after one keystroke —
# no manual re-lock chaining needed, this is tmux's native single-shot design
# (the exact behavior we had to hand-build in Zellij's KDL).
#
# The only no-prefix exception kept: Ctrl+Alt+hjkl for pane focus (same one
# deliberate exception made in the Zellij config, for low-collision-risk
# high-frequency navigation).
# =============================================================================

# --- shell & behavior ---------------------------------------------------------
{{ if eq .chezmoi.os "windows" -}}
set -g default-shell "pwsh"
{{ end -}}
set -g mouse on
set -g mode-keys vi
set -g history-limit 10000
set -g base-index 1
set -g pane-base-index 1
set -g renumber-windows on
set -g automatic-rename off
set -g allow-rename off
set -g focus-events on
set -g status-position bottom
set -g repeat-time 750

{{ if ne .chezmoi.os "windows" -}}
# --- Linux tmux plugins -------------------------------------------------------
set -g @plugin 'tmux-plugins/tpm'
set -g @plugin 'tmux-plugins/tmux-sensible'
set -g @plugin 'tmux-plugins/tmux-yank'
set -g @plugin 'christoomey/vim-tmux-navigator'
set -g @plugin 'tmux-plugins/tmux-resurrect'
set -g @plugin 'Nybkox/tmux-kanagawa'

set -g @kanagawa-theme 'Kanagawa'
set -g @kanagawa-plugins "git cpu-usage ram-usage"
set -g @kanagawa-ignore-window-colors true

set -g default-terminal "tmux-256color"
set -ga terminal-overrides ",*:Tc"
set -s extended-keys off

if-shell 'command -v wl-copy >/dev/null 2>&1' \
  'bind-key -T copy-mode-vi y send-keys -X copy-pipe-and-cancel "wl-copy"' \
  'bind-key -T copy-mode-vi y send-keys -X copy-pipe-and-cancel "xclip -selection clipboard"'
{{ end -}}

# --- prefix: Ctrl g (same gate key as Zellij) --------------------------------
unbind-key C-b
set -g prefix C-g
bind-key C-g send-prefix

# --- no-prefix exception: Ctrl+Alt+hjkl pane focus (mirrors the Zellij one) -
# Ctrl+Alt (not plain Alt) per herdr's own vetted-safe recommendation: the
# only modifier family left untouched by every terminal/OS combination tested.
bind-key -n C-M-h    if-shell -F '#{pane_at_left}'  'previous-window' 'select-pane -L'
bind-key -n C-M-Left if-shell -F '#{pane_at_left}'  'previous-window' 'select-pane -L'
bind-key -n C-M-j    select-pane -D
bind-key -n C-M-Down select-pane -D
bind-key -n C-M-k    select-pane -U
bind-key -n C-M-Up   select-pane -U
bind-key -n C-M-l    if-shell -F '#{pane_at_right}' 'next-window'     'select-pane -R'
bind-key -n C-M-Right if-shell -F '#{pane_at_right}' 'next-window'    'select-pane -R'

# =============================================================================
# Everything below is behind the prefix (Ctrl g + key). tmux auto-returns to
# passthrough after one keystroke natively — no re-lock chaining needed.
# =============================================================================

# --- pane focus (also reachable via prefix, repeatable within repeat-time) --
bind-key -r h select-pane -L
bind-key -r j select-pane -D
bind-key -r k select-pane -U
bind-key -r l select-pane -R

# --- pane creation (mirrors Zellij: s/d/r, no "stacked" layout equivalent) --
bind-key s if-shell -F '#{>=:#{pane_width},#{pane_height}}' \
    'split-window -h -c "#{pane_current_path}"' \
    'split-window -v -c "#{pane_current_path}"'   # smart split (auto axis)
bind-key d split-window -v -c "#{pane_current_path}"   # down
bind-key r split-window -h -c "#{pane_current_path}"   # right

# tmux-vanilla split aliases, rebound to also follow cwd like d/r above
unbind-key '"'
bind-key '"' split-window -v -c "#{pane_current_path}"   # down (tmux default key)
unbind-key '%'
bind-key '%' split-window -h -c "#{pane_current_path}"   # right (tmux default key)

# herdr-style split aliases (herdr's own defaults: prefix+minus / prefix+v)
bind-key -  split-window -v -c "#{pane_current_path}"   # down (herdr default key)
bind-key v  split-window -h -c "#{pane_current_path}"   # right (herdr default key)
# tmux's native prefix+s (choose-tree sessions) is overridden above by smart
# split; session tree is still reachable via "w" below.

bind-key x confirm-before -p "kill-pane #P? (y/n)" kill-pane   # close pane
bind-key z resize-pane -Z                                       # fullscreen/zoom
bind-key f display-popup -d "#{pane_current_path}" -E "#{default-shell}"  # floating-ish popup

# --- rename pane (tmux has no true pane rename; sets the pane title) --------
bind-key t command-prompt -p "pane title:" "select-pane -T '%%'"   # mnemonic: Title

# --- resize: sticky key-table, tmux repeat-time equivalent, timeout-free ----
# (uses a persistent table: each bound action re-enters the table so you can
# keep resizing without repeating the prefix, exit with Esc/Enter/q)
# Mnemonic: Ctrl r = Resize. +/-/= freed for split-down/right aliases.
bind-key -T prefix -N "enter resize table" C-r switch-client -T resize
bind-key -T resize h      resize-pane -L 3 \; switch-client -T resize
bind-key -T resize Left   resize-pane -L 3 \; switch-client -T resize
bind-key -T resize j      resize-pane -D 3 \; switch-client -T resize
bind-key -T resize Down   resize-pane -D 3 \; switch-client -T resize
bind-key -T resize k      resize-pane -U 3 \; switch-client -T resize
bind-key -T resize Up     resize-pane -U 3 \; switch-client -T resize
bind-key -T resize l      resize-pane -R 3 \; switch-client -T resize
bind-key -T resize Right  resize-pane -R 3 \; switch-client -T resize
bind-key -T resize Esc    switch-client -T prefix
bind-key -T resize Enter  switch-client -T prefix
bind-key -T resize q      switch-client -T prefix

# --- move mode: sticky key-table (swaps the focused pane in a direction) ---
bind-key m switch-client -T move
bind-key -T move h     swap-pane -t '{left-of}'  \; switch-client -T move
bind-key -T move Left  swap-pane -t '{left-of}'  \; switch-client -T move
bind-key -T move j     swap-pane -t '{down-of}'  \; switch-client -T move
bind-key -T move Down  swap-pane -t '{down-of}'  \; switch-client -T move
bind-key -T move k     swap-pane -t '{up-of}'    \; switch-client -T move
bind-key -T move Up    swap-pane -t '{up-of}'    \; switch-client -T move
bind-key -T move l     swap-pane -t '{right-of}' \; switch-client -T move
bind-key -T move Right swap-pane -t '{right-of}' \; switch-client -T move
bind-key -T move Esc   switch-client -T prefix
bind-key -T move Enter switch-client -T prefix
bind-key -T move m     switch-client -T prefix

# --- tabs (tmux windows) ------------------------------------------------------
bind-key c new-window -c "#{pane_current_path}"   # new tab (tmux-canonical letter)
unbind-key ,
bind-key , previous-window
unbind-key .
bind-key . next-window
unbind-key p
bind-key p previous-window   # alias, matches tmux-vanilla n/p
unbind-key n
bind-key n next-window       # alias, matches tmux-vanilla n/p
# 1-9: tmux's native default select-window bindings already work as-is
# (base-index 1 above makes them line up with Zellij's GoToTab 1-9)

bind-key T kill-window                             # Shift+t = close tab
bind-key R command-prompt -I "#W" "rename-window '%%'"   # Shift+r = rename tab

bind-key i swap-window -t -1 \; select-window -t -1   # move tab left
bind-key o swap-window -t +1 \; select-window -t +1   # move tab right

# --- layouts -------------------------------------------------------------------
unbind-key '['
bind-key '[' previous-layout
unbind-key ']'
bind-key ']' next-layout

# --- session -------------------------------------------------------------------
bind-key w choose-tree -Zs         # session manager (matches Zellij "w")
bind-key D detach-client            # Shift+d = detach

# --- scroll / copy-mode (matches Zellij Ctrl-s entry) --------------------------
bind-key C-s copy-mode

# --- quit: tmux's native confirm-before is the REAL confirm dialog Zellij lacks
bind-key C-q confirm-before -p "kill session #S? (y/n)" kill-session

# --- help / cheatsheet ---------------------------------------------------------
{{ if eq .chezmoi.os "windows" -}}
bind-key y display-popup -E "pwsh -NoLogo -NoProfile -Command \"less -N -- (Join-Path $env:USERPROFILE '.tmux-keys')\""
{{ else -}}
bind-key y display-popup -E "less -N -- ~/.tmux-keys"
{{ end -}}
bind-key Y list-keys

{{ if ne .chezmoi.os "windows" -}}
# --- TPM init -----------------------------------------------------------------
run '~/.tmux/plugins/tpm/tpm'
{{ end -}}

# =============================================================================
# Zellij <-> tmux key parity cheat sheet (both use Ctrl-g as the gate)
# =============================================================================
# Keys that MATCH Zellij exactly:
# h/j/k/l        -> focus pane            (also Ctrl+Alt+hjkl, no prefix, both tools)
# d/r            -> new pane down/right
# x              -> close pane (tmux asks y/n natively; Zellij does not)
# z              -> fullscreen/zoom
# f              -> floating-ish popup shell
# +/-/=          -> enter sticky Resize table   (hjkl to resize, Esc/Enter/q exit)
# m              -> enter sticky Move table     (hjkl to swap pane, Esc/Enter/m exit)
# 1-9            -> go to tab N
# Shift+t        -> close tab/window
# i/o            -> move tab left/right
# [/]            -> prev/next layout
# w              -> session manager (choose-tree)
# Shift+d        -> detach
# Ctrl-s         -> scroll/copy-mode
# Ctrl-q         -> quit (WITH confirm-before — better than Zellij here)
# y/Y            -> cheatsheet / raw keylist
#
# Keys that DIVERGE from Zellij on purpose (tmux-specific choices):
# s              -> new pane, smart split (Zellij uses "s" for stacked instead)
# c              -> new tab/window          (Zellij uses "c" for rename pane)
# t              -> rename pane             (Zellij uses "t" for new tab)
# n/p            -> next/previous tab, ALIAS alongside ,/. (tmux-vanilla mnemonic;
#                   Zellij has no equivalent alias, only ,/.)
# Shift+r        -> rename tab/window (unchanged, still matches Zellij)
