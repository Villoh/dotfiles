{
  "lastChangelogVersion": "0.80.10",
  "defaultProvider": "tunnel-agent-cliproxy",
  "defaultModel": "gpt-5.6-terra",
  "defaultThinkingLevel": "medium",
  "packages": [
    "npm:pi-mcp-adapter",
    "npm:pi-rtk-optimizer",
    "npm:pi-subagents",
    "npm:@juicesharp/rpiv-ask-user-question",
    "npm:@juicesharp/rpiv-todo",
    "npm:@juicesharp/rpiv-btw",
    "npm:@juicesharp/rpiv-advisor",
    "npm:@juicesharp/rpiv-args",
    "npm:pi-web-access",
    "npm:pi-autoresearch",
    "npm:pi-caveman",
    "npm:pi-markdown-preview",
    "npm:pi-studio",
    "npm:@upstash/context7-pi",
    "git:github.com/DietrichGebert/ponytail",
    "npm:@ff-labs/pi-fff",
    "npm:@injaneity/pi-computer-use",
    "npm:@quintinshaw/pi-dynamic-workflows",
    "npm:pi-rewind",
    "npm:pi-codex-goal",
    "npm:pi-lens",
    "npm:pi-messenger",
    "npm:pi-intercom",
    "npm:pi-cliproxy-usage"
  ],
  "powerline": {
    "preset": "default",
    "fixedEditor": true
  },
  "npmCommand": [
    "npm"
  ],
  "hideThinkingBlock": false,
  "theme": "dark",
  "subagents": {
    "defaultModel": "tunnel-agent-cliproxy/gpt-5.6-sol",
    "modelScope": {
      "enforce": true,
      "allow": [
        "tunnel-agent-cliproxy/*",
        "tunnel-agent-cliproxy-anthropic/*"
      ]
    },
    "agentOverrides": {
      "scout": {
        "model": "tunnel-agent-cliproxy/gpt-5.4-mini",
        "thinking": "low",
        "fallbackModels": [
          "tunnel-agent-cliproxy/gpt-5.6-luna"
        ]
      },
      "researcher": {
        "model": "tunnel-agent-cliproxy/gpt-5.6-terra",
        "thinking": "high",
        "fallbackModels": [
          "tunnel-agent-cliproxy-anthropic/claude-sonnet-5"
        ]
      },
      "context-builder": {
        "model": "tunnel-agent-cliproxy/gpt-5.6-terra",
        "thinking": "high",
        "fallbackModels": [
          "tunnel-agent-cliproxy/gpt-5.6-sol"
        ]
      },
      "planner": {
        "model": "tunnel-agent-cliproxy/gpt-5.6-sol",
        "thinking": "max",
        "fallbackModels": [
          "tunnel-agent-cliproxy-anthropic/claude-fable-5"
        ]
      },
      "worker": {
        "model": "tunnel-agent-cliproxy/gpt-5.6-sol",
        "thinking": "high",
        "fallbackModels": [
          "tunnel-agent-cliproxy-anthropic/claude-fable-5"
        ]
      },
      "reviewer": {
        "model": "tunnel-agent-cliproxy-anthropic/claude-fable-5",
        "thinking": "high",
        "fallbackModels": [
          "tunnel-agent-cliproxy/gpt-5.6-sol"
        ]
      },
      "oracle": {
        "model": "tunnel-agent-cliproxy-anthropic/claude-opus-4-8",
        "thinking": "max",
        "fallbackModels": [
          "tunnel-agent-cliproxy/gpt-5.6-sol"
        ]
      },
      "delegate": {
        "model": "tunnel-agent-cliproxy/gpt-5.6-terra",
        "thinking": "medium",
        "fallbackModels": [
          "tunnel-agent-cliproxy-anthropic/claude-sonnet-5"
        ]
      }
    }
  }
}