    "defaultProfile": "{574e775e-4f2a-5b96-ac1e-a2962a402336}",
    "keybindings": 
    [
        {
            "id": "Terminal.CopyToClipboard",
            "keys": "ctrl+shift+c"
        },
        {
            "id": "Terminal.SplitPaneDown",
            "keys": "ctrl+shift+d"
        },
        {
            "id": "Terminal.PrevTab",
            "keys": "ctrl+shift+tab"
        },
        {
            "id": "Terminal.NextTab",
            "keys": "ctrl+tab"
        },
        {
            "id": "Terminal.ResizePaneLeft",
            "keys": "ctrl+alt+shift+left"
        },
        {
            "id": "Terminal.PasteFromClipboard",
            "keys": "ctrl+shift+v"
        },
        {
            "id": "Terminal.ClosePane",
            "keys": "ctrl+shift+w"
        },
        {
            "id": "User.closeTab.0",
            "keys": "ctrl+shift+q"
        },
        {
            "id": "Terminal.TogglePaneZoom",
            "keys": "ctrl+shift+z"
        },
        {
            "id": "Terminal.FindText",
            "keys": "ctrl+shift+f"
        },
        {
            "id": "Terminal.OpenNewTab",
            "keys": "ctrl+shift+t"
        },
        {
            "id": "Terminal.OpenNewWindow",
            "keys": "ctrl+shift+n"
        },
        {
            "id": "Terminal.SplitPaneRight",
            "keys": "ctrl+shift+e"
        },
        {
            "id": "Terminal.MoveFocusLeft",
            "keys": "ctrl+alt+left"
        },
        {
            "id": "Terminal.MoveFocusRight",
            "keys": "ctrl+alt+right"
        },
        {
            "id": "Terminal.MoveFocusUp",
            "keys": "ctrl+alt+up"
        },
        {
            "id": "Terminal.MoveFocusDown",
            "keys": "ctrl+alt+down"
        },
        {
            "id": "Terminal.ResizePaneRight",
            "keys": "ctrl+alt+shift+right"
        },
        {
            "id": "Terminal.ResizePaneUp",
            "keys": "ctrl+alt+shift+up"
        },
        {
            "id": "Terminal.ResizePaneDown",
            "keys": "ctrl+alt+shift+down"
        },
        {
            "id": "Terminal.DecreaseFontSize",
            "keys": "ctrl+minus"
        },
        {
            "id": "Terminal.IncreaseFontSize",
            "keys": "ctrl+plus"
        },
        {
            "id": "Terminal.ResetFontSize",
            "keys": "ctrl+0"
        },
        {
            "id": "Terminal.ScrollUpPage",
            "keys": "shift+pgup"
        },
        {
            "id": "Terminal.ScrollDownPage",
            "keys": "shift+pgdn"
        },
        {
            "id": "Terminal.ScrollToTop",
            "keys": "shift+home"
        },
        {
            "id": "Terminal.ScrollToBottom",
            "keys": "shift+end"
        }
    ],
