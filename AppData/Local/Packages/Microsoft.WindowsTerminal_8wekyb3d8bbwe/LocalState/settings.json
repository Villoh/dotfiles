{
    "$help": "https://aka.ms/terminal-documentation",
    "$schema": "https://aka.ms/terminal-profiles-schema",
    "actions": [],
    "alwaysShowTabs": true,
    "centerOnLaunch": true,
    "copyFormatting": "none",
    "copyOnSelect": false,
    "defaultProfile": "{574e775e-4f2a-5b96-ac1e-a2962a402336}",
    "keybindings":
    [
        { "command": "copy",                                         "keys": "ctrl+shift+c"         },
        { "command": "paste",                                        "keys": "ctrl+shift+v"         },
        { "command": "find",                                         "keys": "ctrl+shift+f"         },
        { "command": "newTab",                                       "keys": "ctrl+shift+t"         },
        { "command": "closeTab",                                     "keys": "ctrl+shift+q"         },
        { "command": "closePane",                                    "keys": "ctrl+shift+w"         },
        { "command": "nextTab",                                      "keys": "ctrl+tab"             },
        { "command": "prevTab",                                      "keys": "ctrl+shift+tab"       },
        { "command": "newWindow",                                    "keys": "ctrl+shift+n"         },
        { "command": { "action": "splitPane", "split": "right" },   "keys": "ctrl+shift+e"         },
        { "command": { "action": "splitPane", "split": "down"  },   "keys": "ctrl+shift+d"         },
        { "command": "togglePaneZoom",                               "keys": "ctrl+shift+z"         },
        { "command": { "action": "moveFocus", "direction": "left"  },"keys": "ctrl+alt+left"       },
        { "command": { "action": "moveFocus", "direction": "right" },"keys": "ctrl+alt+right"      },
        { "command": { "action": "moveFocus", "direction": "up"    },"keys": "ctrl+alt+up"         },
        { "command": { "action": "moveFocus", "direction": "down"  },"keys": "ctrl+alt+down"       },
        { "command": { "action": "resizePane", "direction": "left"  },"keys": "ctrl+alt+shift+left" },
        { "command": { "action": "resizePane", "direction": "right" },"keys": "ctrl+alt+shift+right"},
        { "command": { "action": "resizePane", "direction": "up"    },"keys": "ctrl+alt+shift+up"   },
        { "command": { "action": "resizePane", "direction": "down"  },"keys": "ctrl+alt+shift+down" },
        { "command": { "action": "adjustFontSize", "delta": 1  },   "keys": "ctrl+plus"            },
        { "command": { "action": "adjustFontSize", "delta": -1 },   "keys": "ctrl+minus"           },
        { "command": "resetFontSize",                                "keys": "ctrl+0"               },
        { "command": "scrollUpPage",                                 "keys": "shift+pgup"           },
        { "command": "scrollDownPage",                               "keys": "shift+pgdn"           },
        { "command": "scrollToTop",                                  "keys": "shift+home"           },
        { "command": "scrollToBottom",                               "keys": "shift+end"            }
    ],
    "newTabMenu":
    [
        {
            "type": "remainingProfiles"
        }
    ],
    "profiles":
    {
        "defaults":
        {
            "colorScheme": "catppuccin-mocha",
            "font":
            {
                "face": "CaskaydiaCove Nerd Font"
            },
            "opacity": 95
        },
