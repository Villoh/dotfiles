{
  "docker": {
    "command": "uvx",
    "args": [
      "mcp-server-docker"
    ]
  },
  "MCP_DOCKER": {
    "command": "docker",
    "args": [
      "mcp",
      "gateway",
      "run"
    ]
  },
  "context7": {
    "command": "npx",
    "args": [
      "-y",
      "@upstash/context7-mcp",
      "--api-key",
      "YOUR_REDACTED_HERE"
    ]
  },
  "Framelink MCP for Figma": {
    "command": "npx",
    "args": [
      "-y",
      "figma-developer-mcp",
      "--figma-api-key (REDACTED)",
      "--stdio"
    ]
  },
  "TalkToFigma": {
    "command": "bunx",
    "args": [
      "cursor-talk-to-figma-mcp@latest"
    ]
  },
  "linkedin": {
    "command": "uvx",
    "args": [
      "linkedin-scraper-mcp"
    ]
  },
  "chrome-devtools": {
    "command": "npx",
    "args": [
      "-y",
      "chrome-devtools-mcp@latest"
    ]
  },
  "playwright": {
    "command": "npx",
    "args": [
      "@playwright/mcp@latest"
    ]
  }
}
