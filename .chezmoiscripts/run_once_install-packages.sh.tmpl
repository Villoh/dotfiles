{{ if ne .chezmoi.os "windows" -}}
#!/bin/bash
set -uo pipefail

PKG_DIR="{{ .chezmoi.sourceDir }}/packages/linux"
LOG_FILE="/tmp/chezmoi-install-$(date +%Y%m%d-%H%M%S).log"

# ── Logging helpers ────────────────────────────────────────────────────────────
log()     { local msg="[$(date +%H:%M:%S)] $*"; echo "$msg" | tee -a "$LOG_FILE"; }
log_ok()  { log "  ✅ $*"; }
log_skip(){ log "  ⚠️  $*"; }
log_fail(){ log "  ❌ $*"; }
log_section() { log; log "── $* ──"; }

ok=0; skip=0; fail=0

try_install() {
    local name="$1"; shift
    if "$@" >> "$LOG_FILE" 2>&1; then
        log_ok "$name"
        (( ok++ )) || true
    else
        log_fail "$name"
        (( fail++ )) || true
    fi
}

log "Chezmoi install started — log: $LOG_FILE"

# ── Bootstrap ─────────────────────────────────────────────────────────────────
log_section "Bootstrap"

# paru (AUR helper) — build from AUR if neither paru nor yay present
if ! command -v paru &>/dev/null && ! command -v yay &>/dev/null; then
    try_install "paru" bash -c '
        sudo pacman -S --needed --noconfirm base-devel git
        git clone https://aur.archlinux.org/paru-bin.git /tmp/paru-bin
        cd /tmp/paru-bin && makepkg -si --noconfirm
        rm -rf /tmp/paru-bin
    '
else
    log_skip "AUR helper already installed ($(command -v paru &>/dev/null && echo paru || echo yay))"
    (( skip++ )) || true
fi

# Use paru or yay, whichever is available
AUR_HELPER=$(command -v paru 2>/dev/null || command -v yay 2>/dev/null || echo "")

# flatpak
if ! command -v flatpak &>/dev/null; then
    try_install "flatpak" sudo pacman -S --needed --noconfirm flatpak
else
    log_skip "flatpak already installed"
    (( skip++ )) || true
fi

# node / npm
if ! command -v node &>/dev/null; then
    try_install "node" sudo pacman -S --needed --noconfirm nodejs npm
else
    log_skip "node already installed"
    (( skip++ )) || true
fi

# bun
if ! command -v bun &>/dev/null; then
    try_install "bun" bash -c 'curl -fsSL https://bun.sh/install | bash'
    export PATH="$HOME/.bun/bin:$PATH"
else
    log_skip "bun already installed"
    (( skip++ )) || true
fi

# uv
if ! command -v uv &>/dev/null; then
    try_install "uv" bash -c 'curl -LsSf https://astral.sh/uv/install.sh | sh'
    export PATH="$HOME/.local/bin:$PATH"
else
    log_skip "uv already installed"
    (( skip++ )) || true
fi

# bin (via AUR)
if ! command -v bin &>/dev/null; then
    try_install "bin" "$AUR_HELPER" -S --needed --noconfirm bin-bin
else
    log_skip "bin already installed"
    (( skip++ )) || true
fi

# ── pacman / AUR (via paru) ────────────────────────────────────────────────────
if [ -f "$PKG_DIR/pacman_filtered.txt" ]; then
    log_section "pacman / AUR"
    while IFS= read -r pkg; do
        [[ -z "$pkg" ]] && continue
        if pacman -Qi "$pkg" &>/dev/null; then
            log_skip "$pkg already installed"
            (( skip++ )) || true
        else
            try_install "$AUR_HELPER: $pkg" "$AUR_HELPER" -S --needed --noconfirm "$pkg"
        fi
    done < <(grep -v '^\s*$' "$PKG_DIR/pacman_filtered.txt")
fi

# ── flatpak ───────────────────────────────────────────────────────────────────
if [ -f "$PKG_DIR/flatpak.txt" ]; then
    log_section "flatpak"
    while IFS= read -r app; do
        [[ -z "$app" ]] && continue
        if flatpak list --app | grep -q "$app"; then
            log_skip "$app already installed"
            (( skip++ )) || true
        else
            try_install "flatpak: $app" flatpak install -y --noninteractive "$app"
        fi
    done < "$PKG_DIR/flatpak.txt"
fi

# ── uv tools ──────────────────────────────────────────────────────────────────
if [ -f "$PKG_DIR/uv-tools.txt" ]; then
    log_section "uv"
    while IFS= read -r tool; do
        [[ -z "$tool" || "$tool" == "-" ]] && continue
        try_install "uv: $tool" uv tool install "$tool"
    done < "$PKG_DIR/uv-tools.txt"
fi

# ── bun global packages ───────────────────────────────────────────────────────
if [ -f "$PKG_DIR/bun-global.txt" ]; then
    log_section "bun"
    while IFS= read -r pkg; do
        [[ -z "$pkg" ]] && continue
        try_install "bun: $pkg" bun add -g "$pkg"
    done < "$PKG_DIR/bun-global.txt"
fi

# ── npm global packages ───────────────────────────────────────────────────────
if [ -f "$PKG_DIR/npm-global.txt" ]; then
    log_section "npm"
    while IFS= read -r pkg; do
        [[ -z "$pkg" ]] && continue
        try_install "npm: $pkg" npm install -g "$pkg"
    done < "$PKG_DIR/npm-global.txt"
fi

# ── bin (GitHub release binaries) ─────────────────────────────────────────────
if [ -f "$PKG_DIR/bin-packages.txt" ]; then
    log_section "bin"
    while IFS= read -r url; do
        [[ -z "$url" ]] && continue
        try_install "bin: $url" bin install "$url"
    done < "$PKG_DIR/bin-packages.txt"
fi

# ── Summary ───────────────────────────────────────────────────────────────────
log
log "══════════════════════════════════════"
log "  ✅ OK:      $ok"
log "  ⚠️  Skipped: $skip"
log "  ❌ Failed:  $fail"
log "  📄 Log:     $LOG_FILE"
log "══════════════════════════════════════"
{{ end -}}
