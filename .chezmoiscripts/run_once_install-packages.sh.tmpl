{{ if ne .chezmoi.os "windows" -}}
#!/bin/bash
set -uo pipefail

PKG_DIR="{{ .chezmoi.sourceDir }}/packages/linux"
LOG_FILE="/tmp/chezmoi-install-$(date +%Y%m%d-%H%M%S).log"

# -- Logging helpers -----------------------------------------------------------
log()         { local msg="[$(date +%H:%M:%S)] $*"; echo "$msg" | tee -a "$LOG_FILE"; }
log_ok()      { log "  [OK]   $*"; }
log_skip()    { log "  [SKIP] $*"; }
log_fail()    { log "  [FAIL] $*"; }
log_section() { log; log "-- $* --"; }

ok=0; skip=0; fail=0

try_install() {
    local name="$1"; shift
    if "$@" >> "$LOG_FILE" 2>&1; then
        log_ok "$name"
        (( ok++ )) || true
    else
        log_fail "$name"
        (( fail++ )) || true
    fi
}

log "Chezmoi install started -- log: $LOG_FILE"

# -- Bootstrap -----------------------------------------------------------------
log_section "Bootstrap"

# paru (AUR helper)
if ! command -v paru &>/dev/null && ! command -v yay &>/dev/null; then
    try_install "paru" bash -c '
        sudo pacman -S --needed --noconfirm base-devel git
        git clone https://aur.archlinux.org/paru-bin.git /tmp/paru-bin
        cd /tmp/paru-bin && makepkg -si --noconfirm
        rm -rf /tmp/paru-bin
    '
else
    log_skip "AUR helper already installed ($(command -v paru &>/dev/null && echo paru || echo yay))"
    (( skip++ )) || true
fi

AUR_HELPER=$(command -v paru 2>/dev/null || command -v yay 2>/dev/null || echo "")

# flatpak
if ! command -v flatpak &>/dev/null; then
    try_install "flatpak" sudo pacman -S --needed --noconfirm flatpak
else
    log_skip "flatpak already installed"
    (( skip++ )) || true
fi

# node / npm
if ! command -v node &>/dev/null; then
    try_install "node" sudo pacman -S --needed --noconfirm nodejs npm
else
    log_skip "node already installed"
    (( skip++ )) || true
fi

# bun
if ! command -v bun &>/dev/null; then
    try_install "bun" bash -c 'curl -fsSL https://bun.sh/install | bash'
    export PATH="$HOME/.bun/bin:$PATH"
else
    log_skip "bun already installed"
    (( skip++ )) || true
fi

# uv
if ! command -v uv &>/dev/null; then
    try_install "uv" bash -c 'curl -LsSf https://astral.sh/uv/install.sh | sh'
    export PATH="$HOME/.local/bin:$PATH"
else
    log_skip "uv already installed"
    (( skip++ )) || true
fi

# bin (via AUR)
if ! command -v bin &>/dev/null; then
    try_install "bin" "$AUR_HELPER" -S --needed --noconfirm bin-bin
else
    log_skip "bin already installed"
    (( skip++ )) || true
fi

# -- pacman / AUR --------------------------------------------------------------
if [ -f "$PKG_DIR/pacman_filtered.txt" ]; then
    log_section "pacman / AUR"
    while IFS= read -r pkg; do
        [[ -z "$pkg" ]] && continue
        if pacman -Qi "$pkg" &>/dev/null; then
            log_skip "$pkg already installed"
            (( skip++ )) || true
        else
            try_install "$AUR_HELPER: $pkg" "$AUR_HELPER" -S --needed --noconfirm "$pkg"
        fi
    done < <(grep -v '^\s*$' "$PKG_DIR/pacman_filtered.txt")
fi

# -- flatpak -------------------------------------------------------------------
if [ -f "$PKG_DIR/flatpak.txt" ]; then
    log_section "flatpak"
    while IFS= read -r app; do
        [[ -z "$app" ]] && continue
        if flatpak list --app | grep -q "$app"; then
            log_skip "$app already installed"
            (( skip++ )) || true
        else
            try_install "flatpak: $app" flatpak install -y --noninteractive "$app"
        fi
    done < "$PKG_DIR/flatpak.txt"
fi

# -- npm -----------------------------------------------------------------------
if [ -f "$PKG_DIR/npm-global.txt" ]; then
    log_section "npm"
    npm_installed=$(npm list -g --depth=0 2>/dev/null)
    while IFS= read -r pkg; do
        [[ -z "$pkg" ]] && continue
        pkg_name="${pkg%@*}"
        if echo "$npm_installed" | grep -q "$pkg_name"; then
            log_skip "npm: $pkg already installed"
            (( skip++ )) || true
        else
            try_install "npm: $pkg" npm install -g "$pkg"
        fi
    done < "$PKG_DIR/npm-global.txt"
fi

# -- bun -----------------------------------------------------------------------
if [ -f "$PKG_DIR/bun-global.txt" ]; then
    log_section "bun"
    bun_installed=$(bun pm ls -g 2>/dev/null)
    while IFS= read -r pkg; do
        [[ -z "$pkg" ]] && continue
        pkg_name="${pkg%@*}"
        if echo "$bun_installed" | grep -q "$pkg_name"; then
            log_skip "bun: $pkg already installed"
            (( skip++ )) || true
        else
            try_install "bun: $pkg" bun add -g "$pkg"
        fi
    done < "$PKG_DIR/bun-global.txt"
fi

# -- uv tools ------------------------------------------------------------------
if [ -f "$PKG_DIR/uv-tools.txt" ]; then
    log_section "uv"
    uv_installed=$(uv tool list 2>/dev/null)
    while IFS= read -r tool; do
        [[ -z "$tool" || "$tool" == "-" ]] && continue
        if echo "$uv_installed" | grep -q "$tool"; then
            log_skip "uv: $tool already installed"
            (( skip++ )) || true
        else
            try_install "uv: $tool" uv tool install "$tool"
        fi
    done < "$PKG_DIR/uv-tools.txt"
fi

# -- bin (GitHub release binaries) --------------------------------------------
if [ -f "$PKG_DIR/bin-packages.txt" ]; then
    log_section "bin"
    bin_dir="$HOME/.bin"
    mkdir -p "$bin_dir"
    # Ensure bin config has correct default_path
    bin_config_dir="$HOME/.config/bin"
    bin_config="$bin_config_dir/config.json"
    mkdir -p "$bin_config_dir"
    if [ -f "$bin_config" ]; then
        # Update default_path if wrong
        python3 -c "
import json, sys
with open('$bin_config') as f: c = json.load(f)
c['default_path'] = '$bin_dir/'
with open('$bin_config', 'w') as f: json.dump(c, f, indent=4)
" 2>/dev/null || true
    else
        echo "{\"default_path\": \"$bin_dir/\"}" > "$bin_config"
    fi
    bin_installed=$(bin list 2>/dev/null)
    pushd "$bin_dir" > /dev/null
    while IFS= read -r url; do
        [[ -z "$url" ]] && continue
        base_url="${url%%/releases/*}"
        if echo "$bin_installed" | grep -qF "$base_url"; then
            log_skip "bin: $url already installed"
            (( skip++ )) || true
        else
            try_install "bin: $url" bin install "$url"
        fi
    done < "$PKG_DIR/bin-packages.txt"
    popd > /dev/null
fi

# -- Summary -------------------------------------------------------------------
log
log "======================================"
log "  [OK]   OK:      $ok"
log "  [SKIP] Skipped: $skip"
log "  [FAIL] Failed:  $fail"
log "  [LOG]  Log:     $LOG_FILE"
log "======================================"
{{ end -}}
