{{ if and (ne .chezmoi.os "windows") .enable_secrets -}}
#!/bin/bash
# secrets.json {{ include "packages/linux/system/secrets.json" | sha256sum }}
set -uo pipefail

CONFIG_FILE="{{ .chezmoi.sourceDir }}/packages/linux/system/secrets.json"

if [[ ! -f "$CONFIG_FILE" ]]; then
  echo "  [SKIP] secrets.json not found"
  exit 0
fi

if ! command -v python3 >/dev/null 2>&1; then
  echo "  [FAIL] python3 is required to process secrets.json"
  exit 1
fi

python3 - "$CONFIG_FILE" <<'PY'
import json
import os
import re
import shutil
import shlex
import sys
from pathlib import Path

config_file = Path(sys.argv[1])
config = json.loads(config_file.read_text(encoding="utf-8"))
env_name_re = re.compile(r"^[A-Za-z_][A-Za-z0-9_]*$")

config_home = Path(os.environ.get("XDG_CONFIG_HOME", Path.home() / ".config"))
terminal_file = config_home / "zsh" / "functions" / "api-keys.zsh"
global_file = config_home / "secrets" / "global-env.sh"


def get_secret(spec):
    name = spec.get("name", "")
    if not env_name_re.fullmatch(name):
        print(f"  [SKIP] invalid environment variable name: {name}")
        return None
    if not spec.get("bw_item") or not spec.get("bw_field"):
        print(f"  [SKIP] {name} (missing bw_item or bw_field)")
        return None

    value = None
    if os.environ.get("BW_SESSION"):
        import subprocess
        result = subprocess.run(
            ["bw", "get", "item", spec["bw_item"]],
            check=False,
            capture_output=True,
            text=True,
        )
        if result.returncode == 0 and result.stdout.strip():
            item = json.loads(result.stdout)
            field = spec["bw_field"]
            if field in ("login.password", "password"):
                value = (item.get("login") or {}).get("password")
            elif field == "notes":
                value = item.get("notes")
            else:
                for custom_field in item.get("fields", []):
                    if custom_field.get("name") == field:
                        value = custom_field.get("value")
                        break

    if not value:
        print(f"  [MISS] {name} (no value)")
        return None

    return value


def build_entries(config):
    entries = []
    for group in ("terminal_envs", "global_envs"):
        entry_type = "terminal" if group == "terminal_envs" else "global"
        for spec in config.get(group) or []:
            label = f"[{entry_type:<8}] {spec.get('name', '')} <- {spec.get('bw_item', '')}.{spec.get('bw_field', '')}"
            entries.append({"type": entry_type, "spec": spec, "label": label})
    return entries


def select_entries(entries):
    if not entries:
        return []
    import subprocess
    if os.environ.get("SECRETS_SELECT_ALL"):
        print(f"  [WARN] SECRETS_SELECT_ALL is set - processing all {len(entries)} secrets")
        return entries
    if not shutil.which("fzf"):
        print(f"  [WARN] fzf not found - processing all {len(entries)} secrets")
        return entries
    result = subprocess.run(
        ["fzf", "--multi", "--bind", "ctrl-a:toggle-all,tab:toggle", "--prompt", "  Secrets> ", "--header", "Select secrets to refresh (Ctrl+A select all, Tab toggle, Enter confirm)"],
        input="\n".join(entry["label"] for entry in entries) + "\n",
        check=False,
        stdout=subprocess.PIPE,
        text=True,
    )
    selected = set(result.stdout.splitlines())
    if not selected:
        print("  [SKIP] no secrets selected")
        return []
    return [entry for entry in entries if entry["label"] in selected]


selected_entries = select_entries(build_entries(config))
if not selected_entries:
    sys.exit(0)
terminal_specs = [entry["spec"] for entry in selected_entries if entry["type"] == "terminal"]
global_specs = [entry["spec"] for entry in selected_entries if entry["type"] == "global"]

terminal_lines = ["# API keys -- generated by chezmoi from Bitwarden. Do not edit manually."]
for spec in terminal_specs:
    value = get_secret(spec)
    name = spec.get("name", "")
    if value:
        terminal_lines.append(f"export {name}={shlex.quote(value)}")
        print(f"  [OK]   {name}")
    else:
        print(f"  [SKIP] {name}")

terminal_file.parent.mkdir(parents=True, exist_ok=True)
terminal_file.write_text("\n".join(terminal_lines) + "\n", encoding="utf-8")
terminal_file.chmod(0o600)
print(f"  Secrets written to {terminal_file}")

global_lines = ["# API keys -- generated by chezmoi from Bitwarden. Do not edit manually."]
for spec in global_specs:
    value = get_secret(spec)
    name = spec.get("name", "")
    if value:
        global_lines.append(f"export {name}={shlex.quote(value)}")
        print(f"  [OK]   {name}")
    else:
        print(f"  [SKIP] {name}")

global_file.parent.mkdir(parents=True, exist_ok=True)
global_file.write_text("\n".join(global_lines) + "\n", encoding="utf-8")
global_file.chmod(0o600)
print(f"  Global secrets written to {global_file}")
PY
{{ end -}}
