{{ if eq .chezmoi.os "windows" -}}
# run_onchange_ triggers when any of these change:
# junctions.json       {{ include "packages/windows/system/junctions.json" | sha256sum }}
# startup.json {{ include "packages/windows/system/startup.json" | sha256sum }}
{{ range (glob "program_files/ditto/Themes/*.xml") -}}
# {{ . }} {{ include . | sha256sum }}
{{ end -}}
{{ range (glob "program_files/nilesoft/imports/*.nss") -}}
# {{ . }} {{ include . | sha256sum }}
{{ end -}}
{{ range (glob "program_files/windows/resources/themes/**") -}}
# {{ . }} {{ include . | sha256sum }}
{{ end -}}
{{ range (glob "program_files/windows/cursors/**") -}}
# {{ . }} {{ include . | sha256sum }}
{{ end -}}
{{ range (glob "Pictures/Wallpapers/main-wallpaper.*") -}}
# {{ . }} {{ include . | sha256sum }}
{{ end -}}
{{ range (glob "program_files/windhawk/**") -}}
# {{ . }} {{ include . | sha256sum }}
{{ end -}}
{{ if stat "packages/windows/system/windhawk/settings.reg" -}}
# windhawk/settings.reg {{ include "packages/windows/system/windhawk/settings.reg" | sha256sum }}
{{ end }}
$chezmoisrc = ("{{ .chezmoi.sourceDir }}").Replace('/', '\')
$pkgDir     = "$chezmoisrc\packages\windows"
$logFile    = "$env:TEMP\chezmoi-setup-$(Get-Date -Format 'yyyyMMdd-HHmmss').log"
$tmpScript  = "$env:TEMP\chezmoi-setup.ps1"

@"
`$chezmoisrc = "$chezmoisrc"
`$pkgDir     = "$pkgDir"
`$logFile    = "$logFile"
`$ok = 0; `$skip = 0; `$fail = 0

function Log    { param([string]`$pfx, [string]`$msg) Add-Content -Path "`$logFile" -Value "[`$(Get-Date -Format 'HH:mm:ss')] [`$pfx] `$msg" }
function LogOk  { param([string]`$msg) Log "OK"   `$msg; `$script:ok++   }
function LogSkip{ param([string]`$msg) Log "SKIP" `$msg; `$script:skip++ }
function LogFail{ param([string]`$msg) Log "FAIL" `$msg; `$script:fail++ }
function LogSec { param([string]`$msg) Log "--"   "-- `$msg --"           }
function TryRun {
    param([string]`$name, [scriptblock]`$block)
    try   { & `$block; LogOk `$name }
    catch { LogFail "`$name - `$(`$_.Exception.Message)" }
}
# == JUNCTIONS / SYMLINKS ======================================================
LogSec "Junctions"

if (Test-Path "`$pkgDir\system\junctions.json") {
    `$junctions = Get-Content "`$pkgDir\system\junctions.json" | ConvertFrom-Json
} else {
    LogFail "junctions.json not found - skipping"
    `$junctions = @()
}

foreach (`$j in `$junctions) {
    `$src    = "`$chezmoisrc\`$(`$j.src)"
    `$dst    = [System.Environment]::ExpandEnvironmentVariables(`$j.dst)
    `$parent = Split-Path `$dst
    if (`$parent -and -not (Test-Path `$parent)) { New-Item -ItemType Directory -Force -Path `$parent | Out-Null }
    if (Test-Path `$dst) { Remove-Item `$dst -Recurse -Force }
    if (`$j.type -eq "copy") {
        TryRun "copy: `$dst" { Copy-Item "`$src" "`$dst" -Force }
    } elseif (`$j.type -eq "file") {
        TryRun "symlink: `$dst" { cmd /c mklink "`$dst" "`$src" | Out-Null }
    } else {
        TryRun "junction: `$dst" { cmd /c mklink /J "`$dst" "`$src" | Out-Null }
    }
}

# == STARTUP ENTRIES ===========================================================
LogSec "Startup entries"

if (Test-Path "`$pkgDir\system\startup.json") {
    `$startup = Get-Content "`$pkgDir\system\startup.json" | ConvertFrom-Json

    # -- HKCU\Run registry entries ----------------------------------------------
    `$runPath = "HKCU:\Software\Microsoft\Windows\CurrentVersion\Run"
    foreach (`$entry in `$startup.registry) {
        `$expanded = [System.Environment]::ExpandEnvironmentVariables(`$entry.path)

        if (`$entry.glob) {
            `$expanded = Get-ChildItem (Split-Path `$expanded) -Filter (Split-Path `$expanded -Leaf) -ErrorAction SilentlyContinue |
                Sort-Object Name -Descending | Select-Object -First 1 -ExpandProperty FullName
        }

        if (-not `$expanded -or -not (Test-Path `$expanded)) {
            LogSkip "registry: `$(`$entry.name) (exe not found)"
            continue
        }

        `$value = if (`$entry.args) { "``"`$expanded``" `$(`$entry.args)" } else { "``"`$expanded``"" }
        TryRun "registry: `$(`$entry.name)" {
            Set-ItemProperty -Path `$runPath -Name `$entry.name -Value `$value -Type String
        }
    }

    # -- Startup folder shortcuts -----------------------------------------------
    `$startupFolder = [System.Environment]::GetFolderPath("Startup")
    foreach (`$entry in `$startup.folder) {
        `$expanded = [System.Environment]::ExpandEnvironmentVariables(`$entry.path)

        if (-not (Test-Path `$expanded)) {
            LogSkip "folder: `$(`$entry.name) (exe not found)"
            continue
        }

        `$lnk = "`$startupFolder\`$(`$entry.name).lnk"
        TryRun "folder: `$(`$entry.name)" {
            `$shell   = New-Object -ComObject WScript.Shell
            `$shortcut = `$shell.CreateShortcut(`$lnk)
            `$shortcut.TargetPath = `$expanded
            if (`$entry.args)        { `$shortcut.Arguments  = `$entry.args }
            if (`$entry.windowStyle) { `$shortcut.WindowStyle = `$entry.windowStyle }
            `$shortcut.Save()
        }
    }

    # -- MSIX packaged startup tasks --------------------------------------------
    `$msixBase = "HKCU:\Software\Classes\Local Settings\Software\Microsoft\Windows\CurrentVersion\AppModel\SystemAppData"
    foreach (`$entry in `$startup.msix) {
        `$pkg = Get-AppxPackage -Name "*`$(`$entry.package)*" -ErrorAction SilentlyContinue
        if (-not `$pkg) { LogSkip "msix: `$(`$entry.name) (package not installed)"; continue }

        `$taskKey = Get-ChildItem "`$msixBase\`$(`$pkg.PackageFamilyName)" -ErrorAction SilentlyContinue |
            Where-Object { `$_.GetValue("State") -ne `$null } | Select-Object -First 1

        if (-not `$taskKey) {
            # Key only exists after first launch — start the app once to register it
            `$appExe = Get-ChildItem "`$env:LOCALAPPDATA\Microsoft\WindowsApps" -Filter "*`$(`$entry.package)*" -ErrorAction SilentlyContinue | Select-Object -First 1
            if (`$appExe) {
                `$proc = Start-Process `$appExe.FullName -PassThru -WindowStyle Hidden
                Start-Sleep -Seconds 3
                Stop-Process -Id `$proc.Id -ErrorAction SilentlyContinue
                `$taskKey = Get-ChildItem "`$msixBase\`$(`$pkg.PackageFamilyName)" -ErrorAction SilentlyContinue |
                    Where-Object { `$_.GetValue("State") -ne `$null } | Select-Object -First 1
            }
        }

        if (-not `$taskKey) { LogSkip "msix: `$(`$entry.name) (startup task key not found)"; continue }

        TryRun "msix: `$(`$entry.name)" {
            Set-ItemProperty -Path `$taskKey.PSPath -Name State -Value 2 -Type DWord
        }
    }
} else {
    LogSkip "startup.json not found"
}

# == PROGRAM FILES =============================================================
LogSec "Program files"

`$copies = @(
    @{ Src = "`$chezmoisrc\program_files\ditto\Themes";     Dst = "C:\Program Files\Ditto\Themes";          App = "Ditto";          Ext = "*.xml" },
    @{ Src = "`$chezmoisrc\program_files\nilesoft\imports"; Dst = "C:\Program Files\Nilesoft Shell\imports"; App = "Nilesoft Shell"; Ext = "*.nss" }
)


foreach (`$c in `$copies) {
    if (-not (Test-Path (Split-Path `$c.Dst))) {
        LogSkip "`$(`$c.App) - not installed at '`$(Split-Path `$c.Dst)'"
        continue
    }
    New-Item -ItemType Directory -Force -Path `$c.Dst | Out-Null
    `$files = Get-ChildItem "`$(`$c.Src)\`$(`$c.Ext)" -ErrorAction SilentlyContinue
    `$files | ForEach-Object { Copy-Item `$_.FullName -Destination "`$(`$c.Dst)\`$(`$_.Name)" -Force }
    LogOk "`$(`$c.App) - `$(`$files.Count) file(s) installed"
}

# Exclude themes path from Defender to prevent false positives on unsigned .msstyles
Add-MpPreference -ExclusionPath "C:\Windows\Resources\Themes" -ErrorAction SilentlyContinue

`$rcopies = @(
    @{ Src = "`$chezmoisrc\program_files\windows\resources\themes"; Dst = "C:\Windows\Resources\Themes"; App = "Windows themes" }
)

`$secureUxInstalled = Get-ItemProperty "HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall\*" -ErrorAction SilentlyContinue | Where-Object { `$_.DisplayName -like "*SecureUxTheme*" }

foreach (`$r in `$rcopies) {
    if (-not (Test-Path `$r.Dst)) {
        LogSkip "`$(`$r.App) - destination '`$(`$r.Dst)' not found"
        continue
    }
    `$copyErrors = @()
    Copy-Item -Path "`$(`$r.Src)\*" -Destination `$r.Dst -Recurse -Force -ErrorAction SilentlyContinue -ErrorVariable copyErrors
    if (`$copyErrors.Count -gt 0) {
        LogOk "`$(`$r.App) - installed (`$(`$copyErrors.Count) file(s) skipped - in use)"
    } else {
        LogOk "`$(`$r.App) - installed"
    }
    if (-not `$secureUxInstalled) {
        LogSkip "`$(`$r.App) - SecureUxTheme not installed, themes copied but won't apply"
    }
}

# == CURSOR SCHEMES ============================================================
LogSec "Cursor schemes"

Get-ChildItem "`$chezmoisrc\program_files\windows\cursors" -Recurse -Filter "install.inf" | ForEach-Object {
    `$infFile = `$_
    TryRun "cursor: `$(`$infFile.Directory.Name)" {
        rundll32.exe setupapi.dll,InstallHinfSection DefaultInstall 132 "`$(`$infFile.FullName)"
    }
}

# == WINDHAWK ==================================================================
LogSec "Windhawk"
if (Test-Path "HKLM:\SOFTWARE\Windhawk") {
    Stop-Process -Name "Windhawk*" -Force -ErrorAction SilentlyContinue

    `$whReg = "`$pkgDir\system\windhawk\settings.reg"
    if (Test-Path `$whReg) {
        reg import "`$whReg" 2>`$null
        if (`$LASTEXITCODE -eq 0) { LogOk "Windhawk registry imported" }
        else                      { LogFail "Windhawk registry import failed (exit `$LASTEXITCODE)" }
    } else {
        LogSkip "Windhawk settings.reg not found"
    }

    `$whPf = "`$chezmoisrc\program_files\windhawk"
    if (Test-Path "`$whPf\userprofile.json") {
        New-Item -ItemType Directory -Force -Path "C:\ProgramData\Windhawk" | Out-Null
        Copy-Item "`$whPf\userprofile.json" "C:\ProgramData\Windhawk\userprofile.json" -Force
        LogOk "Windhawk userprofile.json restored"
    } else {
        LogSkip "Windhawk userprofile.json not found"
    }

    if (Test-Path "`$whPf\ModsSource") {
        New-Item -ItemType Directory -Force -Path "C:\ProgramData\Windhawk\ModsSource" | Out-Null
        Copy-Item "`$whPf\ModsSource\*.wh.cpp" "C:\ProgramData\Windhawk\ModsSource\" -Force
        LogOk "Windhawk ModsSource restored"
    } else {
        LogSkip "Windhawk ModsSource not found"
    }

    foreach (`$arch in @("32", "64")) {
        `$src = "`$whPf\`$arch"
        `$dst = "C:\ProgramData\Windhawk\Engine\Mods\`$arch"
        if (Test-Path `$src) {
            New-Item -ItemType Directory -Force -Path `$dst | Out-Null
            `$dlls = Get-ChildItem "`$src\*.dll" -ErrorAction SilentlyContinue
            `$dlls | ForEach-Object { Copy-Item `$_.FullName -Destination "`$dst\`$(`$_.Name)" -Force }
            LogOk "Windhawk DLLs (`$arch-bit) - `$(`$dlls.Count) installed"
        } else {
            LogSkip "Windhawk DLLs `$arch-bit - source not found"
        }
    }
} else {
    LogSkip "Windhawk - not installed"
}

Log "--" "-- elevated summary: `$ok OK  `$skip skipped  `$fail failed --"
"@ | Set-Content $tmpScript

Write-Host "[windows-setup] Requesting elevation..." -ForegroundColor Cyan
Start-Process powershell.exe -Verb RunAs -WindowStyle Hidden -ArgumentList "-NoProfile", "-File", $tmpScript -Wait

# -- Stream log back to current terminal with colors ---------------------------
Write-Host ""
if (Test-Path $logFile) {
    foreach ($line in Get-Content $logFile) {
        if     ($line -match '\[OK\]')   { Write-Host $line -ForegroundColor Green  }
        elseif ($line -match '\[SKIP\]') { Write-Host $line -ForegroundColor Yellow }
        elseif ($line -match '\[FAIL\]') { Write-Host $line -ForegroundColor Red    }
        elseif ($line -match '\[--\]')   { Write-Host $line -ForegroundColor Cyan   }
        else                             { Write-Host $line -ForegroundColor Gray   }
    }
    Remove-Item $logFile
} else {
    Write-Warning "windows-setup: no output received (UAC cancelled or script failed)"
}
Remove-Item $tmpScript -ErrorAction SilentlyContinue

{{ end -}}
