{{ if eq .chezmoi.os "windows" -}}
# run_onchange_ triggers when this script's content changes.
# Hashes for all tracked files that get copied to Program Files:
{{ range (glob "program_files/ditto/Themes/*.xml") -}}
# {{ . }} {{ include . | sha256sum }}
{{ end -}}
{{ range (glob "program_files/nilesoft/imports/*.nss") -}}
# {{ . }} {{ include . | sha256sum }}
{{ end -}}
{{ range (glob "program_files/windows/resources/themes/**") -}}
# {{ . }} {{ include . | sha256sum }}
{{ end -}}
{{ range (glob "program_files/windows/cursors/**") -}}
# {{ . }} {{ include . | sha256sum }}
{{ end }}
$chezmoisrc = ("{{ .chezmoi.sourceDir }}").Replace('/', '\')
$logFile    = "$env:TEMP\chezmoi-program-files-$(Get-Date -Format 'yyyyMMdd-HHmmss').log"
$tmpScript  = "$env:TEMP\install-program-files.ps1"

@"
`$logFile = "$logFile"
`$ok = 0; `$skip = 0; `$fail = 0

function Log    { param([string]`$pfx, [string]`$msg) Add-Content -Path "`$logFile" -Value "[`$(Get-Date -Format 'HH:mm:ss')] [`$pfx] `$msg" }
function LogOk  { param([string]`$msg) Log "OK"   `$msg; `$script:ok++   }
function LogSkip{ param([string]`$msg) Log "SKIP" `$msg; `$script:skip++ }
function LogFail{ param([string]`$msg) Log "FAIL" `$msg; `$script:fail++ }
function LogSec { param([string]`$msg) Log "--"   "-- `$msg --"           }

LogSec "program-files install"

# -- File copies (flat, filtered by extension) ---------------------------------
`$copies = @(
    @{ Src = "$chezmoisrc\program_files\ditto\Themes";     Dst = "C:\Program Files\Ditto\Themes";          App = "Ditto";          Ext = "*.xml" },
    @{ Src = "$chezmoisrc\program_files\nilesoft\imports"; Dst = "C:\Program Files\Nilesoft Shell\imports"; App = "Nilesoft Shell"; Ext = "*.nss" }
)

foreach (`$c in `$copies) {
    if (-not (Test-Path (Split-Path `$c.Dst))) {
        LogSkip "`$(`$c.App) - not installed at '`$(Split-Path `$c.Dst)'"
        continue
    }
    New-Item -ItemType Directory -Force -Path `$c.Dst | Out-Null
    `$files = Get-ChildItem "`$(`$c.Src)\`$(`$c.Ext)" -ErrorAction SilentlyContinue
    `$files | ForEach-Object { Copy-Item `$_.FullName -Destination "`$(`$c.Dst)\`$(`$_.Name)" -Force }
    LogOk "`$(`$c.App) - `$(`$files.Count) file(s) installed"
}

# -- Recursive copies ----------------------------------------------------------
`$rcopies = @(
    @{ Src = "$chezmoisrc\program_files\windows\resources\themes"; Dst = "C:\Windows\Resources\Themes"; App = "Windows themes" }
)

foreach (`$r in `$rcopies) {
    if (-not (Test-Path `$r.Dst)) {
        LogSkip "`$(`$r.App) - destination '`$(`$r.Dst)' not found"
        continue
    }
    `$copyErrors = @()
    Copy-Item -Path "`$(`$r.Src)\*" -Destination `$r.Dst -Recurse -Force -ErrorAction SilentlyContinue -ErrorVariable copyErrors
    if (`$copyErrors.Count -gt 0) {
        LogOk "`$(`$r.App) - installed (`$(`$copyErrors.Count) file(s) skipped - in use)"
    } else {
        LogOk "`$(`$r.App) - installed"
    }
}

# -- Cursor schemes (via .inf installer) ---------------------------------------
LogSec "cursor schemes"
Get-ChildItem "$chezmoisrc\program_files\windows\cursors" -Recurse -Filter "install.inf" | ForEach-Object {
    try {
        rundll32.exe setupapi.dll,InstallHinfSection DefaultInstall 132 "`$(`$_.FullName)"
        LogOk "Cursor: `$(`$_.Directory.Name)"
    } catch {
        LogFail "Cursor: `$(`$_.Directory.Name) - `$(`$_.Exception.Message)"
    }
}

Log "--" "-- summary: `$ok OK  `$skip skipped  `$fail failed --"
"@ | Set-Content $tmpScript

Write-Host "[program-files] Requesting elevation..." -ForegroundColor Cyan
Start-Process powershell.exe -Verb RunAs -WindowStyle Hidden -ArgumentList "-NoProfile", "-File", $tmpScript -Wait

# -- Stream log back to current terminal with colors ---------------------------
Write-Host ""
if (Test-Path $logFile) {
    foreach ($line in Get-Content $logFile) {
        if     ($line -match '\[OK\]')   { Write-Host $line -ForegroundColor Green  }
        elseif ($line -match '\[SKIP\]') { Write-Host $line -ForegroundColor Yellow }
        elseif ($line -match '\[FAIL\]') { Write-Host $line -ForegroundColor Red    }
        elseif ($line -match '\[--\]')   { Write-Host $line -ForegroundColor Cyan   }
        else                             { Write-Host $line -ForegroundColor Gray   }
    }
    Remove-Item $logFile
} else {
    Write-Warning "program-files: no output received (UAC cancelled or script failed)"
}
Remove-Item $tmpScript -ErrorAction SilentlyContinue
{{ end -}}
