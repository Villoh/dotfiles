{{ if and (eq .chezmoi.os "windows") .enable_secrets -}}
# secrets.json {{ include "packages/windows/system/secrets.json" | sha256sum }}
$chezmoisrc = ("{{ .chezmoi.sourceDir }}").Replace('/', '\')
$pkgDir     = "$chezmoisrc\packages\windows"
$secretsDir = "$env:USERPROFILE\Documents\PowerShell\Secrets"
$outFile    = "$secretsDir\api-keys.ps1"
$configFile = "$pkgDir\system\secrets.json"

New-Item -ItemType Directory -Force -Path $secretsDir | Out-Null

function Escape-PowerShellSingleQuotedString {
    param([string]$Value)
    return $Value.Replace("'", "''")
}

function Test-EnvName {
    param([string]$Name)
    return $Name -match "^[A-Za-z_][A-Za-z0-9_]*$"
}

function Invoke-BwGetItem {
    param([string]$ItemName)

    $psi = [System.Diagnostics.ProcessStartInfo]::new()
    $psi.FileName = "bw"
    $psi.Arguments = "get item `"$ItemName`""
    $psi.RedirectStandardInput = $true
    $psi.RedirectStandardOutput = $true
    $psi.RedirectStandardError = $true
    $psi.UseShellExecute = $false

    $process = [System.Diagnostics.Process]::Start($psi)
    $process.StandardInput.Close()
    $stdout = $process.StandardOutput.ReadToEnd()
    $process.StandardError.ReadToEnd() | Out-Null
    $process.WaitForExit()

    if ($process.ExitCode -ne 0) {
        return $null
    }
    return $stdout
}

function Get-SecretValue {
    param($Spec)

    if (-not $Spec.name -or -not (Test-EnvName $Spec.name)) {
        Write-Host "  [SKIP] invalid environment variable name: $($Spec.name)" -ForegroundColor Yellow
        return $null
    }

    if (-not $Spec.bw_item -or -not $Spec.bw_field) {
        Write-Host "  [SKIP] $($Spec.name) (missing bw_item or bw_field)" -ForegroundColor Yellow
        return $null
    }

    $value = $null
    if ($env:BW_SESSION) {
        Write-Host "  [GET]  $($Spec.name) <- $($Spec.bw_item).$($Spec.bw_field)" -ForegroundColor DarkGray
        $itemJson = Invoke-BwGetItem $Spec.bw_item
        if ($itemJson) {
            $item = $itemJson | ConvertFrom-Json
            $value = switch ($Spec.bw_field) {
                "login.password" { $item.login.password; break }
                "password"       { $item.login.password; break }
                "notes"          { $item.notes; break }
                default {
                    @(
                        $item.fields |
                        Where-Object { $_.name -eq $Spec.bw_field } |
                        Select-Object -First 1 -ExpandProperty value
                    )[0]
                }
            }
            if ([string]::IsNullOrWhiteSpace($value)) {
                Write-Host "  [MISS] $($Spec.name) (field '$($Spec.bw_field)' missing or empty in '$($Spec.bw_item)')" -ForegroundColor Yellow
            }
        } else {
            Write-Host "  [MISS] $($Spec.name) (Bitwarden item '$($Spec.bw_item)' not found)" -ForegroundColor Yellow
        }
    } else {
        Write-Host "  [MISS] $($Spec.name) (BW_SESSION is not set)" -ForegroundColor Yellow
    }
    if ([string]::IsNullOrWhiteSpace($value)) {
        Write-Host "  [MISS] $($Spec.name) (no value)" -ForegroundColor Yellow
        return $null
    }
    return [string]$value
}

function Set-UserEnv {
    param([string]$Name, [string]$Value)

    if ([string]::IsNullOrWhiteSpace($Value)) {
        return $false
    }

    [System.Environment]::SetEnvironmentVariable($Name, $Value, "User")
    [System.Environment]::SetEnvironmentVariable($Name, $Value, "Process")
    return $true
}

function Remove-EmptyUserEnv {
    param([string]$Name)

    if ([System.Environment]::GetEnvironmentVariable($Name, "User") -eq "") {
        [System.Environment]::SetEnvironmentVariable($Name, $null, "User")
        Write-Host "  [CLEAN] $Name (removed empty User env)" -ForegroundColor Yellow
    }
}

function Select-SecretSpecs {
    param($TerminalSpecs, $GlobalSpecs)

    $entries = @()
    foreach ($spec in $TerminalSpecs) {
        $entries += [pscustomobject]@{ Type = "terminal"; Spec = $spec; Label = ("[terminal] {0} <- {1}.{2}" -f $spec.name, $spec.bw_item, $spec.bw_field) }
    }
    foreach ($spec in $GlobalSpecs) {
        $entries += [pscustomobject]@{ Type = "global"; Spec = $spec; Label = ("[global]   {0} <- {1}.{2}" -f $spec.name, $spec.bw_item, $spec.bw_field) }
    }

    if ($entries.Count -eq 0) {
        return @()
    }

    if ($env:SECRETS_SELECT_ALL) {
        Write-Host "  [WARN] SECRETS_SELECT_ALL is set - processing all $($entries.Count) secrets" -ForegroundColor Yellow
        return $entries
    }

    if (-not (Get-Command fzf -ErrorAction SilentlyContinue)) {
        Write-Host "  [WARN] fzf not found - processing all $($entries.Count) secrets" -ForegroundColor Yellow
        return $entries
    }

    $selectedLabels = @($entries.Label | fzf --multi --bind="ctrl-a:toggle-all,tab:toggle" --prompt="  Secrets> " --header="Select secrets to refresh (Ctrl+A select all, Tab toggle, Enter confirm)")
    if ($selectedLabels.Count -eq 0) {
        Write-Host "  [SKIP] no secrets selected" -ForegroundColor DarkGray
        return @()
    }

    return @($entries | Where-Object { $selectedLabels -contains $_.Label })
}

function Set-GlobalEnvs {
    param($Specs)

    foreach ($spec in $Specs) {
        Write-Host "  [PROC] $($spec.name)" -ForegroundColor DarkGray
        try {
            $value = Get-SecretValue $spec
            if (Set-UserEnv $spec.name $value) {
                Write-Host "  [OK]   $($spec.name)" -ForegroundColor Green
            } else {
                Remove-EmptyUserEnv $spec.name
                Write-Host "  [SKIP] $($spec.name)" -ForegroundColor DarkGray
            }
        } catch {
            Write-Host "  [FAIL] $($spec.name) - $($_.Exception.Message)" -ForegroundColor Red
        }
    }
}

if (-not (Test-Path $configFile)) {
    Write-Host "  [SKIP] secrets.json not found" -ForegroundColor DarkGray
    return
}

$config = Get-Content $configFile -Raw | ConvertFrom-Json
$terminalEnvSpecs = @($config.terminal_envs | Where-Object { $_ })
$globalEnvSpecs = @($config.global_envs | Where-Object { $_ })
$selectedSpecs = Select-SecretSpecs $terminalEnvSpecs $globalEnvSpecs
if ($selectedSpecs.Count -eq 0) {
    return
}
$terminalEnvSpecs = @($selectedSpecs | Where-Object { $_.Type -eq "terminal" } | ForEach-Object { $_.Spec })
$globalEnvSpecs = @($selectedSpecs | Where-Object { $_.Type -eq "global" } | ForEach-Object { $_.Spec })
$lines = @("# API keys -- generated by chezmoi from Bitwarden. Do not edit manually.")

Write-Host "  Terminal envs: $($terminalEnvSpecs.Count)" -ForegroundColor Cyan
foreach ($spec in $terminalEnvSpecs) {
    $value = Get-SecretValue $spec
    if ($value) {
        $escapedValue = Escape-PowerShellSingleQuotedString $value
        $lines += "`$env:$($spec.name) = '$escapedValue'"
        Write-Host "  [OK]   $($spec.name)" -ForegroundColor Green
    } else {
        Write-Host "  [SKIP] $($spec.name)" -ForegroundColor DarkGray
    }
}

$lines | Set-Content $outFile -Encoding UTF8
Write-Host "  Secrets written to $outFile" -ForegroundColor Cyan

Write-Host "  Global envs: $($globalEnvSpecs.Count)" -ForegroundColor Cyan
Set-GlobalEnvs $globalEnvSpecs
{{ end -}}
