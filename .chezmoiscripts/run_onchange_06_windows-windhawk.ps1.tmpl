{{ if and (eq .chezmoi.os "windows") .enable_windhawk -}}
# run_onchange_ triggers when any of these change:
{{ range (glob "program_files/windhawk/**") -}}
# {{ . }} {{ include . | sha256sum }}
{{ end -}}
{{ if stat "packages/windows/system/windhawk/settings.reg" -}}
# windhawk/settings.reg {{ include "packages/windows/system/windhawk/settings.reg" | sha256sum }}
{{ end -}}
$chezmoisrc = ("{{ .chezmoi.sourceDir }}").Replace('/', '\')
$pkgDir     = "$chezmoisrc\packages\windows"
$logFile    = "$env:TEMP\chezmoi-windhawk-$(Get-Date -Format 'yyyyMMdd-HHmmss').log"
$tmpScript  = "$env:TEMP\chezmoi-windhawk.ps1"

@"
`$chezmoisrc = "$chezmoisrc"
`$pkgDir     = "$pkgDir"
`$logFile    = "$logFile"
`$ok = 0; `$skip = 0; `$fail = 0

function Log    { param([string]`$pfx, [string]`$msg) Add-Content -Path "`$logFile" -Value "[`$(Get-Date -Format 'HH:mm:ss')] [`$pfx] `$msg" }
function LogOk  { param([string]`$msg) Log "OK"   `$msg; `$script:ok++   }
function LogSkip{ param([string]`$msg) Log "SKIP" `$msg; `$script:skip++ }
function LogFail{ param([string]`$msg) Log "FAIL" `$msg; `$script:fail++ }
function LogSec { param([string]`$msg) Log "--"   "-- `$msg --"           }
function TryRun {
    param([string]`$name, [scriptblock]`$block)
    try   { & `$block; LogOk `$name }
    catch { LogFail "`$name - `$(`$_.Exception.Message)" }
}

LogSec "Windhawk"

if (Test-Path "HKLM:\SOFTWARE\Windhawk") {
    Stop-Process -Name "Windhawk*" -Force -ErrorAction SilentlyContinue

    `$whReg = "`$pkgDir\system\windhawk\settings.reg"
    if (Test-Path `$whReg) {
        reg import "`$whReg" 2>`$null
        if (`$LASTEXITCODE -eq 0) { LogOk "Windhawk registry imported" }
        else                      { LogFail "Windhawk registry import failed (exit `$LASTEXITCODE)" }
    } else {
        LogSkip "Windhawk settings.reg not found"
    }

    `$whPf = "`$chezmoisrc\program_files\windhawk"
    if (Test-Path "`$whPf\userprofile.json") {
        New-Item -ItemType Directory -Force -Path "C:\ProgramData\Windhawk" | Out-Null
        Copy-Item "`$whPf\userprofile.json" "C:\ProgramData\Windhawk\userprofile.json" -Force
        LogOk "Windhawk userprofile.json restored"
    } else {
        LogSkip "Windhawk userprofile.json not found"
    }

    if (Test-Path "`$whPf\ModsSource") {
        New-Item -ItemType Directory -Force -Path "C:\ProgramData\Windhawk\ModsSource" | Out-Null
        Copy-Item "`$whPf\ModsSource\*.wh.cpp" "C:\ProgramData\Windhawk\ModsSource\" -Force
        LogOk "Windhawk ModsSource restored"
    } else {
        LogSkip "Windhawk ModsSource not found"
    }

    foreach (`$arch in @("32", "64")) {
        `$src = "`$whPf\`$arch"
        `$dst = "C:\ProgramData\Windhawk\Engine\Mods\`$arch"
        if (Test-Path `$src) {
            New-Item -ItemType Directory -Force -Path `$dst | Out-Null
            `$dlls = Get-ChildItem "`$src\*.dll" -ErrorAction SilentlyContinue
            `$dlls | ForEach-Object { Copy-Item `$_.FullName -Destination "`$dst\`$(`$_.Name)" -Force }
            LogOk "Windhawk DLLs (`$arch-bit) - `$(`$dlls.Count) installed"
        } else {
            LogSkip "Windhawk DLLs `$arch-bit - source not found"
        }
    }
} else {
    LogSkip "Windhawk - not installed"
}

Log "--" "-- elevated summary: `$ok OK  `$skip skipped  `$fail failed --"
"@ | Set-Content $tmpScript

Write-Host "[windows-windhawk] Requesting elevation..." -ForegroundColor Cyan
Start-Process powershell.exe -Verb RunAs -WindowStyle Hidden -ArgumentList "-NoProfile", "-File", $tmpScript -Wait

if (Test-Path $logFile) {
    foreach ($line in Get-Content $logFile) {
        if     ($line -match '\[OK\]')   { Write-Host $line -ForegroundColor Green  }
        elseif ($line -match '\[SKIP\]') { Write-Host $line -ForegroundColor Yellow }
        elseif ($line -match '\[FAIL\]') { Write-Host $line -ForegroundColor Red    }
        elseif ($line -match '\[--\]')   { Write-Host $line -ForegroundColor Cyan   }
        else                             { Write-Host $line -ForegroundColor Gray   }
    }
    Remove-Item $logFile
} else {
    Write-Warning "windows-windhawk: no output received (UAC cancelled or script failed)"
}
Remove-Item $tmpScript -ErrorAction SilentlyContinue

{{ end -}}
