{{ if eq .chezmoi.os "windows" -}}
$pkgDir = "{{ .chezmoi.sourceDir }}\packages\windows"
$logFile = "$env:TEMP\chezmoi-install-$(Get-Date -Format 'yyyyMMdd-HHmmss').log"
$isAdmin = ([Security.Principal.WindowsPrincipal][Security.Principal.WindowsIdentity]::GetCurrent()).IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator)

# -- Logging helpers -----------------------------------------------------------
function Log {
    param([string]$msg, [string]$color = "White")
    $ts = "[$(Get-Date -Format 'HH:mm:ss')]"
    $line = "$ts $msg"
    Write-Host $line -ForegroundColor $color
    Add-Content -Path $logFile -Value $line
}

function LogOk      { param([string]$msg) Log "  [OK]   $msg" "Green"  }
function LogSkip    { param([string]$msg) Log "  [SKIP] $msg" "Yellow" }
function LogFail    { param([string]$msg) Log "  [FAIL] $msg" "Red"    }
function LogSection { param([string]$msg) Write-Host ""; Add-Content -Path $logFile -Value ""; Log "-- $msg --" "Cyan" }

$summary = @{ ok = 0; skip = 0; fail = 0 }

function TryInstall {
    param([string]$name, [scriptblock]$block)
    try {
        & $block
        if ($LASTEXITCODE -and $LASTEXITCODE -ne 0) { throw "exit code $LASTEXITCODE" }
        LogOk $name
        $summary.ok++
    } catch {
        LogFail "$name - $($_.Exception.Message)"
        $summary.fail++
    }
}

# -- fzf selection helpers -----------------------------------------------------
# Multi-select: TAB=toggle (no cursor move)  CTRL-A=toggle-all  ENTER=confirm  ESC=skip
function Select-WithFzf {
    param(
        [string[]]$Items,
        [string]$Prompt,
        [string]$Header = "TAB=toggle  CTRL-A=toggle-all  ENTER=confirm  ESC=skip"
    )
    if (-not $Items -or $Items.Count -eq 0) { return @() }
    if (-not (Get-Command fzf -ErrorAction SilentlyContinue)) {
        Log "  [WARN] fzf not found - installing all $($Items.Count) items" "Yellow"
        return $Items
    }
    $selected = $Items | fzf --multi --prompt="  $Prompt " --header="$Header" `
        --layout=reverse --border --bind='ctrl-a:toggle-all' --bind='tab:toggle'
    if ($LASTEXITCODE -ne 0) { return @() }
    return @($selected | Where-Object { $_ })
}

# Single-select: ENTER=confirm  ESC=skip
function Select-OneFzf {
    param(
        [string[]]$Items,
        [string]$Prompt,
        [string]$Header = "ENTER=confirm  ESC=skip"
    )
    if (-not $Items -or $Items.Count -eq 0) { return $null }
    if (-not (Get-Command fzf -ErrorAction SilentlyContinue)) { return $Items[0] }
    $selected = $Items | fzf --prompt="  $Prompt " --header="$Header" `
        --layout=reverse --border
    if ($LASTEXITCODE -ne 0) { return $null }
    return $selected
}

Log "Chezmoi install started - log: $logFile" "Cyan"

# == BOOTSTRAP (always runs, no selection) =====================================
LogSection "Bootstrap"

# -- scoop ---------------------------------------------------------------------
if (-not (Get-Command scoop -ErrorAction SilentlyContinue)) {
    TryInstall "Scoop" {
        Set-ExecutionPolicy RemoteSigned -Scope CurrentUser -Force
        iex "& {$(irm get.scoop.sh)} -RunAsAdmin"
    }
    $env:PATH = [System.Environment]::GetEnvironmentVariable('PATH', 'Machine') + ';' +
                [System.Environment]::GetEnvironmentVariable('PATH', 'User')
} else {
    LogSkip "Scoop already installed"
    $summary.skip++
}

# -- fzf (needed for package selection below) ----------------------------------
if (-not (Get-Command fzf -ErrorAction SilentlyContinue)) {
    TryInstall "fzf" { scoop install fzf }
} else {
    LogSkip "fzf already installed"
    $summary.skip++
}

# -- Developer Mode (required for chezmoi symlinks on Windows) -----------------
$devModeKey = "HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\AppModelUnlock"
$devModeVal = (Get-ItemProperty -Path $devModeKey -ErrorAction SilentlyContinue).AllowDevelopmentWithoutDevLicense
if ($devModeVal -eq 1) {
    LogSkip "Developer Mode already enabled"
    $summary.skip++
} else {
    TryInstall "Developer Mode (elevated)" {
        $cmd = 'Set-ItemProperty -Path "HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\AppModelUnlock" -Name "AllowDevelopmentWithoutDevLicense" -Value 1 -Type DWord -Force'
        Start-Process powershell.exe -Verb RunAs -WindowStyle Hidden -ArgumentList "-NoProfile", "-Command", $cmd -Wait
    }
}

# -- Refresh PATH from registry ------------------------------------------------
$env:PATH = [System.Environment]::GetEnvironmentVariable('PATH', 'Machine') + ';' +
            [System.Environment]::GetEnvironmentVariable('PATH', 'User')

# == PACKAGE MANAGER SELECTION =================================================
LogSection "Package selection"

# Build list of available managers
$elevatedPkgs = @(if (Test-Path "$pkgDir\winget\elevated.json") {
    (Get-Content "$pkgDir\winget\elevated.json" | ConvertFrom-Json).Sources |
        ForEach-Object { $_.Packages } | Select-Object -ExpandProperty PackageIdentifier
})

$candidates = [System.Collections.Generic.List[string]]::new()
if (Test-Path "$pkgDir\winget\packages.json")       { $candidates.Add("winget             | required  |  base app installs") }
if ($elevatedPkgs.Count -gt 0)                      { $candidates.Add("winget-elevated    | required  |  apps needing admin") }
if (Test-Path "$pkgDir\scoop\packages.json")        { $candidates.Add("scoop              | required  |  CLI tools and extras") }
if (Test-Path "$pkgDir\node\npm-packages.json")     { $candidates.Add("npm                | personal  |  Node.js global tools") }
if (Test-Path "$pkgDir\node\bun-packages.txt")      { $candidates.Add("bun                | personal  |  Bun global tools") }
if (Test-Path "$pkgDir\uv-tools.txt")               { $candidates.Add("uv                 | personal  |  Python tools") }
if (Test-Path "$pkgDir\bin-packages.txt")           { $candidates.Add("bin                | personal  |  GitHub release binaries") }
if (Test-Path "$pkgDir\cargo\cargo.txt" -or Test-Path "$pkgDir\cargo\cargo-minimal.txt") { $candidates.Add("cargo              | personal  |  Rust crates (crates.io + git)") }
$candidates.Add(                                       "powershell-modules | required  |  Terminal-Icons and other PS modules")

# Required managers are auto-selected; personal ones go through fzf
$requiredManagers  = @($candidates | Where-Object { $_ -match '\|\s*required\s*\|' } |
    ForEach-Object { ($_ -split '\s*\|')[0].Trim() })
$personalCandidates = @($candidates | Where-Object { $_ -notmatch '\|\s*required\s*\|' })

if ($requiredManagers.Count -gt 0) {
    Log "  Required (auto-selected): $($requiredManagers -join ', ')" "Cyan"
}

$selectedOptional = @()
if ($personalCandidates.Count -gt 0) {
    $selectedOptional = Select-WithFzf $personalCandidates "Optional package managers>" `
        "TAB=toggle  CTRL-A=all  ENTER=confirm  ESC=skip optional"
    $selectedOptional = @($selectedOptional | ForEach-Object { ($_ -split '\s*\|')[0].Trim() })
}

$selectedManagers = $requiredManagers + $selectedOptional

if ($selectedManagers.Count -eq 0) {
    Log "No managers selected - skipping all package installs" "Yellow"
} else {
    Log "  Selected: $($selectedManagers -join ', ')" "Cyan"
}

# == PACKAGE CONFIGURATION (all interactive prompts upfront) ===================
LogSection "Package configuration"

# -- winget --------------------------------------------------------------------
$wingetFile        = $null
$selectedWingetIds = @()
if ($selectedManagers -contains "winget") {
    $wingetProfiles = @()
    if (Test-Path "$pkgDir\winget\minimal.json")  { $wingetProfiles += "minimal  |  necessary packages to replicate the setup (recommended)" }
    if (Test-Path "$pkgDir\winget\packages.json") { $wingetProfiles += "full     |  personal complete setup" }

    $profileChoice = Select-OneFzf $wingetProfiles "winget profile>"
    $profileKey    = if ($profileChoice) { ($profileChoice -split '\s*\|')[0].Trim() } else { "full" }
    $wingetFile    = if ($profileKey -eq "minimal") { "$pkgDir\winget\minimal.json" } else { "$pkgDir\winget\packages.json" }
    Log "  winget profile: $(Split-Path $wingetFile -Leaf)" "Cyan"

    $wingetJson    = Get-Content $wingetFile | ConvertFrom-Json
    $allWingetIds  = @($wingetJson.Sources | ForEach-Object { $_.Packages } |
        Select-Object -ExpandProperty PackageIdentifier | Sort-Object)
    $selectedWingetIds = Select-WithFzf $allWingetIds "winget>"
}

# -- winget (elevated) ---------------------------------------------------------
$selectedElevatedPkgs = @()
if ($selectedManagers -contains "winget-elevated") {
    $selectedElevatedPkgs = Select-WithFzf $elevatedPkgs "winget-elevated>"
}

# -- scoop ---------------------------------------------------------------------
$scoopFile          = $null
$scoopData          = $null
$selectedScoopNames = @()
if ($selectedManagers -contains "scoop") {
    $scoopProfiles = @()
    if (Test-Path "$pkgDir\scoop\minimal.json")  { $scoopProfiles += "minimal  |  essential tools to bootstrap the setup" }
    if (Test-Path "$pkgDir\scoop\packages.json") { $scoopProfiles += "full     |  personal complete setup" }

    $scoopProfileChoice = Select-OneFzf $scoopProfiles "scoop profile>"
    $scoopProfileKey    = if ($scoopProfileChoice) { ($scoopProfileChoice -split '\s*\|')[0].Trim() } else { "full" }
    $scoopFile          = if ($scoopProfileKey -eq "minimal") { "$pkgDir\scoop\minimal.json" } else { "$pkgDir\scoop\packages.json" }
    Log "  scoop profile: $(Split-Path $scoopFile -Leaf)" "Cyan"

    $scoopData          = Get-Content $scoopFile | ConvertFrom-Json
    $allScoopNames      = @($scoopData.apps | Select-Object -ExpandProperty Name | Sort-Object)
    $selectedScoopNames = Select-WithFzf $allScoopNames "scoop>"
}

# -- npm -----------------------------------------------------------------------
$selectedNpmPkgs = @()
if ($selectedManagers -contains "npm") {
    $npm = Get-Content "$pkgDir\node\npm-packages.json" | ConvertFrom-Json
    if ($npm.dependencies) {
        $allNpmPkgs      = @($npm.dependencies.PSObject.Properties |
            ForEach-Object { "$($_.Name)@$($_.Value)" } | Sort-Object)
        $selectedNpmPkgs = Select-WithFzf $allNpmPkgs "npm>"
    }
}

# -- bun -----------------------------------------------------------------------
$selectedBunPkgs = @()
if ($selectedManagers -contains "bun") {
    $bunPkgs = @(Get-Content "$pkgDir\node\bun-packages.txt" | Where-Object { $_.Trim() -ne "" } | Sort-Object)
    if ($bunPkgs) { $selectedBunPkgs = Select-WithFzf $bunPkgs "bun>" }
}

# -- uv tools ------------------------------------------------------------------
$selectedUvTools = @()
if ($selectedManagers -contains "uv") {
    $uvTools = @(Get-Content "$pkgDir\uv-tools.txt" | Where-Object { $_.Trim() -ne "" } | Sort-Object)
    if ($uvTools) { $selectedUvTools = Select-WithFzf $uvTools "uv>" }
}

# -- PowerShell modules --------------------------------------------------------
$selectedPsModules = @()
if ($selectedManagers -contains "powershell-modules") {
    $allPsModules      = @("Terminal-Icons")
    $selectedPsModules = Select-WithFzf $allPsModules "powershell-modules>"
}

# -- bin (GitHub release binaries) ---------------------------------------------
$selectedBinUrls = @()
if ($selectedManagers -contains "bin") {
    $binPkgs = @(Get-Content "$pkgDir\bin-packages.txt" | Where-Object { $_.Trim() -ne "" })
    if ($binPkgs) {
        $binItems = $binPkgs | ForEach-Object {
            [PSCustomObject]@{
                Label = ($_ -replace 'https://github.com/', '' -replace '/releases/.*', '')
                Url   = $_
            }
        }
        $selectedBinLabels = Select-WithFzf ($binItems.Label | Sort-Object) "bin>"
        $selectedBinUrls   = $binItems |
            Where-Object { $selectedBinLabels -contains $_.Label } |
            Select-Object -ExpandProperty Url
    }
}

# -- cargo (crates.io + git) ---------------------------------------------------
$cargoFile         = $null
$selectedCargoEntries = @()
if ($selectedManagers -contains "cargo") {
    $cargoProfiles = @()
    if (Test-Path "$pkgDir\cargo\cargo-minimal.txt") { $cargoProfiles += "minimal  |  curated subset" }
    if (Test-Path "$pkgDir\cargo\cargo.txt")         { $cargoProfiles += "full     |  all packages" }

    $cargoProfileChoice = Select-OneFzf $cargoProfiles "cargo profile>"
    $cargoProfileKey    = if ($cargoProfileChoice) { ($cargoProfileChoice -split '\s*\|')[0].Trim() } else { "minimal" }
    $cargoFile          = if ($cargoProfileKey -eq "minimal") {
        "$pkgDir\cargo\cargo-minimal.txt"
    } else {
        "$pkgDir\cargo\cargo.txt"
    }
    Log "  cargo profile: $(Split-Path $cargoFile -Leaf)" "Cyan"

    $cargoEntries = @(Get-Content $cargoFile |
        Where-Object { $_.Trim() -ne "" -and -not $_.TrimStart().StartsWith('#') })
    if ($cargoEntries) { $selectedCargoEntries = Select-WithFzf ($cargoEntries | Sort-Object) "cargo>" }
}

# == PACKAGE INSTALLS ==========================================================

# -- winget --------------------------------------------------------------------
if ($selectedManagers -contains "winget") {
    LogSection "winget"
    foreach ($id in $selectedWingetIds) {
        $installed = winget list --id $id --accept-source-agreements 2>$null | Select-String $id
        if ($installed) {
            LogSkip "winget: $id already installed"
            $summary.skip++
        } else {
            TryInstall "winget: $id" {
                winget install --id $id --accept-package-agreements --accept-source-agreements -e
            }
        }
    }
}

# -- winget (elevated) ---------------------------------------------------------
if ($selectedManagers -contains "winget-elevated") {
    LogSection "winget (elevated)"
    foreach ($pkg in $selectedElevatedPkgs) {
        $installed = winget list --id $pkg --accept-source-agreements 2>$null | Select-String $pkg
        if ($installed) {
            LogSkip "winget: $pkg already installed"
            $summary.skip++
        } else {
            $tmpScript = "$env:TEMP\winget-elevated-$pkg.ps1"
@"
winget install --id $pkg --accept-package-agreements --accept-source-agreements -e
"@ | Set-Content $tmpScript
            Start-Process powershell.exe -Verb RunAs -WindowStyle Hidden -ArgumentList "-NoProfile", "-File", $tmpScript -Wait
            Remove-Item $tmpScript -ErrorAction SilentlyContinue
            # Start-Process does not propagate exit codes — verify install result directly
            $nowInstalled = winget list --id $pkg --accept-source-agreements 2>$null | Select-String $pkg
            if ($nowInstalled) {
                LogOk "winget: $pkg (elevated)"
                $summary.ok++
            } else {
                LogFail "winget: $pkg (elevated) - not found after install attempt"
                $summary.fail++
            }
        }
    }
}

# -- scoop ---------------------------------------------------------------------
if ($selectedManagers -contains "scoop") {
    LogSection "scoop"

    # Always add all buckets (apps may depend on them regardless of selection)
    $scoopBuckets = scoop bucket list | Select-Object -ExpandProperty Name 2>$null
    foreach ($bucket in $scoopData.buckets) {
        if ($scoopBuckets -contains $bucket.Name) {
            LogSkip "bucket: $($bucket.Name) already added"
            $summary.skip++
        } else {
            TryInstall "bucket: $($bucket.Name)" {
                scoop bucket add $bucket.Name $bucket.Source
            }
        }
    }

    $scoopInstalled = scoop list 2>$null | Select-Object -ExpandProperty Name
    foreach ($name in $selectedScoopNames) {
        $app = $scoopData.apps | Where-Object { $_.Name -eq $name }
        if ($scoopInstalled -contains $name) {
            LogSkip "scoop: $name already installed"
            $summary.skip++
        } else {
            TryInstall "scoop: $name" {
                scoop install "$($app.Source)/$($app.Name)"
            }
        }
    }

    # Refresh PATH so newly installed tools (e.g. mingw dlltool) are available
    # for subsequent steps like cargo-git compilation
    $env:PATH = [System.Environment]::GetEnvironmentVariable('PATH', 'Machine') + ';' +
                [System.Environment]::GetEnvironmentVariable('PATH', 'User')
}

# -- npm -----------------------------------------------------------------------
if ($selectedManagers -contains "npm") {
    LogSection "npm"
    if (-not (Get-Command node -ErrorAction SilentlyContinue)) {
        TryInstall "Node.js" {
            scoop install nodejs-lts
        }
        $env:PATH = [System.Environment]::GetEnvironmentVariable('PATH', 'Machine') + ';' +
                    [System.Environment]::GetEnvironmentVariable('PATH', 'User')
    } else {
        LogSkip "Node.js already installed"
        $summary.skip++
    }
    foreach ($pkg in $selectedNpmPkgs) {
        TryInstall "npm: $pkg" { npm install -g $pkg }
    }
}

# -- bun -----------------------------------------------------------------------
if ($selectedManagers -contains "bun") {
    LogSection "bun"
    if (-not (Get-Command bun -ErrorAction SilentlyContinue)) {
        TryInstall "Bun" {
            scoop install bun
        }
        $env:PATH = [System.Environment]::GetEnvironmentVariable('PATH', 'Machine') + ';' +
                    [System.Environment]::GetEnvironmentVariable('PATH', 'User')
    } else {
        LogSkip "Bun already installed"
        $summary.skip++
    }
    $bunInstalled = bun pm ls -g 2>$null
    foreach ($pkg in $selectedBunPkgs) {
        $pkgName = ($pkg -split '@')[0]
        if ($bunInstalled -match [regex]::Escape($pkgName)) {
            LogSkip "bun: $pkg already installed"
            $summary.skip++
        } else {
            TryInstall "bun: $pkg" { bun add -g $pkg }
        }
    }
}

# -- uv tools ------------------------------------------------------------------
if ($selectedManagers -contains "uv") {
    LogSection "uv"
    if (-not (Get-Command uv -ErrorAction SilentlyContinue)) {
        TryInstall "uv" {
            scoop install uv
        }
        $env:PATH = [System.Environment]::GetEnvironmentVariable('PATH', 'Machine') + ';' +
                    [System.Environment]::GetEnvironmentVariable('PATH', 'User')
    } else {
        LogSkip "uv already installed"
        $summary.skip++
    }
    $uvInstalled = uv tool list 2>$null
    foreach ($tool in $selectedUvTools) {
        if ($uvInstalled -match [regex]::Escape($tool)) {
            LogSkip "uv: $tool already installed"
            $summary.skip++
        } else {
            TryInstall "uv: $tool" { uv tool install $tool }
        }
    }
}

# -- PowerShell modules --------------------------------------------------------
if ($selectedManagers -contains "powershell-modules") {
    LogSection "PowerShell modules"
    foreach ($mod in $selectedPsModules) {
        $isInstalled = pwsh -NoProfile -Command "if (Get-Module -ListAvailable -Name '$mod') { 'yes' } else { 'no' }"
        if ($isInstalled -eq "yes") {
            LogSkip "$mod already installed"
            $summary.skip++
        } else {
            TryInstall "PSModule: $mod" {
                pwsh -NoProfile -Command "Install-Module '$mod' -Scope CurrentUser -Force -SkipPublisherCheck"
            }
        }
    }
}

# -- bin (GitHub release binaries) ---------------------------------------------
if ($selectedManagers -contains "bin") {
    LogSection "bin"

    # Ensure scoop extras bucket is available (bin is in extras)
    if (-not (scoop bucket list | Select-Object -ExpandProperty Name | Where-Object { $_ -eq 'extras' })) {
        TryInstall "scoop bucket extras" { scoop bucket add extras }
    } else {
        LogSkip "scoop bucket extras already added"
        $summary.skip++
    }
    if (-not (Get-Command bin -ErrorAction SilentlyContinue)) {
        TryInstall "bin" { scoop install extras/bin }
        $env:PATH = [System.Environment]::GetEnvironmentVariable('PATH', 'Machine') + ';' +
                    [System.Environment]::GetEnvironmentVariable('PATH', 'User')
    } else {
        LogSkip "bin already installed"
        $summary.skip++
    }

    if ($selectedBinUrls) {
        # Setup ~/.bin dir and PATH
        $binDir = "$env:USERPROFILE\.bin"
        New-Item -ItemType Directory -Force -Path $binDir | Out-Null
        $userPath = [System.Environment]::GetEnvironmentVariable('PATH', 'User')
        if ($userPath -notmatch [regex]::Escape($binDir)) {
            [System.Environment]::SetEnvironmentVariable('PATH', "$userPath;$binDir", 'User')
        }

        # Ensure bin config has correct default_path
        $binConfigDir  = "$env:USERPROFILE\.config\bin"
        $binConfigFile = "$binConfigDir\config.json"
        New-Item -ItemType Directory -Force -Path $binConfigDir | Out-Null
        if (Test-Path $binConfigFile) {
            $binCfg = Get-Content $binConfigFile -Raw | ConvertFrom-Json
            $binCfg | Add-Member -MemberType NoteProperty -Name default_path -Value "$binDir/" -Force
            $binCfg | ConvertTo-Json -Depth 5 | Set-Content $binConfigFile
        } else {
            [pscustomobject]@{ default_path = "$binDir/" } | ConvertTo-Json | Set-Content $binConfigFile
        }

        $binInstalled = (bin list 2>$null) -join "`n"
        Push-Location $binDir
        foreach ($url in $selectedBinUrls) {
            $baseUrl = ($url -split '/releases/')[0]
            if ($binInstalled -match [regex]::Escape($baseUrl)) {
                LogSkip "bin: $url already installed"
                $summary.skip++
            } else {
                TryInstall "bin: $url" { bin install $url }
            }
        }
        Pop-Location
    }
}

# -- Refresh PATH (picks up rustup/cargo installed during winget) --------------
$env:PATH = [System.Environment]::GetEnvironmentVariable('PATH', 'Machine') + ';' +
            [System.Environment]::GetEnvironmentVariable('PATH', 'User')

# -- Rust GNU toolchain --------------------------------------------------------
if (Get-Command rustup -ErrorAction SilentlyContinue) {
    $gnuToolchain = "stable-x86_64-pc-windows-gnu"
    $installedToolchains = rustup toolchain list 2>$null
    if ($installedToolchains -match [regex]::Escape($gnuToolchain)) {
        LogSkip "Rust toolchain $gnuToolchain already configured"
        $summary.skip++
    } else {
        TryInstall "Rust toolchain: $gnuToolchain" {
            rustup toolchain install $gnuToolchain
            rustup default $gnuToolchain
            rustup component add rust-analyzer clippy rustfmt
        }
    }
} else {
    Log "  [INFO] rustup not found - skipping Rust toolchain setup (install rustup first)" "Yellow"
}

# -- cargo (crates.io + git) --------------------------------------------------
if ($selectedManagers -contains "cargo") {
    LogSection "cargo"
    if (-not (Get-Command cargo -ErrorAction SilentlyContinue)) {
        Log "  [WARN] cargo not found - skipping (install rustup first)" "Yellow"
    } else {
        $cargoInstalled = cargo install --list 2>$null
        foreach ($entry in $selectedCargoEntries) {
            if ($entry -match '^https://') {
                $baseUrl = ($entry -split '\s+')[0] -replace '\.git$', ''
                if ($cargoInstalled -match [regex]::Escape($baseUrl)) {
                    LogSkip "cargo: $baseUrl already installed"
                    $summary.skip++
                } else {
                    Log "  [....] cargo: $entry" "Cyan"
                    try {
                        Invoke-Expression "cargo install --git $entry"
                        if ($LASTEXITCODE -ne 0) { throw "exit code $LASTEXITCODE" }
                        LogOk "cargo: $baseUrl"
                        $summary.ok++
                    } catch {
                        LogFail "cargo: $entry - $($_.Exception.Message)"
                        $summary.fail++
                    }
                }
            } else {
                if ($cargoInstalled -match "^$([regex]::Escape($entry))\s") {
                    LogSkip "cargo: $entry already installed"
                    $summary.skip++
                } else {
                    TryInstall "cargo: $entry" { Invoke-Expression "cargo install $entry" }
                }
            }
        }
    }
}

# -- Summary -------------------------------------------------------------------
Write-Host ""; Add-Content -Path $logFile -Value ""
Log "======================================" "Cyan"
Log "  [OK]   OK:      $($summary.ok)"   "Green"
Log "  [SKIP] Skipped: $($summary.skip)" "Yellow"
Log "  [FAIL] Failed:  $($summary.fail)"  $(if ($summary.fail -gt 0) { "Red" } else { "White" })
Log "  [LOG]  Log:     $logFile"          "Cyan"
Log "======================================" "Cyan"

{{ end -}}
