{{ if eq .chezmoi.os "windows" -}}
$pkgDir = ("{{ .chezmoi.sourceDir }}").Replace('/', '\') + "\packages\windows"

function Start-IfNotRunning {
    param([string]$Name, [string]$Path, [string]$Args = "")
    $expanded = [System.Environment]::ExpandEnvironmentVariables($Path)
    if (-not (Test-Path $expanded)) {
        Write-Host "  [SKIP] $Name - not found" -ForegroundColor Yellow
        return
    }
    $procName = [System.IO.Path]::GetFileNameWithoutExtension($expanded)
    if (Get-Process -Name $procName -ErrorAction SilentlyContinue) {
        Write-Host "  [SKIP] $Name - already running" -ForegroundColor DarkGray
        return
    }
    if ($Args) {
        Start-Process $expanded -ArgumentList $Args
    } else {
        Start-Process $expanded
    }
    Write-Host "  [OK]   $Name" -ForegroundColor Green
}

Write-Host "[startup] Starting apps..." -ForegroundColor Cyan

# -- Registry startup apps (from startup.json) ---------------------------------
if (Test-Path "$pkgDir\system\startup.json") {
    $startup = Get-Content "$pkgDir\system\startup.json" | ConvertFrom-Json
    foreach ($entry in $startup.registry) {
        $argsVal = if ($entry.args) { $entry.args } else { "" }
        Start-IfNotRunning $entry.name $entry.path $argsVal
    }
}

# -- Windhawk (not in startup registry) ----------------------------------------
$whInstall = (Get-ItemProperty "HKLM:\SOFTWARE\Windhawk" -ErrorAction SilentlyContinue).InstallPath
if (-not $whInstall) { $whInstall = "C:\Program Files\Windhawk" }
Start-IfNotRunning "Windhawk" (Join-Path $whInstall "Windhawk.exe")

# -- Mica For Everyone (MSIX) --------------------------------------------------
$micaPkg = Get-AppxPackage -Name "*MicaForEveryone*" -ErrorAction SilentlyContinue
if ($micaPkg) {
    $micaExe = Get-ChildItem "$env:LOCALAPPDATA\Microsoft\WindowsApps" `
        -Filter "*MicaForEveryone*.exe" -ErrorAction SilentlyContinue | Select-Object -First 1
    if ($micaExe) {
        Start-IfNotRunning "MicaForEveryone" $micaExe.FullName
    }
} else {
    Write-Host "  [SKIP] MicaForEveryone - not installed" -ForegroundColor Yellow
}

Write-Host "[startup] Done." -ForegroundColor Cyan

{{ end -}}
