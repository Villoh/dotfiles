{{ if and (eq .chezmoi.os "windows") .enable_secrets -}}
$secretsDir = "$env:USERPROFILE\Documents\PowerShell\Secrets"
$outFile    = "$secretsDir\api-keys.ps1"

New-Item -ItemType Directory -Force -Path $secretsDir | Out-Null

function Get-Secret {
    param([string]$BwItem, [string]$BwField, [string]$Label)
    $value = $null
    if ($env:BW_SESSION) {
        $value = (bw get item $BwItem 2>$null | ConvertFrom-Json).fields |
            Where-Object { $_.name -eq $BwField } |
            Select-Object -ExpandProperty value
    }
    if (-not $value) {
        Write-Host "  $Label (BW unavailable, enter manually -- leave empty to skip): " -NoNewline
        $value = [Console]::ReadLine()
    }
    return $value
}

$lines = @("# API keys -- generated by chezmoi from Bitwarden. Do not edit manually.")

# FIGMA_API_KEY
$figmaKey = Get-Secret "Figma" "token" "FIGMA_API_KEY"
if ($figmaKey) {
    $lines += "`$env:FIGMA_API_KEY = `"$figmaKey`""
    Write-Host "  [OK]   FIGMA_API_KEY" -ForegroundColor Green
} else {
    Write-Host "  [SKIP] FIGMA_API_KEY" -ForegroundColor DarkGray
}

$lines | Set-Content $outFile -Encoding UTF8
Write-Host "  Secrets written to $outFile" -ForegroundColor Cyan

# YASB_GITHUB_TOKEN — set as persistent User environment variable
$githubToken = Get-Secret "GitHub" "yasb-token" "YASB_GITHUB_TOKEN"
if ($githubToken) {
    [System.Environment]::SetEnvironmentVariable("YASB_GITHUB_TOKEN", $githubToken, "User")
    Write-Host "  [OK]   YASB_GITHUB_TOKEN" -ForegroundColor Green
} else {
    Write-Host "  [SKIP] YASB_GITHUB_TOKEN" -ForegroundColor DarkGray
}
{{ end -}}
