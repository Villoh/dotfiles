{{ if eq .chezmoi.os "windows" -}}
$config = "$env:USERPROFILE\.config"

# btop: scoop/persist/btop/btop.conf -> ~/.config/btop/btop.conf
$src = "$config\btop\btop.conf"
$dst = "$env:USERPROFILE\scoop\persist\btop\btop.conf"
if (Test-Path $dst) { Remove-Item $dst -Force }
cmd /c mklink "$dst" "$src"

# zed: AppData/Roaming/Zed -> ~/.config/zed  (junction)
$src = "$config\zed"
$dst = "$env:APPDATA\Zed"
if (Test-Path $dst) { Remove-Item $dst -Recurse -Force }
cmd /c mklink /J "$dst" "$src"

# yazi: AppData/Roaming/yazi/config -> ~/.config/yazi  (junction)
$src = "$config\yazi"
$dst = "$env:APPDATA\yazi\config"
New-Item -ItemType Directory -Force -Path "$env:APPDATA\yazi" | Out-Null
if (Test-Path $dst) { Remove-Item $dst -Recurse -Force }
cmd /c mklink /J "$dst" "$src"

# vencord: AppData/Roaming/Vencord/settings -> chezmoi source vesktop/settings  (junction)
$src = ("{{ .chezmoi.sourceDir }}\dot_config\vesktop\settings").Replace('/', '\')
$dst = "$env:APPDATA\Vencord\settings"
New-Item -ItemType Directory -Force -Path "$env:APPDATA\Vencord" | Out-Null
if (Test-Path $dst) { Remove-Item $dst -Recurse -Force }
cmd /c mklink /J "$dst" "$src"
{{ end -}}
