{{ if eq .chezmoi.os "windows" -}}
$pkgDir = "{{ .chezmoi.sourceDir }}\packages\windows"
$logFile = "$env:TEMP\chezmoi-install-$(Get-Date -Format 'yyyyMMdd-HHmmss').log"

# ── Logging helpers ────────────────────────────────────────────────────────────
function Log {
    param([string]$msg, [string]$color = "White")
    $ts = "[$(Get-Date -Format 'HH:mm:ss')]"
    $line = "$ts $msg"
    Write-Host $line -ForegroundColor $color
    Add-Content -Path $logFile -Value $line
}

function LogOk    { param([string]$msg) Log "  ✅ $msg" "Green"  }
function LogSkip  { param([string]$msg) Log "  ⚠️  $msg" "Yellow" }
function LogFail  { param([string]$msg) Log "  ❌ $msg" "Red"    }
function LogSection { param([string]$msg) Log "`n── $msg ──" "Cyan" }

$summary = @{ ok = 0; skip = 0; fail = 0 }

function TryInstall {
    param([string]$name, [scriptblock]$block)
    try {
        & $block
        LogOk $name
        $summary.ok++
    } catch {
        LogFail "$name — $($_.Exception.Message)"
        $summary.fail++
    }
}

Log "Chezmoi install started — log: $logFile" "Cyan"

# ── scoop (bootstrap) ─────────────────────────────────────────────────────────
LogSection "Bootstrap"
if (-not (Get-Command scoop -ErrorAction SilentlyContinue)) {
    TryInstall "Scoop" {
        Set-ExecutionPolicy RemoteSigned -Scope CurrentUser -Force
        irm get.scoop.sh | iex
        $env:PATH = "$env:USERPROFILE\scoop\shims;$env:PATH"
    }
} else {
    LogSkip "Scoop already installed"
    $summary.skip++
}

# ── chocolatey (bootstrap) ────────────────────────────────────────────────────
if (-not (Get-Command choco -ErrorAction SilentlyContinue)) {
    TryInstall "Chocolatey" {
        Set-ExecutionPolicy Bypass -Scope Process -Force
        [System.Net.ServicePointManager]::SecurityProtocol = [System.Net.ServicePointManager]::SecurityProtocol -bor 3072
        iex ((New-Object System.Net.WebClient).DownloadString('https://community.chocolatey.org/install.ps1'))
        $env:PATH = "$env:ALLUSERSPROFILE\chocolatey\bin;$env:PATH"
    }
} else {
    LogSkip "Chocolatey already installed"
    $summary.skip++
}

# ── winget ────────────────────────────────────────────────────────────────────
if (Test-Path "$pkgDir\winget-packages.json") {
    LogSection "winget"
    TryInstall "winget packages" {
        winget import --accept-package-agreements --accept-source-agreements "$pkgDir\winget-packages.json"
    }
}

# ── scoop ─────────────────────────────────────────────────────────────────────
if (Test-Path "$pkgDir\scoop-packages.json") {
    LogSection "scoop"
    $scoop = Get-Content "$pkgDir\scoop-packages.json" | ConvertFrom-Json

    foreach ($bucket in $scoop.buckets) {
        TryInstall "bucket: $($bucket.Name)" {
            scoop bucket add $bucket.Name $bucket.Source 2>$null
        }
    }
    foreach ($app in $scoop.apps) {
        TryInstall "scoop: $($app.Name)" {
            scoop install "$($app.Source)/$($app.Name)"
        }
    }
}

# ── chocolatey ────────────────────────────────────────────────────────────────
if (Test-Path "$pkgDir\chocolatey-packages.config") {
    LogSection "chocolatey"
    TryInstall "choco packages" {
        choco install "$pkgDir\chocolatey-packages.config" -y
    }
}

# ── npm ───────────────────────────────────────────────────────────────────────
if (Test-Path "$pkgDir\npm-packages.json") {
    $npm = Get-Content "$pkgDir\npm-packages.json" | ConvertFrom-Json
    if ($npm.dependencies) {
        LogSection "npm"
        foreach ($pkg in $npm.dependencies.PSObject.Properties) {
            TryInstall "npm: $($pkg.Name)" {
                npm install -g "$($pkg.Name)@$($pkg.Value)"
            }
        }
    }
}

# ── bun ───────────────────────────────────────────────────────────────────────
if (Test-Path "$pkgDir\bun-packages.txt") {
    $bunPkgs = Get-Content "$pkgDir\bun-packages.txt" | Where-Object { $_.Trim() -ne "" }
    if ($bunPkgs) {
        LogSection "bun"
        foreach ($pkg in $bunPkgs) {
            TryInstall "bun: $pkg" {
                bun add -g $pkg
            }
        }
    }
}

# ── uv tools ──────────────────────────────────────────────────────────────────
if (Test-Path "$pkgDir\uv-tools.txt") {
    $uvTools = Get-Content "$pkgDir\uv-tools.txt" | Where-Object { $_.Trim() -ne "" }
    if ($uvTools) {
        LogSection "uv"
        foreach ($tool in $uvTools) {
            TryInstall "uv: $tool" {
                uv tool install $tool
            }
        }
    }
}

# ── PowerShell modules ────────────────────────────────────────────────────────
LogSection "PowerShell modules"
@("Terminal-Icons") | ForEach-Object {
    $mod = $_
    if (Get-Module -ListAvailable -Name $mod) {
        LogSkip "$mod already installed"
        $summary.skip++
    } else {
        TryInstall "PSModule: $mod" {
            Install-Module $mod -Scope CurrentUser -Force -SkipPublisherCheck
        }
    }
}

# ── bin (GitHub release binaries) ─────────────────────────────────────────────
if (Test-Path "$pkgDir\bin-packages.txt") {
    $binPkgs = Get-Content "$pkgDir\bin-packages.txt" | Where-Object { $_.Trim() -ne "" }
    if ($binPkgs) {
        LogSection "bin"
        foreach ($url in $binPkgs) {
            TryInstall "bin: $url" {
                bin install $url
            }
        }
    }
}

# ── Summary ───────────────────────────────────────────────────────────────────
Log "`n══════════════════════════════════════" "Cyan"
Log "  ✅ OK:      $($summary.ok)"   "Green"
Log "  ⚠️  Skipped: $($summary.skip)" "Yellow"
Log "  ❌ Failed:  $($summary.fail)"  $(if ($summary.fail -gt 0) { "Red" } else { "White" })
Log "  📄 Log:     $logFile"          "Cyan"
Log "══════════════════════════════════════" "Cyan"

Read-Host "`nPress Enter to exit"
{{ end -}}
