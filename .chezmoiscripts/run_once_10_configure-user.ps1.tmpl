{{ if eq .chezmoi.os "windows" -}}
$source  = ("{{ .chezmoi.sourceDir }}").Replace('/', '\')
$logFile = "$env:TEMP\chezmoi-user-config-$(Get-Date -Format 'yyyyMMdd-HHmmss').log"
$ok = 0; $skip = 0

function Log        { param([string]$msg, [string]$color = "White") $ts = "[$(Get-Date -Format 'HH:mm:ss')]"; $line = "$ts $msg"; Write-Host $line -ForegroundColor $color; Add-Content -Path $logFile -Value $line }
function LogOk      { param([string]$msg) Log "  [OK]   $msg" "Green";  $script:ok++   }
function LogSkip    { param([string]$msg) Log "  [SKIP] $msg" "Yellow"; $script:skip++ }
function LogSection { param([string]$msg) Log "`n-- $msg --" "Cyan" }
function Ask {
    param([string]$Prompt, [string]$Default)
    $answer = Read-Host "$Prompt (default: $Default)"
    if (-not $answer) { return $Default }
    return $answer
}
function PatchFile {
    param([string]$File, [string]$Pattern, [string]$Replacement)
    if (-not (Test-Path $File)) { LogSkip "File not found: $File"; return }
    $content = Get-Content $File -Raw
    $patched = $content -replace $Pattern, $Replacement
    if ($content -ne $patched) {
        Set-Content $File -Value $patched -NoNewline
        LogOk "Patched: $(Split-Path $File -Leaf)"
    } else {
        LogSkip "No change: $(Split-Path $File -Leaf)"
    }
}

Log "User configuration" "Cyan"

# == YASB ======================================================================
LogSection "YASB"
$weatherLocation = Ask "Weather location" "Cantabria, Spain"
PatchFile "$source\dot_config\yasb\config.yaml" '(location:\s*")[^"]*"' "location: `"$weatherLocation`""

# -- Summary -------------------------------------------------------------------
Log "`n-- summary: $ok patched  $skip skipped --" "Cyan"
Log "  Log: $logFile" "Cyan"
{{ end -}}
