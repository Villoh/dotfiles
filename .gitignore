# Claude Code — local session state, not config
.claude/settings.local.json

# Pi agent — local runtime state, not config
.pi/

# State / runtime — not config
**/*.tmp
**/*.log
**/*.bak
**/Cache/
**/cache/
**/Logs/
**/logs/

# Nested git repos (stored as dot_git by chezmoi)
**/dot_git/

# Plugin dirs that reinstall themselves
AppData/Roaming/FlowLauncher/Settings/Plugins/

# bin tool — runtime state, managed by install script
other_config/bin/config.json

# Micro editor state
dot_config/micro/backups/
dot_config/micro/buffers/

# Yazi plugins/flavors — managed via ya pack install
dot_config/yazi/plugins/
dot_config/yazi/flavors/

# OpenCode — runtime deps, not config
dot_config/opencode/node_modules/
dot_config/opencode/bun.lock
dot_config/opencode/package.json

# Local agent skills not meant for git
dot_agents/skills/jira-scrum-cards-acli/
dot_agents/skills/jira-scrum-cards-mcp/

# Superpowers planning artifacts and specs
docs/superpowers/
docs/specs/

# Secrets — generated by chezmoi from Bitwarden, never committed
Documents/PowerShell/Secrets/api-keys.ps1
dot_config/secrets/global-env.sh
dot_config/zsh/functions/api-keys.zsh

# SSH private keys — public keys are safe to track
dot_ssh/*
!dot_ssh/config
!dot_ssh/id_personal.pub

# openvpn profiles
other_config/openvpn/

# PowerShell runtime state
Documents/PowerShell/LastExecutionTime.txt

# Rainmeter — runtime files, only Rainmeter.ini and layouts are config
AppData/Roaming/Rainmeter/Rainmeter.data
AppData/Roaming/Rainmeter/Rainmeter.exe
AppData/Roaming/Rainmeter/Rainmeter.stats
AppData/Roaming/Rainmeter/Layouts/@Backup/

# ytm-player — only config.toml and themes/ are config, rest is runtime state
dot_config/ytm-player/*
!dot_config/ytm-player/config.toml
!dot_config/ytm-player/themes/
# Local Pi runtime state
.atl/
