{
  "registry": [
    {
      "name": "GlazeWM",
      "path": "%USERPROFILE%\\scoop\\apps\\glazewm\\current\\glazewm.exe"
    },
    {
      "name": "YASB",
      "path": "%USERPROFILE%\\scoop\\apps\\yasb\\current\\yasb.exe"
    },
    {
      "name": "AltSnap",
      "path": "%APPDATA%\\AltSnap\\AltSnap.exe",
      "args": "-hide"
    },
    {
      "name": "Ditto",
      "path": "%ProgramFiles%\\Ditto\\Ditto.exe"
    },
    {
      "name": "Flow.Launcher",
      "path": "%LOCALAPPDATA%\\FlowLauncher\\Flow.Launcher.exe"
    },
    {
      "name": "Rainmeter",
      "path": "%ProgramFiles%\\Rainmeter\\Rainmeter.exe"
    },
    {
      "name": "Handy",
      "path": "%USERPROFILE%\\scoop\\apps\\handy\\current\\handy.exe"
    }
  ],
  "msix": [
    {
      "name": "MicaForEveryone",
      "package": "MicaForEveryone.MicaForEveryone2"
    }
  ],
  "scheduler": [
    {
      "name": "ButteryTaskbar",
      "path": "%USERPROFILE%\\scoop\\apps\\buttery-taskbar\\current\\buttery-taskbar.exe",
      "runLevel": "Highest"
    }
  ],
  "folder": [
    {
      "name": "gpg-connect-agent",
      "path": "%ProgramFiles%\\GnuPG\\bin\\gpg-connect-agent.exe",
      "args": "/bye",
      "windowStyle": 7
    }
  ]
}
